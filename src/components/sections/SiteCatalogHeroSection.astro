---
import { BOOKS_URL, WEREAD_NAME } from "../../consts";

const CATALOG_HERO_BOOK_OPTIONS = [
	{
		id: "90000074",
		title: "The Adventures of Tom Sawyer, Complete",
		author: "Mark Twain",
		cover: "https://reader.pub/books/protected-content/90000074/assets/OEBPS/1055025884842794877_cover.jpg",
	},
	{
		id: "90000120",
		title: "Treasure Island",
		author: "Robert Louis Stevenson",
		cover: "https://reader.pub/books/protected-content/90000120/assets/OEBPS/9148187011918732592_cover.jpg",
	},
	{
		id: "90008800",
		title: "The Divine Comedy",
		author: "Dante Alighieri; illustrated by Gustave Dore",
		cover: "https://reader.pub/books/protected-content/90008800/assets/OEBPS/975265859820879404_cover.jpg",
	},
	{
		id: "90014838",
		title: "The Tale of Peter Rabbit",
		author: "Beatrix Potter",
		cover: "https://reader.pub/books/protected-content/90014838/assets/OEBPS/5231809340272607769_peter02.gif.png",
	},
	{
		id: "90055040",
		title: 'The Nursery "Alice"',
		author: "Lewis Carroll",
		cover: "https://reader.pub/books/protected-content/90055040/assets/OEBPS/8035424117275221048_cover.jpg",
	},
	{
		id: "90016865",
		title: "Pinocchio: The Tale of a Puppet",
		author: "Carlo Collodi",
		cover: "https://reader.pub/books/protected-content/90016865/assets/OEBPS/5958518236637178825_illus-022.png",
	},
	{
		id: "90078504",
		title: "The Fairy Caravan",
		author: "Beatrix Potter",
		cover: "https://reader.pub/books/protected-content/90078504/assets/OEBPS/5784209194575853353_cover.jpg",
	},
	{
		id: "90025433",
		title: "The Baby's Own Aesop",
		author: "Aesop; illustrated by Walter Crane",
		cover: "https://reader.pub/books/protected-content/90025433/assets/OEBPS/2611731572878816242_front_cover.png",
	},
	{
		id: "90035997",
		title: "The Jungle Book",
		author: "Rudyard Kipling",
		cover: "https://reader.pub/books/protected-content/90035997/assets/OEBPS/5834958138474680943_cover.jpg",
	},
	{
		id: "90052521",
		title: "Grimm's Fairy Tales",
		author: "Jacob Grimm and Wilhelm Grimm",
		cover: "https://reader.pub/books/protected-content/90052521/assets/OEBPS/3371397222058935216_cover.jpg",
	},
	{
		id: "90071879",
		title: "The Tarzan Twins",
		author: "Edgar Rice Burroughs",
		cover: "https://reader.pub/books/protected-content/90071879/assets/OEBPS/7834129313317133214_cover.jpg",
	},
	{
		id: "90025344",
		title: "The Scarlet Letter",
		author: "Nathaniel Hawthorne",
		cover: "https://reader.pub/books/protected-content/90025344/assets/OEBPS/2874891055637417969_cover.jpg",
	},
];
---

<section class="site-catalog-hero" aria-label="Reader experience preview">
	<div class="site-catalog-hero-top">
		<div class="site-catalog-hero-side">
			<div class="site-catalog-hero-copy">
				<div class="site-catalog-hero-eyebrow">{WEREAD_NAME} – THE BROWSER E-READER</div>
				<h1 class="home-hero-heading">
					60,000+ famous books.<br />
					Genuine eReader.<br />
					Right in your browser.
				</h1>
				<p class="site-catalog-hero-text">
					<span class="site-catalog-hero-text-line">Smooth pages, instant open, preserved reading position, easy Notes, Comments and Sharing.</span>
				</p>
			</div>
		</div>
		<div class="site-catalog-hero-readers" aria-hidden="true">
			<img
				src="/images/readers2.webp"
				alt=""
				loading="lazy"
				decoding="async"
				width="950"
				height="791"
			/>
		</div>
		<div class="site-catalog-hero-actions">
			<details class="site-hero-book-picker">
				<summary class="site-catalog-hero-button site-hero-book-picker-summary">Check it out in WeRead</summary>
				<div class="site-hero-book-picker-menu">
					{CATALOG_HERO_BOOK_OPTIONS.map((book) => (
						<a class="site-hero-book-option" href={`${BOOKS_URL}protected/?id=${book.id}`} target="_blank" rel="noreferrer">
							<img class="site-hero-book-option-cover" src={book.cover} alt="" />
							<span class="site-hero-book-option-body">
								<span class="site-hero-book-option-title">{book.title}</span>
								<span class="site-hero-book-option-author">{book.author}</span>
							</span>
						</a>
					))}
				</div>
			</details>
			<a class="site-catalog-hero-button" href={BOOKS_URL} target="_blank" rel="noreferrer">
				Browse Catalog
			</a>
			<a class="site-catalog-hero-button site-catalog-hero-publish-button" href="https://reader.pub/publish/" target="_blank" rel="noreferrer">
				Publish Your Book
			</a>
		</div>
	</div>
</section>

<script is:inline>
	(() => {
		const heroBookPickers = Array.from(document.querySelectorAll(".site-hero-book-picker"));

		document.addEventListener("keydown", (event) => {
			if (event.key !== "Escape") return;
			heroBookPickers.forEach((picker) => picker.removeAttribute("open"));
		});

		document.addEventListener("click", (event) => {
			heroBookPickers.forEach((picker) => {
				if (picker.contains(event.target)) return;
				picker.removeAttribute("open");
			});
		});
	})();
</script>

<style>
	.site-catalog-hero {
		display: flex;
		flex-direction: column;
		gap: 24px;
		align-items: stretch;
		margin-bottom: 0;
		padding-bottom: 28px;
		width: 100%;
		max-width: 100%;
		min-width: 0;
		overflow-x: clip;
	}

	.site-catalog-hero-top {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 43%);
		grid-template-areas:
			"copy image"
			"actions image";
		column-gap: 32px;
		row-gap: 20px;
		align-items: center;
		width: 100%;
		max-width: 100%;
		min-width: 0;
	}

	.site-catalog-hero-side {
		grid-area: copy;
		grid-column: 1;
		grid-row: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		min-width: 0;
		max-width: none;
		width: 100%;
		gap: 0;
		justify-self: start;
		align-self: center;
	}

	.site-catalog-hero-copy {
		padding: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 16px;
		max-width: 100%;
		width: 100%;
		border: none;
		background: transparent;
		box-shadow: none;
		min-width: 0;
	}

	.site-catalog-hero-copy > * {
		margin: 0;
	}

	.site-catalog-hero-readers {
		grid-area: image;
		grid-column: 2;
		grid-row: 1 / span 2;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		pointer-events: none;
		min-width: 0;
		justify-self: end;
		align-self: center;
		width: 100%;
		max-width: min(480px, 100%);
	}

	.site-catalog-hero-readers img {
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
		transform: none;
	}

	.site-catalog-hero-text-line {
		display: block;
		white-space: normal;
	}

	.site-catalog-hero-text {
		margin: 0;
		max-width: 760px;
		font-size: clamp(16px, 1.55vw, 18px);
		line-height: 1.42;
		color: #586273;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.28em;
		width: 100%;
	}

	.site-catalog-hero-actions {
		grid-area: actions;
		grid-column: 1;
		grid-row: 2;
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		align-items: center;
		justify-content: flex-start;
		width: 100%;
		max-width: 100%;
		min-width: 0;
		margin-top: 10px;
		justify-self: start;
		align-self: start;
	}

	.site-catalog-hero-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 10px 18px;
		border-radius: 999px;
		border: 1px solid var(--accent);
		color: #ffffff;
		background: var(--accent);
		font-weight: 600;
		font-size: 14px;
		line-height: 1.4;
		box-shadow: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		cursor: pointer;
		text-decoration: none;
	}

	.site-catalog-hero-button:hover {
		text-decoration: none;
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(0, 143, 128, 0.2);
	}

	.site-catalog-hero-publish-button {
		background: linear-gradient(135deg, var(--card) 0%, var(--card) 15%, #ffffff 100%);
		color: var(--link);
		border-color: var(--link);
	}

	.site-catalog-hero-publish-button:hover {
		text-decoration: none;
	}

	.site-hero-book-picker {
		position: relative;
	}

	.site-hero-book-picker-summary {
		list-style: none;
		cursor: pointer;
		user-select: none;
	}

	.site-hero-book-picker-summary::-webkit-details-marker {
		display: none;
	}

	.site-hero-book-picker-summary::after {
		content: "▾";
		margin-left: 10px;
		font-size: 14px;
		line-height: 1;
		pointer-events: none;
	}

	.site-hero-book-picker[open] .site-hero-book-picker-summary::after {
		content: "▴";
	}

	.site-hero-book-picker-menu {
		position: absolute;
		top: calc(100% + 10px);
		left: 0;
		z-index: 30;
		width: min(360px, calc(100vw - 48px));
		max-height: 344px;
		overflow-y: auto;
		overscroll-behavior: contain;
		padding: 10px;
		border: 1px solid var(--border);
		border-radius: 18px;
		background: #fffdfa;
		box-shadow: 0 18px 38px rgba(20, 32, 47, 0.12);
		text-align: left;
	}

	.site-hero-book-option {
		display: grid;
		grid-template-columns: 34px minmax(0, 1fr);
		align-items: center;
		justify-items: start;
		gap: 12px;
		padding: 10px 12px;
		border-radius: 12px;
		color: inherit;
		text-decoration: none;
		text-align: left;
	}

	.site-hero-book-option:hover {
		background: #f5fbfa;
		text-decoration: none;
	}

	.site-hero-book-option-cover {
		width: 34px;
		height: 48px;
		border-radius: 5px;
		object-fit: cover;
	}

	.site-hero-book-option-body {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 2px;
		min-width: 0;
		width: 100%;
		text-align: left;
	}

	.site-hero-book-option-title {
		display: block;
		width: 100%;
		font-size: 14px;
		font-weight: 600;
		line-height: 1.2;
		color: #14202f;
		text-align: left;
	}

	.site-hero-book-option-author {
		display: block;
		width: 100%;
		font-size: 12px;
		line-height: 1.25;
		color: #586273;
		text-align: left;
	}

	@media (orientation: portrait) {
		.site-catalog-hero {
			gap: 16px;
			padding-bottom: 20px;
			width: 100%;
			max-width: none;
		}

		.site-catalog-hero-top {
			display: grid;
			grid-template-columns: 1fr;
			grid-template-areas:
				"copy"
				"image"
				"actions";
			row-gap: 16px;
			column-gap: 0;
			align-items: center;
			justify-items: center;
			width: 100%;
			max-width: none;
		}

		.site-catalog-hero-side {
			grid-area: copy;
			grid-column: 1;
			grid-row: auto;
			gap: 0;
			align-items: center;
			max-width: none;
			justify-self: center;
			align-self: center;
			width: 100%;
		}

		.site-catalog-hero-readers {
			grid-area: image;
			grid-column: 1;
			grid-row: auto;
			justify-content: center;
			width: 100%;
			margin-inline: 0;
			max-width: none;
		}

		.site-catalog-hero-readers img {
			width: 100%;
			max-width: 100%;
			transform: none;
		}

		.site-catalog-hero-copy {
			padding: 0;
			align-items: center;
			text-align: center;
			width: 100%;
			max-width: none;
			margin-inline: auto;
			gap: 16px;
		}

		.site-catalog-hero-text-line {
			white-space: normal;
		}

		.site-catalog-hero-text {
			font-size: 16px;
			align-items: center;
			width: 100%;
			text-align: center;
			max-width: none;
			line-height: 1.45;
		}

		.site-catalog-hero-actions {
			grid-area: actions;
			grid-column: 1;
			grid-row: auto;
			width: 100%;
			margin-inline: auto;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			margin-top: 0;
			justify-self: center;
			align-self: center;
		}

		.site-catalog-hero-actions > * {
			width: fit-content;
			max-width: 100%;
		}

		.site-catalog-hero-button {
			width: fit-content;
			max-width: 100%;
		}

		.site-hero-book-picker-menu {
			left: 50%;
			right: auto;
			transform: translateX(-50%);
			width: min(360px, calc(100vw - 32px));
			max-width: calc(100vw - 32px);
			padding: clamp(8px, 2.5vw, 10px);
			text-align: left;
		}

		.site-hero-book-option,
		.site-hero-book-option-body,
		.site-hero-book-option-title,
		.site-hero-book-option-author {
			text-align: left;
		}

		.site-hero-book-option-body {
			align-items: flex-start;
		}

		.site-hero-book-option {
			grid-template-columns: clamp(28px, 8vw, 34px) minmax(0, 1fr);
			gap: clamp(8px, 2.4vw, 12px);
			padding: clamp(8px, 2.4vw, 10px) clamp(8px, 2.8vw, 12px);
		}

		.site-hero-book-option-cover {
			width: clamp(28px, 8vw, 34px);
			height: clamp(40px, 11vw, 48px);
		}

		.site-hero-book-option-title {
			font-size: clamp(14px, 4.1vw, 16px);
			line-height: 1.2;
		}

		.site-hero-book-option-author {
			font-size: clamp(12px, 3.6vw, 14px);
			line-height: 1.25;
		}
	}
</style>

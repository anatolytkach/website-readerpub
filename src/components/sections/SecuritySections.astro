---
import SectionIcon from "../SectionIcon.astro";
import SpecCardsSection from "./SpecCardsSection.astro";

interface Props {
	standalone?: boolean;
}

const { standalone = false } = Astro.props;
---

<section
	class:list={[
		"hero",
		"security-hero",
		!standalone && "platform-security-hero section-continuation",
	]}
>
	<div class="security-hero-copy">
		<div class="menu-eyebrow">SECURITY</div>
		<h1 class="security-hero-title">Protect the book. Control the access.</h1>
		<p class="lede security-hero-primary-lede security-mobile-left-text">
			Most large-scale ebook piracy does not begin by breaking platforms. It begins when a complete book file reaches a user’s device, is extracted, converted, and redistributed.
		</p>
		<img
			class="image-block security-image security-image--mobile"
			src="/images/security.webp"
			alt=""
			aria-hidden="true"
			loading="lazy"
			decoding="async"
			width="897"
			height="791"
		/>
		<p class="security-hero-followup security-mobile-left-text">
			ReaderPub reduces that risk by keeping reading access on the web instead of delivering a downloadable file — while giving you full control over who can access your content and how it is distributed. Web-accessible editions are fully protected against downloading or copying.
		</p>
		<div class="cta-row security-hero-actions">
			<a class="button" href="/contact">Talk to us</a>
			<a class="button secondary" href="/authors">See publishing options</a>
		</div>
	</div>
	<img
		class="image-block security-image security-image--desktop"
		src="/images/security.webp"
		alt="ReaderPub security and controlled access"
		loading="lazy"
		decoding="async"
		width="897"
		height="791"
	/>
</section>

<SpecCardsSection class="section-continue-next security-first-section">
	<h2>How file-based piracy scales</h2>
	<p class="security-mobile-left-text">
		In traditional ebook distribution, a complete file is delivered to the end user. Once that file exists on a device, it becomes the starting point for extraction, conversion, and redistribution.
	</p>
	<div class="card-grid security-steps-grid">
		<div class="card security-step-card">
			<svg class="security-step-icon" viewBox="0 0 298.97 269.23" style="transform: rotate(90deg);"><path d="M298.95 134.03c-0.19,-4.2 -2.71,-7.95 -6.54,-9.69l-276.52 -123.31c-1.46,-0.67 -3.06,-1.02 -4.68,-1.02 -6.19,0 -11.21,5.02 -11.21,11.21 0,1.64 0.36,3.27 1.06,4.76l53.95 118.64 -53.95 118.64c-0.69,1.49 -1.06,3.11 -1.06,4.76 0,6.19 5.02,11.21 11.21,11.21 1.62,0 3.21,-0.35 4.68,-1.02l276.52 -123.31c3.99,-1.82 6.56,-5.81 6.56,-10.2 0,-0.22 -0.01,-0.44 -0.02,-0.66l0 0zm-38.77 0.58l-226.43 100.89 43.79 -96.22c0.67,-1.46 1.02,-3.06 1.02,-4.67 0,-1.61 -0.35,-3.21 -1.02,-4.67l-43.79 -96.22 226.43 100.89 -0 -0z"/></svg>
			<h3>File delivered</h3>
			<p>A complete ebook file reaches the reader’s device.</p>
		</div>
		<div class="card security-step-card">
			<svg class="security-step-icon" viewBox="0 0 298.97 269.23"><path d="M298.95 134.03c-0.19,-4.2 -2.71,-7.95 -6.54,-9.69l-276.52 -123.31c-1.46,-0.67 -3.06,-1.02 -4.68,-1.02 -6.19,0 -11.21,5.02 -11.21,11.21 0,1.64 0.36,3.27 1.06,4.76l53.95 118.64 -53.95 118.64c-0.69,1.49 -1.06,3.11 -1.06,4.76 0,6.19 5.02,11.21 11.21,11.21 1.62,0 3.21,-0.35 4.68,-1.02l276.52 -123.31c3.99,-1.82 6.56,-5.81 6.56,-10.2 0,-0.22 -0.01,-0.44 -0.02,-0.66l0 0zm-38.77 0.58l-226.43 100.89 43.79 -96.22c0.67,-1.46 1.02,-3.06 1.02,-4.67 0,-1.61 -0.35,-3.21 -1.02,-4.67l-43.79 -96.22 226.43 100.89 -0 -0z"/></svg>
			<h3>File extracted</h3>
			<p>The file becomes available for copying outside the original platform.</p>
		</div>
		<div class="card security-step-card">
			<svg class="security-step-icon" viewBox="0 0 298.97 269.23" style="transform: rotate(-90deg);"><path d="M298.95 134.03c-0.19,-4.2 -2.71,-7.95 -6.54,-9.69l-276.52 -123.31c-1.46,-0.67 -3.06,-1.02 -4.68,-1.02 -6.19,0 -11.21,5.02 -11.21,11.21 0,1.64 0.36,3.27 1.06,4.76l53.95 118.64 -53.95 118.64c-0.69,1.49 -1.06,3.11 -1.06,4.76 0,6.19 5.02,11.21 11.21,11.21 1.62,0 3.21,-0.35 4.68,-1.02l276.52 -123.31c3.99,-1.82 6.56,-5.81 6.56,-10.2 0,-0.22 -0.01,-0.44 -0.02,-0.66l0 0zm-38.77 0.58l-226.43 100.89 43.79 -96.22c0.67,-1.46 1.02,-3.06 1.02,-4.67 0,-1.61 -0.35,-3.21 -1.02,-4.67l-43.79 -96.22 226.43 100.89 -0 -0z"/></svg>
			<h3>File converted</h3>
			<p>It can be turned into standard ebook formats for reuse.</p>
		</div>
		<div class="card security-step-card">
			<svg class="security-step-icon security-step-icon--bad" viewBox="0 0 1856.52 1856.44"><path d="M928.26 0c-511.32,0 -928.26,416.94 -928.26,928.18 0,511.24 416.94,928.26 928.26,928.26 511.32,0 928.26,-416.94 928.26,-928.26 0,-511.32 -414.78,-928.18 -928.26,-928.18zm0 116.28c449.86,0 814.13,364.27 814.13,811.98 0,447.71 -364.27,811.98 -814.13,811.98 -449.87,0 -811.98,-362.2 -811.98,-812.06 0,-447.63 362.12,-811.9 811.98,-811.9zm351.08 333.59c-138.26,0 -250.15,111.89 -250.15,250.14 0,138.26 111.89,250.15 250.15,250.15 138.26,0 250.14,-114.13 250.14,-250.15 0,-136.02 -114.12,-250.14 -250.14,-250.14zm-700.01 4.31c-138.26,0 -250.15,114.12 -250.15,250.14 0,136.02 111.89,250.15 250.15,250.15 138.26,0 250.14,-111.89 250.14,-250.15 0,-138.26 -114.12,-250.14 -250.14,-250.14zm700.01 111.97c74.64,0 133.86,59.22 133.86,133.86 0,74.65 -59.22,133.86 -133.86,133.86 -74.65,0 -133.86,-59.22 -133.86,-133.86 0,-74.64 59.22,-133.86 133.86,-133.86zm-700.01 4.4c74.64,0 133.86,59.22 133.86,133.86 0,74.65 -59.22,133.86 -133.86,133.86 -74.65,0 -133.87,-59.22 -133.87,-133.86 0,-74.64 59.22,-133.86 133.87,-133.86zm348.93 458.66c-188.69,0 -344.53,131.71 -386.25,307.21 -6.55,30.69 13.19,61.46 43.88,70.25 30.69,6.55 61.46,-13.19 70.25,-43.88l0 -0.08c28.53,-125.07 138.26,-217.22 272.13,-217.22 133.86,0 243.59,92.15 272.12,217.22 6.55,30.69 37.32,50.51 70.25,43.88 30.69,-6.55 50.51,-37.32 43.88,-70.25 0,0 0,0 0,0 -39.48,-175.58 -197.48,-307.21 -386.25,-307.21l0 0.08z"/></svg>
			<h3>File redistributed</h3>
			<p>Once a reusable file circulates, redistribution can scale quickly.</p>
		</div>
	</div>
	<p style="color: var(--text);">This pattern is repeatable, automatable, and widely used <strong>by book pirates</strong> across the industry!</p>
</SpecCardsSection>

<SpecCardsSection class="section-continuation section-continue-next">
	<div class="security-distribution-layout">
		<div class="security-distribution-copy">
			<h2>Protected distribution without file-first delivery</h2>
			<p class="security-green-copy security-mobile-left-text">
				ReaderPub offers protected web editions: readers access content in the browser through
				WeRead instead of receiving a downloadable book file.
			</p>
			<ul class="bullets">
				<li>Browser-based access instead of file delivery</li>
				<li>User-level and group-level access control</li>
				<li>Protected reading sessions and reduced copy exposure</li>
				<li>Suitable for premium, private, course, and research editions</li>
			</ul>
			<p class="security-theft-guard-text">All your books are fully protected by the patent-pending <strong class="security-theft-guard-name">WeRead Theft Guard</strong> that employs glyph images instead of regular characters, so the text is not accessible to crawling robots.</p>
		</div>
		<div class="footer-cta security-inline-cta security-theft-guard-card">
			<h3>
				<span class="security-theft-guard-highlight">WeRead Theft Guard</span>
			</h3>
			<p class="security-theft-guard-copy security-mobile-left-text">
				Designed to reduce copying, downloading, and unauthorized redistribution.
			</p>
			<ul class="bullets security-theft-guard-list">
				<li>No standard file handoff</li>
				<li>Platform-managed access</li>
				<li>Controlled reading session</li>
			</ul>
			<div class="cta-row security-theft-guard-action">
				<SectionIcon type="security" title="WeRead Theft Guard" />
				<a class="button" href="/authors/#indie-releases">Check it out</a>
			</div>
		</div>
	</div>
</SpecCardsSection>

<SpecCardsSection id="control-who-reads" class="section-continuation section-continue-next">
	<h2>Control who reads — and how your content is used</h2>
	<div class="security-access-layout">
		<div>
			<p>
				ReaderPub gives institutions full control over access to their publications. You decide who can read, under what conditions, and at what level of visibility — from fully public access to restricted, account-based distribution.
			</p>
			<p style="color: var(--text);">
				Access is not only protected at the content level, but also managed at the platform level through administrative controls and structured user access.
			</p>
			<ul class="bullets">
				<li>Define who can access each publication or collection</li>
				<li>Use account-based access for controlled distribution</li>
				<li>Manage teams, roles, and permissions centrally</li>
				<li>Maintain full visibility across all your published content</li>
			</ul>
			<p>Protection is not just about preventing extraction — it is about controlling distribution end-to-end.</p>
		</div>
		<div class="footer-cta security-inline-cta">
			<h3>Need controlled access for your publications?</h3>
			<p class="security-green-copy">
				Set up ReaderPub for your organization with full control over access, teams, and distribution.
			</p>
			<div class="cta-row">
				<a class="button" href="/contact">Talk to us</a>
			</div>
		</div>
	</div>
</SpecCardsSection>

<SpecCardsSection class="section-continuation section-continue-next">
	<h2>Why this matters to authors and publishers</h2>
	<p>
		When a book is distributed as a file, protection depends on controlling what happens after delivery. In the real world, that model has repeatedly led to commercial ebooks circulating outside their original platforms.
	</p>
	<p class="security-black-copy security-mobile-left-text">
		ReaderPub addresses the problem earlier in the chain: by not delivering the primary reading file in the first place, it removes the standard entry point used in large-scale redistribution workflows.
	</p>
	<div class="card-grid security-compare-grid">
		<div class="card">
			<h3>File-based distribution</h3>
			<ul class="bullets">
				<li>A complete file reaches the device</li>
				<li>Protection begins after delivery</li>
				<li>Extraction risk remains part of the model</li>
				<li>Redistribution can scale once a file circulates</li>
			</ul>
		</div>
		<div class="card">
			<h3>ReaderPub</h3>
			<ul class="bullets">
				<li>Primary access stays on the web</li>
				<li>No standard downloadable primary file</li>
				<li>Risk is reduced at the architectural level</li>
				<li>No routine file handoff to each reader</li>
			</ul>
		</div>
	</div>
</SpecCardsSection>

<SpecCardsSection class="section-continuation section-continue-next">
	<div class="security-publish-layout">
		<h2 class="security-publish-title">A practical, honest security position</h2>
		<div class="security-publish-aligned">
			<p class="security-green-copy security-publish-lead security-mobile-left-text">
				No digital system can prevent every form of copying. Screenshots, manual capture, and other low-efficiency methods can still exist.
			</p>
			<div class="card security-publish-body-card">
				<p class="security-black-copy security-mobile-left-text">
					But ReaderPub removes the most scalable starting point for large-scale piracy: delivering a complete, reusable ebook file to the end user. At that, the web-accessible editions are fully protected against downloading or copying.
				</p>
				<p class="security-black-copy security-mobile-left-text">
					ReaderPub’s primary distribution model is web-native. When needed, we can also produce a production-ready EPUB for archival use, external distribution, or additional publishing workflows — without making routine end-user file delivery the default model.
				</p>
			</div>
			<div class="footer-cta security-inline-cta security-publish-cta">
				<h3>Want to publish with lower leakage risk?</h3>
				<p class="security-green-copy security-mobile-left-text">
					Talk to ReaderPub about web-first publishing for authors, publishers, libraries, and institutions.
				</p>
				<div class="cta-row">
					<a class="button" href="/contact">Get started</a>
				</div>
			</div>
		</div>
	</div>
</SpecCardsSection>

<style>
	.security-theft-guard-text {
		color: var(--link);
		font-size: 18px;
		line-height: 1.35;
		max-width: 680px;
	}

	.security-step-card {
		position: relative;
	}

	.security-step-icon {
		position: absolute;
		top: 14px;
		right: 14px;
		width: 28px;
		height: 28px;
		fill: var(--accent);
	}

	.security-step-icon--bad {
		fill: var(--text);
	}

	.platform-security-hero {
		padding-top: 58px;
	}

	.security-image {
		width: min(100%, 420px);
		max-width: 420px;
		max-height: 360px;
		object-fit: contain;
	}

	.security-hero {
		align-items: flex-start;
		padding-bottom: 24px !important;
	}

	.security-hero-copy {
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
		min-width: 0;
	}

	.security-hero-copy > * {
		margin: 0;
	}

	.security-hero-actions {
		justify-content: flex-start;
	}

	.security-image--mobile {
		display: none;
	}

	.security-steps-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
		justify-content: stretch;
	}

	.security-first-section {
		padding-top: 0 !important;
	}

	.security-compare-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		justify-content: stretch;
	}

	.security-inline-cta,
	.security-footer-cta {
		width: 100%;
		max-width: none;
	}

	.security-inline-cta {
		text-align: center;
		justify-items: center;
		padding-top: 36px;
		padding-bottom: 36px;
		max-width: 360px;
		margin-left: auto;
		align-self: center;
	}

	.security-inline-cta .cta-row {
		justify-content: center;
	}

	.security-access-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 360px);
		gap: 24px;
		align-items: center;
	}

	.security-distribution-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 360px);
		gap: 24px;
		align-items: center;
	}

	.security-distribution-copy {
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
		min-width: 0;
	}

	.security-distribution-copy > h2 {
		margin: 0 !important;
	}

	.security-distribution-copy > .bullets {
		margin: 0;
	}

	.security-theft-guard-card {
		align-self: start !important;
	}

	.security-theft-guard-card h3 {
		max-width: 620px;
	}

	.security-theft-guard-card h3 > span {
		display: block;
	}

	.security-theft-guard-card h3 > .security-theft-guard-highlight {
		color: var(--link) !important;
		font-size: 1.18em;
		margin-top: 8px;
	}

	.security-theft-guard-card .security-theft-guard-copy {
		text-align: center;
		margin: 0;
		max-width: 620px;
	}

	.security-theft-guard-card .security-theft-guard-list {
		margin: 0 auto;
		text-align: left;
		width: fit-content;
		max-width: 100%;
	}

	.security-theft-guard-action {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		justify-content: center;
	}

	.security-theft-guard-action :global(.section-icon) {
		width: 48px;
		height: 48px;
	}

	.security-access-layout > :first-child {
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
	}

	.security-access-layout > :first-child > p {
		color: var(--link);
		font-size: 18px;
		line-height: 1.25;
		max-width: 680px;
		margin: 0;
	}

	.security-access-layout > :first-child > .bullets {
		margin: 0;
	}

	.security-footer-actions {
		justify-content: center;
	}

	.security-black-copy {
		color: var(--text) !important;
		font-size: 16px !important;
		line-height: 1.25 !important;
	}

	.security-green-copy {
		color: var(--link) !important;
		font-size: 18px !important;
		line-height: 1.25 !important;
	}

	.security-publish-layout {
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
	}

	.security-publish-title {
		margin: 0 !important;
	}

	.security-publish-aligned {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 360px);
		grid-template-rows: auto minmax(0, 1fr);
		grid-template-areas:
			"lead cta"
			"body cta";
		column-gap: 24px;
		row-gap: var(--section-flow-gap);
		align-items: stretch;
	}

	.security-publish-lead {
		grid-area: lead;
		margin: 0;
		max-width: 680px;
	}

	.security-publish-body-card {
		grid-area: body;
		width: 100%;
		max-width: none;
		min-height: 100%;
		height: 100%;
		text-align: left;
		align-items: stretch;
		align-self: stretch;
	}

	:global(.page .content .security-publish-body-card) > p {
		text-align: left !important;
	}

	.security-publish-body-card > p {
		margin: 0;
		max-width: none;
	}

	.security-publish-body-card .security-black-copy,
	.section > .security-black-copy {
		font-size: 16px !important;
		line-height: 1.25 !important;
	}

	.security-inline-cta p {
		font-size: 16px !important;
		line-height: 1.25 !important;
	}

	.security-publish-cta {
		grid-area: cta;
		max-width: 360px;
		width: 100%;
		margin-left: auto;
		justify-self: end;
		align-self: stretch !important;
		box-sizing: border-box;
		align-content: center;
		padding: 36px 32px !important;
	}

	@media (max-width: 980px) {
		.security-steps-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.security-compare-grid {
			grid-template-columns: 1fr;
		}

		.security-access-layout {
			grid-template-columns: 1fr;
		}

		.security-distribution-layout {
			grid-template-columns: 1fr;
		}

		.security-publish-aligned {
			display: flex;
			flex-direction: column;
			grid-template-columns: unset;
			grid-template-rows: unset;
			grid-template-areas: unset;
		}

		.security-publish-lead,
		.security-publish-body-card,
		.security-publish-cta {
			grid-area: unset;
			min-height: 0;
			height: auto;
		}

		.security-inline-cta,
		.security-publish-cta {
			width: 100% !important;
			max-width: none !important;
			margin-inline: 0 !important;
			align-self: stretch !important;
			justify-self: stretch !important;
			text-align: center;
			justify-items: center;
			align-items: center;
		}

		.security-distribution-copy > h2,
		.security-distribution-copy > .security-green-copy {
			text-align: center;
			width: 100%;
		}

		.security-inline-cta :is(h3, p, span),
		.security-theft-guard-card .security-theft-guard-copy {
			text-align: center;
		}

		.security-publish-lead,
		.security-publish-body-card :is(p, .security-black-copy) {
			text-align: left !important;
		}

		.security-inline-cta .cta-row,
		.security-theft-guard-action {
			justify-content: center;
			margin-inline: auto;
			width: fit-content;
			max-width: 100%;
		}
	}

	@media (max-width: 900px) {
		.security-steps-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (orientation: portrait) and (max-width: 900px) {
		.security-hero {
			display: flex;
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.security-image--desktop {
			display: none;
		}

		.security-image--mobile {
			display: block;
			margin-left: auto;
			margin-right: auto;
		}

		.security-hero-actions {
			flex-direction: column;
			align-items: center;
			justify-content: center;
		}

		.security-hero-primary-lede,
		.security-hero-followup {
			text-align: left !important;
			width: 100%;
		}
	}

	@media (min-width: 721px) {
		.security-hero-actions {
			flex-direction: row !important;
			align-items: center !important;
			justify-content: flex-start !important;
		}
	}

	@media (orientation: landscape) and (max-width: 900px) {
		.security-hero {
			grid-template-columns: minmax(0, 1fr) minmax(0, 36%);
			column-gap: 20px;

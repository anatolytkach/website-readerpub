---
const cards = [
	{
		href: "/readers",
		title: "For Readers",
		headlinePrefix: "Read any book instantly in ",
		product: "WeRead",
		subheadline:
			"Books open directly in your browser with fast search, annotations, and seamless reading across devices.",
	},
	{
		href: "/authors",
		title: "For Authors & Publishers",
		headlinePrefix: "Publish on the web with ",
		product: "WePub",
		subheadline:
			"5% sales commission. Direct reader relationships. First-party analytics. Fan clubs built in.",
	},
	{
		href: "/institutions",
		title: "For Institutions",
		headlinePrefix: "Unlock underused publications through ",
		product: "WePub",
		subheadline:
			"Transform archives, research publications, and digital collections into searchable browser-accessible assets.",
	},
	{
		href: "/webuzz",
		title: "For Discussion",
		headlinePrefix: "Socialize around books in ",
		product: "WeBuzz",
		subheadline:
			"Discuss books, authors, and passages. Connect readers, authors, publishers, and institutions through shared reading.",
	},
];
---

<div class="card-grid audience-nav-grid">
	{
		cards.map((card) => (
			<a class="card audience-nav-card" href={card.href}>
				<span class="audience-nav-card-header">
					<h3>{card.title}</h3>
					<span class="audience-nav-card-arrow" aria-hidden="true">→</span>
				</span>
				<div class="audience-nav-card-copy">
					<p class="audience-nav-card-headline">
						{card.headlinePrefix}<span class="audience-nav-product">{card.product}</span>.
					</p>
					<p class="audience-nav-card-subheadline">{card.subheadline}</p>
				</div>
			</a>
		))
	}
</div>

<style>
	.audience-nav-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
		justify-content: stretch;
		justify-items: stretch;
		width: 100%;
		max-width: none;
	}

	.audience-nav-card {
		background: linear-gradient(315deg, var(--card) 0%, var(--card) 15%, #ffffff 100%);
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
		height: 100%;
		text-align: left;
		text-decoration: none;
		color: inherit;
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.audience-nav-card:hover {
		text-decoration: none;
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(0, 133, 134, 0.12);
	}

	.audience-nav-card-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 12px;
		width: 100%;
	}

	.audience-nav-card h3,
	.audience-nav-card p {
		margin: 0;
	}

	.audience-nav-card h3 {
		min-width: 0;
	}

	.audience-nav-card-arrow {
		flex-shrink: 0;
		color: var(--link);
		font-size: 1.35em;
		line-height: 1.12;
		font-weight: 600;
	}

	.audience-nav-card-copy {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.audience-nav-card-headline {
		font-size: 18px;
		line-height: 1.25;
		color: var(--link);
		text-align: left;
	}

	.audience-nav-product {
		color: var(--text);
		font-family: "Playfair Display", serif;
		font-weight: 700;
	}

	.audience-nav-card-subheadline {
		font-size: 15.3px;
		line-height: 1.35;
		color: var(--text);
		text-align: left;
	}

	@media (max-width: 1100px) {
		.audience-nav-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 900px) and (orientation: portrait) {
		.audience-nav-grid {
			grid-template-columns: 1fr;
		}

		.audience-nav-card .audience-nav-card-headline,
		.audience-nav-card .audience-nav-card-subheadline {
			text-align: center !important;
			width: 100%;
		}
	}
</style>

---
import { BOOKS_URL, WEREAD_NAME } from "../../consts";
import SectionIcon from "../SectionIcon.astro";

const featuredBooks = [
	{
		title: "The Adventures of Tom Sawyer, Complete",
		author: "Mark Twain",
		readUrl: "https://reader.pub/books/protected/?id=90000074",
		coverUrl: "https://reader.pub/books/content/74/OEBPS/5490705198151656392_cover.jpg",
	},
	{
		title: "Treasure Island",
		author: "Robert Louis Stevenson",
		readUrl: "https://reader.pub/books/protected/?id=90000120",
		coverUrl: "https://reader.pub/books/content/120/OEBPS/4692925496734829213_cover.jpg",
	},
	{
		title: "The Divine Comedy",
		author: "Dante Alighieri",
		readUrl: "https://reader.pub/books/protected/?id=90008800",
		coverUrl: "https://reader.pub/books/content/8800/OEBPS/2447739984665842663_cover.jpg",
	},
	{
		title: "The Tale of Peter Rabbit",
		author: "Beatrix Potter",
		readUrl: "https://reader.pub/books/protected/?id=90014838",
		coverUrl: "/images/Peter_Rabbit.webp",
	},
	{
		title: 'The Nursery "Alice"',
		author: "Lewis Carroll",
		readUrl: "https://reader.pub/books/protected/?id=90055040",
		coverUrl: "https://reader.pub/books/content/55040/OEBPS/9181153211494798952_cover.jpg",
	},
	{
		title: "Pinocchio: The Tale of a Puppet",
		author: "Carlo Collodi",
		readUrl: "https://reader.pub/books/protected/?id=90016865",
		coverUrl: "https://reader.pub/books/content/16865/OEBPS/5166451335491288599_illus-cover.jpg",
	},
];
---

<section id="indie-releases" class="section spec-cards-section home-indie-section">
		<div class="indie-protection-layout">
		<div class="indie-protection-copy">
			<h2 class="indie-protection-heading">
				<SectionIcon type="security" title="Protected publication" />
				<span>Your publications on ReaderPub are protected against piracy.</span>
			</h2>
			<p class="indie-protection-intro">
				When you publish your book with us, it is fully protected against downloading or copying by the patent-pending <strong class="indie-theft-guard-name">WeRead Theft Guard</strong>.<br /><span class="indie-protection-intro-note">Check for yourself whether you can copy the text from these books:</span>
			</p>
		</div>
		<div class="indie-protection-books">
			{featuredBooks.map((b) => (
				<a class="book-card-link" href={b.readUrl} target="_blank" rel="noreferrer">
					<div class="card book-card">
						<div class="book-cover-placeholder" style={`background-image: url('${b.coverUrl}');`}></div>
						<div class="book-card-text">
							<h3>{b.title}</h3>
							<p>{b.author}</p>
							<div class="book-card-protected">
								<span>Protected by<br /><strong class="indie-theft-guard-name">WeRead Theft Guard</strong></span>
								<SectionIcon type="security" title="WeRead Theft Guard" />
							</div>
						</div>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.book-card-link {
		display: block;
		width: 100%;
		max-width: none;
		text-decoration: none;
		color: inherit;
		transition: transform 0.15s ease;
	}

	.book-card-link:hover,
	.book-card-link:focus-visible {
		transform: translateY(-2px);
	}

	.indie-protection-layout {
		display: grid;
		grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
		column-gap: 32px;
		align-items: center;
		width: 100%;
	}

	.indie-protection-copy {
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
		min-width: 0;
	}

	.indie-protection-copy > * {
		margin: 0;
	}

	.indie-protection-intro {
		color: var(--link);
		font-size: 18px;
		line-height: 1.35;
		max-width: none !important;
	}

	.indie-protection-intro-note {
		color: var(--text);
	}

	.indie-protection-books {
		display: grid;
		grid-template-columns: repeat(2, minmax(min(100%, 280px), 1fr));
		gap: var(--section-flow-gap);
		align-items: stretch;
		width: 100%;
		min-width: 0;
		justify-content: stretch;
	}

	.home-indie-section {
		scroll-margin-top: 100px;
	}

	.indie-protection-heading {
		display: inline-flex;
		align-items: center;
		gap: 12px;
	}

	.indie-protection-heading > span {
		min-width: 0;
	}

	.indie-protection-heading :global(.section-icon) {
		width: 48px;
		height: 48px;
		flex-shrink: 0;
	}

	.book-card {
		display: flex;
		flex-direction: row;
		gap: 18px;
		align-items: center;
		padding: 18px 20px;
		min-height: 0;
		width: 100%;
		box-sizing: border-box;
	}

	.book-cover-placeholder {
		width: 84px;
		height: 126px;
		border-radius: 2px;
		background: linear-gradient(135deg, #e9eef3, #d8e1ea);
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		flex-shrink: 0;
		box-shadow: 0 3px 10px rgba(13, 28, 45, 0.12);
	}

	.book-card-text {
		display: grid;
		gap: 6px;
		min-width: 0;
		text-align: left;
	}

	.book-card h3 {
		color: var(--link);
		font-size: clamp(16px, 1.25vw, 20px);
		line-height: 1.12;
		font-family: var(--font-display);
		letter-spacing: -0.02em;
		overflow-wrap: anywhere;
	}

	.book-card-text > p {
		margin: 0;
		font-size: clamp(13px, 1.05vw, 16px);
		line-height: 1.3;
		color: var(--text);
	}

	.book-card-protected {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin-top: 8px;
		color: color-mix(in srgb, var(--text) 72%, white 28%);
		font-size: 14px;
		line-height: 1.25;
		max-width: 100%;
	}

	.book-card-protected span {
		min-width: 0;
		overflow-wrap: anywhere;
	}

	.book-card-protected :global(.section-icon) {
		width: 31.2px;
		height: 31.2px;
		flex-shrink: 0;
	}

	.book-card-protected .indie-theft-guard-name {
		color: var(--link);
	}

	.indie-theft-guard-name {
		font-family: "Playfair Display", serif;
		font-weight: 700;
		color: inherit;
	}

	@media (orientation: portrait) {
		.indie-protection-copy {
			align-items: center;
			text-align: center;
		}

		.indie-protection-heading {
			flex-direction: column;
			align-items: center;
			text-align: center;
			width: 100%;
		}

		.indie-protection-heading > span {
			order: 1;
		}

		.indie-protection-heading :global(.section-icon) {
			order: 2;
		}
	}

	@media (max-width: 980px) {
		.indie-protection-layout {
			grid-template-columns: 1fr;
			row-gap: var(--section-flow-gap);
		}
	}

	@media (max-width: 640px) {
		.indie-protection-books {
			grid-template-columns: 1fr;
		}
		.book-card {
			gap: 14px;
			padding: 16px;
		}

		.book-cover-placeholder {
			width: 72px;
			height: 108px;
		}

		.book-card h3 {
			font-size: clamp(16px, 6vw, 20px);
		}
	}
</style>

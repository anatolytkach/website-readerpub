---
import { SITE_NAME } from "../consts";
---

<nav class="nav" transition:persist>
	<div class="nav-brand">
		<img src="/images/logo.svg" alt="ReaderPub" class="site-logo" fetchpriority="high" width="1" height="1" />
		<a class="nav-logo-link" href="/">{SITE_NAME}</a>
	</div>
	<ul class="nav-links">
		<li><a href="/readers">Readers</a></li>
		<li><a href="/authors">Authors</a></li>
		<li><a href="/institutions">Institutions</a></li>
		<li><a href="/webuzz">WeBuzz</a></li>
		<li><a href="/platform">Platform</a></li>
		<li><a href="/security">Security</a></li>
		<li><a href="/pricing">Pricing</a></li>
	</ul>
	<div class="nav-actions">
		<button class="nav-toggle" type="button" aria-label="Open navigation menu" aria-expanded="false">
			<span class="nav-toggle-bar"></span>
			<span class="nav-toggle-bar"></span>
			<span class="nav-toggle-bar"></span>
		</button>
		<a class="button secondary nav-signin" href="https://reader.pub/publish/" target="_blank">Sign in</a>
		<a class="button nav-cta" href="/contact">Get Started</a>
	</div>
</nav>

<div class="nav-overlay" aria-hidden="true">
	<div class="nav-overlay-header">
		<span class="nav-logo">{SITE_NAME}</span>
		<button class="nav-close" type="button" aria-label="Close navigation menu">✕</button>
	</div>
	<ul class="nav-overlay-links">
		<li><a href="https://reader.pub/publish/" target="_blank">Sign in</a></li>
		<li><a href="/contact">Get Started</a></li>
		<li class="nav-overlay-divider" aria-hidden="true"></li>
		<li><a href="/readers">Readers</a></li>
		<li><a href="/authors">Authors</a></li>
		<li><a href="/institutions">Institutions</a></li>
		<li><a href="/webuzz">WeBuzz</a></li>
		<li><a href="/platform">Platform</a></li>
		<li><a href="/security">Security</a></li>
		<li><a href="/pricing">Pricing</a></li>
	</ul>
</div>

<script is:inline>
	(() => {
		if (window.__readerPubNavReady) return;
		window.__readerPubNavReady = true;

		const getNav = () => document.querySelector(".nav");
		const getToggle = () => document.querySelector(".nav-toggle");
		const getOverlay = () => document.querySelector(".nav-overlay");
		const normalizePath = (path) => path.replace(/\/+$/, "") || "/";

		const openMenu = () => {
			const overlay = getOverlay();
			const toggle = getToggle();
			overlay?.classList.add("nav-overlay--open");
			overlay?.setAttribute("aria-hidden", "false");
			toggle?.setAttribute("aria-expanded", "true");
			document.body.classList.add("nav-open");
		};

		const closeMenu = () => {
			const overlay = getOverlay();
			const toggle = getToggle();
			overlay?.classList.remove("nav-overlay--open");
			overlay?.setAttribute("aria-hidden", "true");
			toggle?.setAttribute("aria-expanded", "false");
			document.body.classList.remove("nav-open");
		};

		const updateNavLayout = () => {
			const nav = getNav();
			if (!nav) return;
			const needsCollapse = window.innerWidth < 1000;
			nav.classList.toggle("nav--collapsed", needsCollapse);
		};

		const updateActiveLink = () => {
			const currentPath = normalizePath(window.location.pathname);
			document.querySelectorAll(".nav a, .nav-overlay a").forEach((link) => {
				link.classList.remove("is-active");
				link.removeAttribute("aria-current");
				const href = link.getAttribute("href");
				if (!href || href.startsWith("http")) return;
				if (normalizePath(href) === currentPath) {
					link.classList.add("is-active");
					link.setAttribute("aria-current", "page");
				}
			});
		};

		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			if (target.closest(".nav-toggle")) {
				event.preventDefault();
				openMenu();
				return;
			}

			if (target.closest(".nav-close") || target.closest(".nav-overlay a")) {
				closeMenu();
			}
		});

		document.addEventListener("pointerdown", (event) => {
			const overlay = getOverlay();
			const toggle = getToggle();
			const isOpen = overlay?.classList.contains("nav-overlay--open");
			if (!isOpen) return;
			const target = event.target;
			if (!(target instanceof Node)) return;
			if (overlay?.contains(target)) return;
			if (toggle?.contains(target)) return;
			closeMenu();
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") closeMenu();
		});

		window.addEventListener("resize", updateNavLayout);
		document.addEventListener("astro:page-load", () => {
			closeMenu();
			updateNavLayout();
			updateActiveLink();
		});

		updateNavLayout();
		updateActiveLink();
	})();
</script>

---
import Base from "../layouts/Base.astro";
import { SITE_NAME } from "../consts";
import SectionIcon from "../components/SectionIcon.astro";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
---

<Base title={`${SITE_NAME} WeBuzz`}>
	<section class="webuzz-hero">
		<div class="webuzz-hero-copy">
			<div class="menu-eyebrow">WEBUZZ</div>
			<h1 class="webuzz-hero-title"><span class="webuzz-hero-product">WeBuzz:</span> The social layer of ReaderPub.</h1>
			<p class="lede webuzz-hero-lede">Discuss books, authors, and passages. Connect readers, authors, publishers, and institutions through shared reading.</p>
			<p class="webuzz-hero-body">ReaderPub already helps people publish books, read books, and discover books. WeBuzz adds the missing layer: meaningful discussion around literature. Readers can discuss books and authors, comment on specific passages, and participate in communities built around reading.</p>
		</div>
		<img
			class="image-block webuzz-hero-image"
			src="/images/webuzz.png"
			alt="Readers discussing books, authors, and highlighted passages inside a modern literary social network"
			loading="lazy"
			decoding="async"
			width="794"
			height="847"
		/>
		<div class="cta-row webuzz-hero-actions">
			<a class="button" href="/wetalk/" target="_blank">Open WeBuzz</a>
			<a class="button secondary" href="/platform">Explore ReaderPub Platform</a>
		</div>
	</section>

	<SpecCardsSection class="webuzz-why-section section-continuation section-continue-next">
		<h2>Reading does not end on the last page.</h2>
		<p class="lede">Most reading platforms stop at access. ReaderPub goes further. WeBuzz turns reading into an ongoing conversation. Discussions can happen around entire books, individual authors, or specific passages that readers find meaningful, surprising, or worth debating.</p>
		<div class="card-grid webuzz-three-cards">
			<div class="card">
				<h3>Books</h3>
				<p>Discuss complete works with readers from around the world.</p>
			</div>
			<div class="card">
				<h3>Authors</h3>
				<p>Follow conversations around authors, ideas, and literary movements.</p>
			</div>
			<div class="card">
				<h3>Passages</h3>
				<p>Comment on specific excerpts and continue the discussion in context.</p>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>For Readers</h2>
		<p class="lede">Books become more meaningful when they are discussed. WeBuzz helps readers discover new perspectives, follow thoughtful participants, and participate in literary conversations that continue long after the final chapter.</p>
		<div class="webuzz-split">
			<div>
				<div class="card-grid webuzz-two-cards">
					<div class="card">
						<h3>Discuss Books</h3>
						<p>Start discussions about books you love, dislike, or simply want to understand better.</p>
					</div>
					<div class="card">
						<h3>Discuss Authors</h3>
						<p>Follow conversations around authors and explore connections across their works.</p>
					</div>
					<div class="card">
						<h3>Discuss Passages</h3>
						<p>Comment on specific excerpts and invite others into the conversation.</p>
					</div>
					<div class="card">
						<h3>Follow Readers</h3>
						<p>Build a personalized reading experience by following people whose insights you value.</p>
					</div>
				</div>
			</div>
			<img
				class="image-block webuzz-split-image webuzz-readers-image"
				src="/images/readers_webuzz.png"
				alt="Readers discussing the same book while highlighting passages"
				loading="lazy"
				decoding="async"
				width="950"
				height="791"
			/>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>For Authors</h2>
		<p class="lede">Authors can participate directly in conversations around their books. Discussions are not limited to reviews. Readers can respond to ideas, scenes, characters, and individual passages, creating a deeper relationship between authors and audiences.</p>
		<div class="webuzz-split">
			<div>
				<div class="card-grid webuzz-two-cards">
					<div class="card">
						<h3>Meet Readers</h3>
						<p>Engage directly with people reading your work.</p>
					</div>
					<div class="card">
						<h3>Answer Questions</h3>
						<p>Respond to discussions and provide additional context.</p>
					</div>
					<div class="card">
						<h3>Build Communities</h3>
						<p>Create lasting engagement around books and series.</p>
					</div>
					<div class="card">
						<h3>Stay Visible</h3>
						<p>Keep conversations active long after publication.</p>
					</div>
				</div>
			</div>
			<img
				class="image-block webuzz-split-image webuzz-author-image"
				src="/images/author_webuzz.webp"
				alt="Author participating in a discussion with readers around a book"
				loading="lazy"
				decoding="async"
				width="1024"
				height="841"
			/>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>For Publishers</h2>
		<p class="lede">Publishing does not end when a book is released. WeBuzz gives publishers a way to encourage discussion, maintain visibility, and support communities around authors and titles.</p>
		<div class="webuzz-split">
			<div>
				<div class="card-grid webuzz-two-cards">
					<div class="card">
						<h3>Reader Engagement</h3>
					</div>
					<div class="card">
						<h3>Book Discovery</h3>
					</div>
					<div class="card">
						<h3>Community Building</h3>
					</div>
					<div class="card">
						<h3>Long-Term Visibility</h3>
					</div>
				</div>
			</div>
			<img
				class="image-block webuzz-split-image webuzz-publisher-image"
				src="/images/publisher_webuzz.png"
				alt="Publisher observing active discussions around multiple books"
				loading="lazy"
				decoding="async"
				width="950"
				height="791"
			/>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>For Libraries and Universities</h2>
		<p class="lede">Reading programs, book clubs, courses, and collections become more valuable when discussion is built into the experience.</p>
		<div class="webuzz-split">
			<div>
				<div class="card-grid webuzz-two-cards">
					<div class="card">
						<h3>Book Clubs</h3>
						<p>Support digital reading communities.</p>
					</div>
					<div class="card">
						<h3>Reading Programs</h3>
						<p>Encourage ongoing engagement with collections.</p>
					</div>
					<div class="card">
						<h3>Classroom Discussion</h3>
						<p>Extend discussion beyond the classroom.</p>
					</div>
					<div class="card">
						<h3>Research Communities</h3>
						<p>Bring students and researchers together around texts.</p>
					</div>
				</div>
			</div>
			<img
				class="image-block webuzz-split-image webuzz-libraries-image"
				src="/images/libraries_webuzz.png"
				alt="University students discussing books in a collaborative reading environment"
				loading="lazy"
				decoding="async"
				width="950"
				height="769"
			/>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>Four products. One connected platform.</h2>
		<p class="lede">ReaderPub combines publishing, reading, discovery, and discussion into a single ecosystem.</p>
		<div class="card-grid webuzz-four-cards">
			<div class="card">
				<h3>WePub</h3>
				<p>Publish books.</p>
				<a class="button secondary" href="/authors">Explore WePub</a>
			</div>
			<div class="card">
				<h3>WeRead</h3>
				<p>Read books.</p>
				<a class="button secondary" href="/readers">Explore WeRead</a>
			</div>
			<div class="card">
				<h3>BookTree</h3>
				<p>Discover books.</p>
				<a class="button secondary" href="/platform">Explore BookTree</a>
			</div>
			<div class="card">
				<h3>WeBuzz</h3>
				<p>Discuss books.</p>
				<a class="button" href="/wetalk/" target="_blank">Open WeBuzz</a>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>Three ways to join the conversation.</h2>
		<div class="card-grid webuzz-three-cards">
			<div class="card">
				<h3>Book Discussions</h3>
				<p>Talk about complete books and reading experiences.</p>
			</div>
			<div class="card">
				<h3>Author Discussions</h3>
				<p>Discuss authors, ideas, and literary influence.</p>
			</div>
			<div class="card">
				<h3>Passage Discussions</h3>
				<p>Start conversations around specific excerpts and quotations.</p>
			</div>
		</div>
	</SpecCardsSection>

	<section class="footer-cta webuzz-footer-cta">
		<h2>Join the conversation.</h2>
		<p class="lede">Whether you are a reader, author, publisher, librarian, or educator, WeBuzz gives you a place to connect through literature.</p>
		<div class="cta-row webuzz-footer-cta-row">
			<a class="button" href="/wetalk/" target="_blank">Open WeBuzz</a>
			<a class="button secondary" href="/">Explore ReaderPub</a>
		</div>
	</section>

	<section class="section webuzz-shared-section section-continuation">
		<h2>Reading becomes more meaningful when it is shared.</h2>
		<p class="lede">ReaderPub combines publishing, reading, discovery, and discussion in one ecosystem. Through WeBuzz, readers can discuss books, follow thoughtful readers, engage with authors, and participate in literary communities.</p>
		<ul class="bullets">
			<li>Discuss books and authors</li>
			<li>Comment on specific passages</li>
			<li>Follow readers and literary experts</li>
			<li>Engage directly with authors</li>
			<li>Discover books through conversation</li>
		</ul>
		<div class="cta-row">
			<a class="button" href="/wetalk/" target="_blank">Explore WeBuzz</a>
		</div>
	</section>

	<SpecCardsSection class="section-continuation webuzz-community-section">
		<div class="card-grid webuzz-community-grid">
			<div class="card icon-grid-card">
				<SectionIcon type="fan" title="WeBuzz communities for every book and author" />
				<div class="icon-grid-card-copy">
					<h2>WeBuzz communities for every book and author.</h2>
					<p>
						WeBuzz is ReaderPub's integrated literary social network, connecting readers, authors, and publishers through discussions, reactions, and shared reading experiences around every book.
					</p>
					<ul class="bullets">
						<li>Members-only posts, updates, and behind-the-scenes notes.</li>
						<li>Early access, bonus chapters, and limited drops.</li>
						<li>Direct announcements to your registered audience.</li>
						<li>Fan insights tied to sales — what converts and retains.</li>
					</ul>
				</div>
			</div>
		</div>
	</SpecCardsSection>

	<style>
		.webuzz-hero {
			display: grid;
			grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
			column-gap: 32px;
			row-gap: 16px;
			align-items: center;
			padding-bottom: 28px;
		}

		.webuzz-hero > * {
			min-width: 0;
		}

		.webuzz-hero-title {
			font-size: clamp(36px, 5vw, 56px);
			line-height: 1.1;
			margin-bottom: 0;
		}

		.webuzz-hero-title .webuzz-hero-product {
			color: var(--link) !important;
		}

		.webuzz-hero-lede {
			color: var(--link) !important;
			font-size: 22.95px !important;
			line-height: 1.45 !important;
			margin: 0;
		}

		.webuzz-hero-body {
			color: var(--text);
			font-size: 22.95px;
			line-height: 1.45;
			margin: 0;
		}

		.webuzz-hero-copy {
			grid-column: 1;
			grid-row: 1;
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
		}

		.webuzz-hero-image {
			grid-column: 2;
			grid-row: 1 / span 2;
			margin-left: auto;
			margin-right: 0;
		}

		.webuzz-hero-actions {
			grid-column: 1;
			grid-row: 2;
			justify-content: flex-start;
		}

		.webuzz-why-section {
			padding-top: 28px !important;
		}

		.webuzz-three-cards {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.webuzz-four-cards {
			grid-template-columns: repeat(4, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.webuzz-community-grid {
			grid-template-columns: 1fr;
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.webuzz-two-cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.webuzz-split {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 368px);
			gap: 32px;
			align-items: start;
		}

		.webuzz-split-image {
			align-self: center;
			justify-self: end;
			max-width: 368px !important;
		}

		.webuzz-readers-image {
			width: 100%;
			height: auto;
			aspect-ratio: auto;
			object-fit: contain;
		}

		.webuzz-author-image {
			width: 100%;
			height: auto;
			aspect-ratio: auto;
			object-fit: contain;
		}

		.webuzz-publisher-image {
			width: 100%;
			height: auto;
			aspect-ratio: auto;
			object-fit: contain;
		}

		.webuzz-libraries-image {
			width: 100%;
			height: auto;
			aspect-ratio: auto;
			object-fit: contain;
		}

		.webuzz-footer-cta {
			width: 100%;
			max-width: none;
			padding: 29px 32px !important;
		}

		.webuzz-footer-cta-row {
			justify-content: center !important;
			width: 100%;
		}

		@media (max-width: 1024px) {
			.webuzz-three-cards,
			.webuzz-four-cards {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}

		@media (orientation: portrait) {
			.webuzz-hero-lede,
			.webuzz-hero-body {
				font-size: 18.36px !important;
				line-height: 1.45 !important;
			}

			.webuzz-hero {
				grid-template-columns: 1fr;
				align-items: center;
				justify-items: center;
				text-align: center;
			}

			.webuzz-hero-copy {
				text-align: center;
				align-items: center;
			}

			.webuzz-hero-copy,
			.webuzz-hero-image,
			.webuzz-hero-actions {
				grid-column: 1;
			}

			.webuzz-hero-copy {
				grid-row: 1;
			}

			.webuzz-hero-image {
				grid-row: 2;
				margin-left: auto;
				margin-right: auto;
			}

			.webuzz-hero-actions {
				grid-row: 3;
				justify-content: center;
			}

			.webuzz-three-cards,
			.webuzz-four-cards,
			.webuzz-two-cards {
				grid-template-columns: 1fr;
			}

			.webuzz-split {
				grid-template-columns: 1fr;
			}

			.webuzz-split-image {
				max-width: 100% !important;
				justify-self: center;
			}
		}

		@media (max-width: 900px) {
			.webuzz-three-cards,
			.webuzz-four-cards,
			.webuzz-two-cards {
				grid-template-columns: 1fr;
			}

			.webuzz-split {
				grid-template-columns: 1fr;
			}
		}

		@media (orientation: landscape) and (max-width: 900px) {
			.webuzz-hero {
				grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
				column-gap: 20px;
				padding-bottom: 16px;
			}

			.webuzz-hero-title {
				font-size: clamp(28px, 4.5vw, 42px);
			}

			.webuzz-hero-lede,
			.webuzz-hero-body {
				font-size: 15.3px !important;
				line-height: 1.35 !important;
			}

			.webuzz-hero-image {
				max-width: 100% !important;
			}
		}

		@media (max-width: 400px) {
			.webuzz-hero-lede,
			.webuzz-hero-body {
				font-size: 16.15px !important;
			}
		}
	</style>
</Base>

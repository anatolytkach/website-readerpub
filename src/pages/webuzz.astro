---
import Base from "../layouts/Base.astro";
import { SITE_NAME } from "../consts";
import SectionIcon from "../components/SectionIcon.astro";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
---

<Base title={`${SITE_NAME} WeBuzz`}>
	<section class="webuzz-hero">
		<div class="webuzz-hero-copy">
			<div class="menu-eyebrow">WEBUZZ</div>
			<h1 class="webuzz-hero-title"><span class="webuzz-hero-product">WeBuzz:</span> The social layer of ReaderPub.</h1>
			<p class="lede webuzz-hero-lede">Discuss books, authors, and passages. Connect readers, authors, publishers, and institutions through shared reading.</p>
			<p class="webuzz-hero-body">WeBuzz is ReaderPub's integrated literary social network, connecting readers, authors, and publishers through discussions, reactions, and shared reading experiences around every book.</p>
		</div>
		<img
			class="image-block webuzz-hero-image"
			src="/images/webuzz.png"
			alt="Readers discussing books, authors, and highlighted passages inside a modern literary social network"
			loading="lazy"
			decoding="async"
			width="794"
			height="847"
		/>
		<div class="cta-row webuzz-hero-actions">
			<a class="button" href="/wetalk/" target="_blank">Join the conversation in WeBuzz</a>
		</div>
	</section>

	<SpecCardsSection class="webuzz-why-section section-continuation section-continue-next">
		<div class="webuzz-overview-layout">
			<div class="card webuzz-overview-card">
				<div class="webuzz-overview-card-heading">
					<SectionIcon type="fan" title="Three ways to join the conversation" />
					<h2>Three ways to join the conversation:</h2>
				</div>
				<ul class="webuzz-overview-list" role="list">
					<li class="webuzz-overview-item">
						<span class="webuzz-overview-bullet" aria-hidden="true"></span>
						<div class="webuzz-overview-item-copy">
							<h2 class="webuzz-overview-item-title">Book Discussions</h2>
							<span>Talk about complete books and reading experiences.</span>
						</div>
					</li>
					<li class="webuzz-overview-item">
						<span class="webuzz-overview-bullet" aria-hidden="true"></span>
						<div class="webuzz-overview-item-copy">
							<h2 class="webuzz-overview-item-title">Author Discussions</h2>
							<span>Discuss authors, ideas, and literary influence.</span>
						</div>
					</li>
					<li class="webuzz-overview-item">
						<span class="webuzz-overview-bullet" aria-hidden="true"></span>
						<div class="webuzz-overview-item-copy">
							<h2 class="webuzz-overview-item-title">Passage Discussions</h2>
							<span>Start conversations around specific excerpts and quotations.</span>
						</div>
					</li>
				</ul>
			</div>
			<div class="webuzz-overview-copy">
				<h2>Reading does not end on the last page.</h2>
				<p class="lede">Most reading platforms stop at access. ReaderPub goes further. WeBuzz turns reading into an ongoing conversation. Discussions can happen around entire books, individual authors, or specific passages that readers find meaningful, surprising, or worth debating.</p>
				<p class="lede webuzz-why-body">Reading becomes more meaningful when it is shared. ReaderPub combines publishing, reading, discovery, and discussion in one ecosystem. Through WeBuzz, readers can discuss books, follow thoughtful readers, engage with authors, and participate in literary communities.</p>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>For Readers</h2>
		<p class="lede">Books become more meaningful when they are discussed. WeBuzz helps readers discover new perspectives, follow thoughtful participants, and participate in literary conversations that continue long after the final chapter.</p>
		<div class="webuzz-split">
			<div>
				<div class="card-grid webuzz-two-cards">
					<div class="card">
						<h3>Discuss Books</h3>
						<p>Start discussions about books you love, dislike, or simply want to understand better.</p>
					</div>
					<div class="card">
						<h3>Discuss Authors</h3>
						<p>Follow conversations around authors and explore connections across their works.</p>
					</div>
					<div class="card">
						<h3>Discuss Passages</h3>
						<p>Comment on specific excerpts and invite others into the conversation.</p>
					</div>
					<div class="card">
						<h3>Follow Readers</h3>
						<p>Build a personalized reading experience by following people whose insights you value.</p>
					</div>
				</div>
			</div>
			<div class="webuzz-split-image-frame">
				<img
					class="image-block webuzz-split-image webuzz-readers-image"
					src="/images/readers_webuzz.png"
					alt="Readers discussing the same book while highlighting passages"
					loading="lazy"
					decoding="async"
					width="950"
					height="791"
				/>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>For Authors</h2>
		<p class="lede">Authors can participate directly in conversations around their books. Discussions are not limited to reviews. Readers can respond to ideas, scenes, characters, and individual passages, creating a deeper relationship between authors and audiences.</p>
		<div class="webuzz-split">
			<div>
				<div class="card-grid webuzz-two-cards">
					<div class="card">
						<h3>Meet Readers</h3>
						<p>Engage directly with people reading your work.</p>
					</div>
					<div class="card">
						<h3>Answer Questions</h3>
						<p>Respond to discussions and provide additional context.</p>
					</div>
					<div class="card">
						<h3>Build Communities</h3>
						<p>Create lasting engagement around books and series.</p>
					</div>
					<div class="card">
						<h3>Stay Visible</h3>
						<p>Keep conversations active long after publication.</p>
					</div>
				</div>
			</div>
			<div class="webuzz-split-image-frame">
				<img
					class="image-block webuzz-split-image webuzz-author-image"
					src="/images/author_webuzz.webp"
					alt="Author participating in a discussion with readers around a book"
					loading="lazy"
					decoding="async"
					width="1024"
					height="841"
				/>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>For Publishers</h2>
		<p class="lede">Publishing does not end when a book is released. WeBuzz gives publishers a way to encourage discussion, maintain visibility, and support communities around authors and titles.</p>
		<div class="webuzz-split">
			<div>
				<div class="card-grid webuzz-two-cards">
					<div class="card">
						<h3>Reader Engagement</h3>
						<p>Build lasting relationships with readers through discussions around books, authors, and individual passages.</p>
					</div>
					<div class="card">
						<h3>Book Discovery</h3>
						<p>Help readers discover titles through conversations, recommendations, and community-driven exploration.</p>
					</div>
					<div class="card">
						<h3>Community Building</h3>
						<p>Create active communities around authors, series, genres, and publishing programs.</p>
					</div>
					<div class="card">
						<h3>Long-Term Visibility</h3>
						<p>Keep books relevant long after publication through ongoing discussion and reader participation.</p>
					</div>
				</div>
			</div>
			<div class="webuzz-split-image-frame">
				<img
					class="image-block webuzz-split-image webuzz-publisher-image"
					src="/images/publisher_webuzz.png"
					alt="Publisher observing active discussions around multiple books"
					loading="lazy"
					decoding="async"
					width="950"
					height="791"
				/>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>For Libraries and Universities</h2>
		<p class="lede">Reading programs, book clubs, courses, and collections become more valuable when discussion is built into the experience.</p>
		<div class="webuzz-split">
			<div>
				<div class="card-grid webuzz-two-cards">
					<div class="card">
						<h3>Book Clubs</h3>
						<p>Support digital reading communities.</p>
					</div>
					<div class="card">
						<h3>Reading Programs</h3>
						<p>Encourage ongoing engagement with collections.</p>
					</div>
					<div class="card">
						<h3>Classroom Discussion</h3>
						<p>Extend discussion beyond the classroom.</p>
					</div>
					<div class="card">
						<h3>Research Communities</h3>
						<p>Bring students and researchers together around texts.</p>
					</div>
				</div>
			</div>
			<div class="webuzz-split-image-frame">
				<img
					class="image-block webuzz-split-image webuzz-libraries-image"
					src="/images/libraries_webuzz.png"
					alt="University students discussing books in a collaborative reading environment"
					loading="lazy"
					decoding="async"
					width="950"
					height="769"
				/>
			</div>
		</div>
	</SpecCardsSection>

	<section class="footer-cta webuzz-footer-cta">
		<h2>Join the conversation.</h2>
		<p class="lede">Whether you are a reader, author, publisher, librarian, or educator, WeBuzz gives you a place to connect through literature.</p>
		<div class="cta-row webuzz-footer-cta-row">
			<a class="button" href="/wetalk/" target="_blank">Open WeBuzz</a>
		</div>
	</section>

	<style>
		:global(section.webuzz-hero),
		:global(section.webuzz-footer-cta),
		:global(section.spec-cards-section) {
			padding-top: 55px;
			padding-bottom: 28px;
		}

		:global(section.spec-cards-section.section-continue-next) {
			padding-bottom: 28px !important;
		}

		:global(section.spec-cards-section.section-continuation) {
			padding-top: 55px !important;
			padding-bottom: 28px !important;
		}

		.webuzz-hero {
			display: grid;
			grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
			column-gap: 32px;
			row-gap: 16px;
			align-items: center;
			padding-bottom: 28px;
		}

		.webuzz-hero > * {
			min-width: 0;
		}

		.webuzz-hero-title {
			font-size: clamp(36px, 5vw, 56px);
			line-height: 1.1;
			margin-bottom: 0;
		}

		.webuzz-hero-title .webuzz-hero-product {
			color: var(--link) !important;
		}

		.webuzz-hero-lede {
			color: var(--link) !important;
			font-size: 22.95px !important;
			line-height: 1.45 !important;
			margin: 0;
		}

		.webuzz-hero-body {
			color: var(--text);
			font-size: 22.95px;
			line-height: 1.45;
			margin: 0;
		}

		.webuzz-why-body {
			color: var(--text);
			margin: 0;
		}

		.webuzz-overview-copy > .lede,
		.webuzz-overview-copy > .webuzz-why-body {
			font-size: 18px !important;
			line-height: 1.45 !important;
		}

		.webuzz-hero-copy {
			grid-column: 1;
			grid-row: 1;
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
		}

		.webuzz-hero-image {
			grid-column: 2;
			grid-row: 1 / span 2;
			margin-left: auto;
			margin-right: 0;
		}

		.webuzz-hero-actions {
			grid-column: 1;
			grid-row: 2;
			justify-content: flex-start;
			margin-top: -8px;
		}

		.webuzz-why-section {
			padding-top: 28px !important;
		}

		.webuzz-overview-layout {
			display: grid;
			grid-template-columns: minmax(320px, 0.85fr) minmax(0, 1.15fr);
			gap: 32px;
			align-items: center;
		}

		.webuzz-overview-copy,
		.webuzz-overview-card {
			min-width: 0;
		}

		.webuzz-overview-copy {
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			gap: var(--section-flow-gap);
			align-self: center;
		}

		.webuzz-overview-copy > h2,
		.webuzz-overview-copy > p,
		.webuzz-overview-copy > ul {
			margin: 0;
		}

		.webuzz-overview-copy .bullets {
			padding-left: 1.4rem;
		}

		.webuzz-overview-card {
			--webuzz-card-heading-size: clamp(19px, 1.62vw, 26px);
			--webuzz-discussion-heading-size: calc(var(--webuzz-card-heading-size) * 0.9);
		}

		.webuzz-overview-card h2 {
			margin-top: 0;
		}

		.webuzz-overview-card-heading {
			display: flex;
			align-items: center;
			gap: 16px;
			width: 100%;
		}

		.webuzz-overview-card-heading h2 {
			margin: 0;
			font-size: var(--webuzz-card-heading-size);
			line-height: 1.12;
			flex: 1;
			min-width: 0;
		}

		.webuzz-overview-card {
			display: flex;
			flex-direction: column;
			gap: 20px;
		}

		.webuzz-overview-list {
			list-style: none;
			margin: 0;
			padding-left: 0;
		}

		.webuzz-overview-item-title,
		.webuzz-overview-item span {
			display: block;
		}

		.webuzz-overview-item-title {
			color: var(--accent);
			margin: 0 0 10px 0;
			font-size: var(--webuzz-discussion-heading-size);
			line-height: 1.12;
		}

		.webuzz-overview-item span {
			font-size: 16px;
			line-height: 1.28;
			color: var(--muted);
		}

		.webuzz-overview-item {
			display: grid;
			grid-template-columns: 56px minmax(0, 1fr);
			column-gap: 16px;
			align-items: start;
			margin-bottom: 20px;
		}

		.webuzz-overview-bullet {
			width: 8.5px;
			height: 8.5px;
			border-radius: 50%;
			background: var(--accent);
			justify-self: center;
			margin-top: 10px;
		}

		.webuzz-overview-item-copy {
			min-width: 0;
		}

		.webuzz-overview-item:last-child {
			margin-bottom: 0;
		}

		.webuzz-three-cards {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.webuzz-two-cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.webuzz-split {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 368px);
			gap: 32px;
			align-items: stretch;
		}

		.webuzz-split-image-frame {
			position: relative;
			align-self: stretch;
			justify-self: end;
			width: 100%;
			max-width: 368px;
			min-height: 0;
		}

		.webuzz-split-image {
			position: absolute;
			inset: 0;
			height: 100%;
			width: 100%;
			max-width: 368px !important;
			object-position: center bottom;
		}

		.webuzz-readers-image {
			width: 100%;
			height: 100%;
			aspect-ratio: auto;
			object-fit: contain;
			object-position: center bottom;
		}

		.webuzz-author-image {
			width: 100%;
			height: 100%;
			aspect-ratio: auto;
			object-fit: contain;
			object-position: center bottom;
		}

		.webuzz-publisher-image {
			width: 100%;
			height: 100%;
			aspect-ratio: auto;
			object-fit: contain;
			object-position: center bottom;
		}

		.webuzz-libraries-image {
			width: 100%;
			height: 100%;
			aspect-ratio: auto;
			object-fit: contain;
			object-position: center bottom;
		}

		.webuzz-footer-cta {
			width: 100%;
			max-width: none;
			margin-top: 28px;
			padding: 28px 32px !important;
		}

		.webuzz-footer-cta-row {
			justify-content: center !important;
			width: 100%;
		}

		@media (orientation: landscape) {
			.webuzz-footer-cta {
				width: 50%;
				max-width: none;
				margin-left: auto;
				margin-right: auto;
			}
		}

		@media (max-width: 1024px) {
			.webuzz-three-cards {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			.webuzz-overview-layout {
				grid-template-columns: 1fr;
			}
		}

		@media (orientation: portrait) {
			.webuzz-hero-lede,
			.webuzz-hero-body {
				font-size: 18.36px !important;
				line-height: 1.45 !important;
			}

			.webuzz-hero {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
			}

			.webuzz-hero-copy {
				display: contents;
			}

			.webuzz-hero-copy .menu-eyebrow {
				order: 1;
			}

			.webuzz-hero-title {
				order: 2;
				width: 100%;
				text-align: center;
			}

			.webuzz-hero-lede {
				order: 3;
				width: 100%;
				text-align: center;
			}

			.webuzz-hero-body {
				order: 5;
				width: 100%;
				text-align: left !important;
			}

			.webuzz-hero-image {
				order: 4;
				width: min(100%, 540px);
				max-width: 100% !important;
				margin-left: auto;
				margin-right: auto;
			}

			.webuzz-hero-actions {
				order: 6;
				justify-content: center;
				margin-top: 0;
			}

			.webuzz-overview-card {
				align-items: stretch;
				text-align: left !important;
			}

			.webuzz-overview-card-heading {
				justify-content: flex-start;
				text-align: left !important;
				width: 100%;
			}

			.webuzz-overview-card-heading h2,
			.webuzz-overview-item-title,
			.webuzz-overview-item span {
				text-align: left !important;
			}

			.webuzz-overview-copy {
				text-align: left !important;
			}

			.webuzz-overview-copy > .lede,
			.webuzz-overview-copy > .webuzz-why-body,
			:global(section.spec-cards-section > .lede) {
				text-align: left !important;
			}

			:global(.page .content .webuzz-hero p.webuzz-hero-body),
			:global(.page .content .webuzz-overview-copy > p.lede),
			:global(.page .content section.spec-cards-section > p.lede) {
				text-align: left !important;
			}

			:global(.page .content .card.webuzz-overview-card),
			:global(.page .content .card.webuzz-overview-card *) {
				text-align: left !important;
			}

			:global(.page .content .card.webuzz-overview-card) {
				align-items: stretch !important;
			}

			:global(.page .content .card.webuzz-overview-card .webuzz-overview-card-heading) {
				justify-content: flex-start !important;
				align-items: center !important;
				width: 100% !important;
			}

			:global(.page .content .card.webuzz-overview-card .webuzz-overview-card-heading h2),
			:global(.page .content .card.webuzz-overview-card .webuzz-overview-item-copy),
			:global(.page .content .card.webuzz-overview-card .webuzz-overview-item-title),
			:global(.page .content .card.webuzz-overview-card .webuzz-overview-item-copy > span) {
				width: 100% !important;
				max-width: none !important;
				margin-left: 0 !important;
				margin-right: 0 !important;
			}

			:global(.page .content .card.webuzz-overview-card .webuzz-overview-list) {
				width: 100% !important;
			}

			:global(.page .content .card.webuzz-overview-card .webuzz-overview-card-heading),
			:global(.page .content .card.webuzz-overview-card .webuzz-overview-item) {
				display: grid !important;
				grid-template-columns: 56px minmax(0, 1fr) !important;
				column-gap: 16px !important;
				width: 100% !important;
				align-items: start !important;
			}

			:global(.page .content .card.webuzz-overview-card .webuzz-overview-card-heading) {
				align-items: center !important;
			}

			:global(.page .content .card.webuzz-overview-card .webuzz-overview-card-heading .section-icon),
			:global(.page .content .card.webuzz-overview-card .webuzz-overview-bullet) {
				justify-self: center !important;
			}

			:global(.page .content .card.webuzz-overview-card .webuzz-overview-bullet) {
				display: block !important;
				width: 8.5px !important;
				min-width: 8.5px !important;
				max-width: 8.5px !important;
				height: 8.5px !important;
				min-height: 8.5px !important;
				max-height: 8.5px !important;
				border-radius: 50% !important;
				margin-top: 10px !important;
			}

			.webuzz-three-cards,
			.webuzz-two-cards {
				grid-template-columns: 1fr;
			}

			.webuzz-split {
				grid-template-columns: 1fr;
			}

			.webuzz-split > :first-child {
				order: 2;
			}

			.webuzz-split-image-frame {
				order: 1;
				position: static;
				align-self: auto;
				justify-self: center;
				width: min(100%, 368px);
				max-width: 100%;
				min-height: auto;
			}

			.webuzz-split-image {
				position: static;
				inset: auto;
				display: block;
				width: 100%;
				height: auto;
				max-width: 100% !important;
				justify-self: center;
			}
		}

		@media (max-width: 900px) {
			.webuzz-three-cards,
			.webuzz-two-cards {
				grid-template-columns: 1fr;
			}

			.webuzz-split {
				grid-template-columns: 1fr;
			}
		}

		@media (orientation: landscape) and (max-width: 900px) {
			.webuzz-hero {
				grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
				column-gap: 20px;
				padding-bottom: 16px;
			}

			.webuzz-hero-title {
				font-size: clamp(23.8px, 3.825vw, 35.7px) !important;
			}

			.webuzz-hero-lede,
			.webuzz-hero-body {
				font-size: 15.3px !important;

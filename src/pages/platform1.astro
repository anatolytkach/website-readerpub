---
import Base from "../layouts/Base.astro";
import { SITE_NAME } from "../consts";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
---

<Base title={`${SITE_NAME} Platform1`}>
	<section class="platform1-hero section-continue-next">
		<div class="platform1-hero-grid">
			<h1 class="platform1-hero-title">
				Publish books to the web.<br />
				Protect access.<br />
				Understand readers.
			</h1>
			<p class="lede platform1-hero-lede">
				ReaderPub is a web-native publishing platform for authors, publishers, schools,
				libraries, and organizations.
			</p>
			<img
				class="image-block platform1-hero-image"
				src="/images/home2.webp"
				alt="ReaderPub connects readers, publishers, and authors through WeRead, WePub, and BookTree"
				loading="lazy"
				decoding="async"
				width="1115"
				height="900"
			/>
			<p class="platform1-hero-body">
				Create browser-based reading editions, generate EPUB files, sell directly, manage
				access, and track engagement from one connected platform.
			</p>
			<p class="lede platform1-hero-note">
				Built for web editions, protected distribution, direct reader relationships, and
				institutional publishing programs.
			</p>
			<div class="cta-row platform1-hero-actions">
				<a class="button" href="/publish/">Start publishing</a>
				<a class="button secondary" href="/security/">Explore security</a>
			</div>
		</div>
	</section>

	<SpecCardsSection class="section-continuation">
		<h2>Three products. One connected platform.</h2>
		<div class="card-grid platform1-three-grid">
			<div class="card">
				<h3>WePub</h3>
				<p>Publishing workflow for authors and organizations.</p>
				<ul class="bullets">
					<li>Create and manage titles</li>
					<li>Upload Word or EPUB files</li>
					<li>Prepare web-accessible editions</li>
					<li>Generate production-ready EPUBs</li>
				</ul>
			</div>
			<div class="card">
				<h3>WeRead</h3>
				<p>Instant browser-based reading for long-form content.</p>
				<ul class="bullets">
					<li>Read without downloading files</li>
					<li>Use annotations and notes</li>
					<li>Support native device text-to-speech</li>
					<li>Reduce unauthorized copying with Theft Guard</li>
				</ul>
			</div>
			<div class="card">
				<h3>BookTree</h3>
				<p>Structure for books, editions, metadata, catalogs, and collections.</p>
				<ul class="bullets">
					<li>Organize books and chapters</li>
					<li>Manage editions and revisions</li>
					<li>Preserve and connect metadata</li>
					<li>Support complex institutional libraries</li>
				</ul>
			</div>
		</div>
	</SpecCardsSection>

	<section class="section platform1-highlights-section section-continuation">
		<h2>Platform highlights & product connection</h2>
		<div class="platform1-highlights-split">
			<div class="platform1-highlights-left">
				<div class="card-grid platform1-highlights-cards">
					<div class="card">
						<h3>Web-first reading</h3>
						<p>Readers open books instantly in the browser with no app install.</p>
					</div>
					<div class="card">
						<h3>Structured publishing</h3>
						<p>Manage titles, metadata, editions, chapters, pricing, and release workflow.</p>
					</div>
					<div class="card">
						<h3>Protected access</h3>
						<p>Control who can read, publish, edit, review, or distribute content.</p>
					</div>
					<div class="card">
						<h3>Commerce and analytics</h3>
						<p>Sell directly and understand how readers engage with your books.</p>
					</div>
				</div>
				<div class="platform1-product-lines">
					<p><strong>WePub</strong>: publish, manage, price, review, and prepare editions.</p>
					<p>
						<strong>ReaderPub Platform</strong>: access control, commerce, analytics, and workflow.
					</p>
					<p>
						<strong>WeRead + BookTree</strong>: instant browser reading plus structured catalogs.
					</p>
				</div>
			</div>
			<img
				class="image-block platform1-highlights-image"
				src="/images/technology.webp"
				alt="Technology and publishing workflows for public and institutional reading"
				loading="lazy"
				decoding="async"
				width="4088"
				height="4138"
			/>
		</div>
	</section>

	<SpecCardsSection class="section-continuation">
		<h2>How it works</h2>
		<p class="lede">
			One publishing pipeline. Multiple ways to deliver.
		</p>
		<div class="card-grid platform1-five-grid">
			<div class="card">
				<h3>1. Upload or create</h3>
				<p>Start with Word, EPUB, structured content, or institutional materials.</p>
			</div>
			<div class="card">
				<h3>2. Structure and review</h3>
				<p>Manage metadata, chapters, editions, rights, pricing, and status.</p>
			</div>
			<div class="card">
				<h3>3. Publish to web</h3>
				<p>Deliver a browser-based reading edition across devices.</p>
			</div>
			<div class="card">
				<h3>4. Sell or assign access</h3>
				<p>Support direct purchases, institutional access, courses, and private distribution.</p>
			</div>
			<div class="card">
				<h3>5. Read and analyze</h3>
				<p>Readers use WeRead while organizations monitor engagement and response.</p>
			</div>
		</div>
	</SpecCardsSection>

	<section class="section platform1-reading-section section-continuation">
		<h2>Reading experience</h2>
		<div class="card-grid platform1-reading-cards">
			<div class="card"><h3>Annotations</h3><p>Highlights, notes, and preserved context.</p></div>
			<div class="card"><h3>Shared context</h3><p>Discussion among readers, authors, and instructors.</p></div>
			<div class="card"><h3>Read-aloud support</h3><p>Native device text-to-speech voices.</p></div>
			<div class="card"><h3>Long-form navigation</h3><p>Clean typography for serious reading.</p></div>
			<div class="card"><h3>Cross-device access</h3><p>Return to assigned or purchased titles anywhere.</p></div>
			<div class="card"><h3>Structured reading</h3><p>Chapters, editions, and metadata stay connected.</p></div>
		</div>
		<img
			class="image-block platform1-reading-image"
			src="/images/readers2.webp"
			alt="Reader experience with WeRead in the browser"
			loading="lazy"
			decoding="async"
			width="1024"
			height="1024"
		/>
	</section>

	<SpecCardsSection class="section-continuation">
		<h2>Capabilities</h2>
		<div class="card-grid platform1-three-grid">
			<div class="card"><h3>Browser-based reading</h3><p>Instant delivery through the web.</p></div>
			<div class="card"><h3>EPUB output</h3><p>Generate standard EPUB when file delivery is needed.</p></div>
			<div class="card"><h3>Protected web editions</h3><p>Web-native access instead of file handoff.</p></div>
			<div class="card"><h3>Direct sales</h3><p>Sell books, courses, cohorts, and limited releases.</p></div>
			<div class="card"><h3>Low commission</h3><p>Direct-to-reader commerce with a low 5% platform fee.</p></div>
			<div class="card"><h3>Reader analytics</h3><p>Track engagement, feedback, and access patterns.</p></div>
			<div class="card"><h3>Collaboration</h3><p>Annotations, notes, and shared context for teams.</p></div>
			<div class="card"><h3>Institutional access</h3><p>User, group, course, department, and role controls.</p></div>
			<div class="card"><h3>Catalog support</h3><p>Import and preserve structured metadata at scale.</p></div>
		</div>
	</SpecCardsSection>

	<section class="section platform1-audiences-section section-continuation">
		<h2>Audiences</h2>
		<div class="card-grid platform1-audiences-cards">
			<div class="card"><h3>Authors</h3><p>Publish and sell directly, then analyze reader engagement.</p></div>
			<div class="card"><h3>Publishers</h3><p>Manage titles, editions, catalogs, and controlled access.</p></div>
			<div class="card"><h3>Schools</h3><p>Distribute course materials and monitor usage.</p></div>
			<div class="card"><h3>Libraries</h3><p>Create browser-based digital shelves for communities.</p></div>
			<div class="card"><h3>Organizations</h3><p>Publish reports, papers, and structured knowledge online.</p></div>
			<div class="card">
				<h3>Manufacturers</h3>
				<p>Publish easily accessible manuals and technical documentation.</p>
			</div>
		</div>
		<img
			class="image-block platform1-audiences-image"
			src="/images/audience.webp"
			alt="Readers, authors, institutions, and publishers connected on ReaderPub"
			loading="lazy"
			decoding="async"
			width="1024"
			height="841"
		/>
	</section>

	<section class="section platform1-commerce-section section-continuation">
		<h2>Commerce &amp; Analytics</h2>
		<div class="platform1-commerce-split">
			<img
				class="image-block platform1-commerce-image"
				src="/images/commerce.webp"
				alt="Commerce and analytics for direct sales and reader engagement"
				loading="lazy"
				decoding="async"
				width="667"
				height="600"
			/>
			<div class="platform1-commerce-cards">
				<section class="card">
					<h3>Manage sales and promotion</h3>
					<p>Sell directly and keep the reader relationship.</p>
					<ul class="bullets">
						<li>Sell web editions directly with low commission</li>
						<li>Support books, courses, cohorts, and limited releases</li>
						<li>Build fan clubs and reader communities</li>
						<li>Connect sales to engagement analytics</li>
					</ul>
				</section>
				<section class="card">
					<h3>Keep track on your readers' audience</h3>
					<p>Know what happens after publication.</p>
					<ul class="bullets">
						<li>Reader engagement and annotation activity</li>
						<li>Title, collection, and institutional usage insights</li>
						<li>First-party relationship with readers</li>
					</ul>
				</section>
			</div>
		</div>
	</section>

	<div class="card-grid platform1-two-grid section-continuation">
		<section class="section">
			<h2>Institutional control</h2>
			<p>
				Access can be assigned by user, group, course, department, team, program, partner
				organization, or custom permission.
			</p>
		</section>
		<section class="card">
			<ul class="bullets">
				<li>Public and private collections</li>
				<li>Controlled access programs</li>
				<li>Course and cohort distribution</li>
				<li>Team-based publishing workflows</li>
				<li>Permission-based administration</li>
			</ul>
		</section>
	</div>

	<div class="card-grid platform1-two-grid section-continuation">
		<section class="footer-cta">
			<h3>For creators</h3>
			<p>Publish your book on ReaderPub.</p>
			<ul class="bullets">
				<li>Upload Word or EPUB files</li>
				<li>Publish browser-based editions</li>
				<li>Generate production-ready EPUBs</li>
				<li>Track reader engagement</li>
			</ul>
			<div class="cta-row">
				<a class="button" href="/publish/">Start publishing</a>
				<a class="button secondary" href="/pricing/">See pricing</a>
			</div>
		</section>
		<section class="footer-cta">
			<h3>For organizations</h3>
			<p>Bring your organization to ReaderPub.</p>
			<ul class="bullets">
				<li>Import from OPDS, MARC, ONIX, KBART, S3, or CSV</li>
				<li>Manage users, groups, and permissions</li>
				<li>Use ReaderPub or custom subdomain deployment</li>
				<li>Track usage and engagement</li>
			</ul>
			<div class="cta-row">
				<a class="button" href="/contact/">Plan onboarding</a>
				<a class="button secondary" href="/security/">Explore security</a>
			</div>
		</section>
	</div>

	<section class="footer-cta section-continuation">
		<h2>ReaderPub turns digital publishing into a connected web experience.</h2>
		<p>
			Publish books. Protect access. Sell directly. Read instantly. Measure engagement.
			Manage content across authors, readers, teams, and institutions.
		</p>
		<div class="cta-row">
			<a class="button" href="/publish/">Get started with ReaderPub</a>
		</div>
	</section>

	<style>
		.platform1-hero-grid {
			display: grid;
			grid-template-columns: minmax(0, 1.18fr) minmax(0, 0.82fr);
			grid-template-areas:
				"title image"
				"lede image"
				"body image"
				"note image"
				"actions image";
			column-gap: 32px;
			row-gap: 16px;
			align-items: start;
			width: 100%;
		}

		.platform1-hero-grid > * {
			margin: 0;
			min-width: 0;
		}

		.platform1-hero-title {
			grid-area: title;
			font-size: clamp(36px, 5vw, 56px);
			line-height: 1.1;
			color: var(--text) !important;
			white-space: nowrap;
		}

		.platform1-hero-lede {
			grid-area: lede;
			margin: 0 !important;
			color: var(--link) !important;
		}

		.platform1-hero-body {
			grid-area: body;
			color: var(--text);
			font-size: 16px;
			line-height: 1.28;
		}

		.platform1-hero-note {
			grid-area: note;
			margin: 0 !important;
			color: var(--link) !important;
		}

		.platform1-hero-actions {
			grid-area: actions;
			justify-content: flex-start;
		}

		.platform1-hero-image {
			grid-area: image;
			width: 100%;
			max-width: calc(460px * 1.2) !important;
			margin-left: auto;
			margin-right: 0;
			align-self: center;
		}

		.platform1-highlights-section > h2 {
			margin-bottom: 0;
		}

		.platform1-highlights-split {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 42%);
			gap: 32px;
			align-items: center;
			margin-top: var(--section-flow-gap);
		}

		.platform1-highlights-left {
			display: grid;
			gap: var(--section-flow-gap);
			min-width: 0;
		}

		.platform1-highlights-cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
		}

		.platform1-product-lines {
			display: grid;
			gap: 10px;
		}

		.platform1-product-lines > * {
			margin: 0;
		}

		.platform1-product-lines p {
			color: var(--muted);
			font-size: 16px;
			line-height: 1.28;
		}

		.platform1-product-lines strong {
			color: var(--link);
			font-weight: 700;
		}

		.platform1-highlights-image {
			justify-self: end;
			align-self: center;
			width: 100%;
			max-width: calc(560px * 0.8 * 0.9) !important;
			margin: 0;
		}

		.platform1-reading-section {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 42%);
			grid-template-areas:
				"title title"
				"cards image";
			column-gap: 32px;
			row-gap: 16px;
			align-items: center;
		}

		.platform1-reading-section > h2 {
			grid-area: title;
			margin-bottom: 0;
		}

		.platform1-reading-cards {
			grid-area: cards;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
		}

		.platform1-reading-image {
			grid-area: image;
			justify-self: end;
			align-self: center;
			width: 100%;
			max-width: 100%;
			margin: 0;
		}

		.platform1-audiences-section {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 42%);
			grid-template-areas:
				"title title"
				"cards image";
			column-gap: 32px;
			row-gap: 16px;
			align-items: center;
		}

		.platform1-audiences-section > h2 {
			grid-area: title;
			margin-bottom: 0;
		}

		.platform1-audiences-cards {
			grid-area: cards;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
		}

		.platform1-audiences-image {
			grid-area: image;
			justify-self: end;
			align-self: center;
			width: 100%;
			max-width: 100%;
			margin: 0;
		}

		.platform1-commerce-section > h2 {
			margin-bottom: 0;
		}

		.platform1-commerce-split {
			display: grid;
			grid-template-columns: minmax(0, 42%) minmax(0, 1fr);
			grid-template-areas: "image cards";
			column-gap: 64px;
			align-items: center;
			width: 100%;
			margin-top: var(--section-block-gap-adjust) !important;
		}

		.platform1-commerce-image {
			grid-area: image;
			justify-self: start;
			align-self: center;
			width: 90%;
			max-width: 90% !important;
			margin: 0;
		}

		.platform1-commerce-cards {
			grid-area: cards;
			display: grid;
			grid-template-columns: minmax(0, 1fr);
			gap: var(--section-flow-gap);
			width: 100%;
		}

		.platform1-two-grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: var(--section-flow-gap);
		}

		.platform1-three-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.platform1-five-grid {
			grid-template-columns: repeat(5, minmax(0, 1fr));
		}

		@media (max-width: 1100px) {
			.platform1-five-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}

		@media (max-width: 900px) {
			.platform1-highlights-split {
				grid-template-columns: 1fr;
				justify-items: center;
			}

			.platform1-highlights-left {
				width: 100%;
			}

			.platform1-highlights-cards {
				grid-template-columns: 1fr;
			}

			.platform1-highlights-image {
				justify-self: center;
				margin-inline: auto;
			}

			.platform1-product-lines strong {
				display: block;
			}

			.platform1-reading-section {
				grid-template-columns: 1fr;
				grid-template-areas:
					"title"
					"cards"
					"image";
				justify-items: center;
			}

			.platform1-reading-cards {
				grid-template-columns: 1fr;
			}

			.platform1-reading-image {
				justify-self: center;
				margin-inline: auto;
			}

			.platform1-audiences-section {
				grid-template-columns: 1fr;
				grid-template-areas:
					"title"
					"image"
					"cards";
				justify-items: center;
			}

			.platform1-audiences-cards {
				grid-template-columns: 1fr;
			}

			.platform1-audiences-image {
				justify-self: center;
				margin-inline: auto;
			}

			.platform1-commerce-split {
				grid-template-columns: 1fr;
				grid-template-areas:
					"image"
					"cards";
				row-gap: var(--section-flow-gap);
				justify-items: center;
			}

			.platform1-commerce-image {
				justify-self: center;
				width: 90%;
				max-width: min(520px, 90%) !important;
				margin-inline: auto;
			}

			.platform1-hero-grid {
				grid-template-columns: 1fr;
				grid-template-areas:
					"title"
					"lede"
					"image"
					"body"
					"note"
					"actions";
				justify-items: center;
			}

			.platform1-hero-title {
				font-size: clamp(36px, 9vw, 56px);
				text-align: center;
				white-space: normal;
			}

			.platform1-hero-lede,
			.platform1-hero-body,
			.platform1-hero-note {
				text-align: center;
				width: 100%;
			}

			.platform1-hero-actions {
				justify-content: center;
			}

			.platform1-hero-image {
				margin-inline: auto;
			}

			.platform1-two-grid,
			.platform1-three-grid,
			.platform1-five-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</Base>

---
import Base from "../layouts/Base.astro";
import { SITE_NAME } from "../consts";
import HomePlatformOverview from "../components/sections/HomePlatformOverview.astro";
import PlatformOnboardingCards from "../components/sections/PlatformOnboardingCards.astro";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
---

<Base title={`${SITE_NAME} Platform`}>
	<section class="technology-hero section-continue-next">
		<div class="menu-eyebrow">PLATFORM</div>
		<h1 class="technology-hero-title">Built for web-native publishing at scale.</h1>
		<p class="lede technology-hero-primary-lede">
			ReaderPub powers instant reading, structured publishing, and analytics for authors and
			institutions.
		</p>
		<img
			class="image-block technology-hero-image"
			src="/images/home2.webp"
			alt="ReaderPub connects readers, publishers, and authors through WeRead, WePub, and BookTree"
			loading="lazy"
			decoding="async"
			width="1115"
			height="900"
		/>
		<div class="technology-hero-body">
			<p>
				ReaderPub supports web publishing plus commerce: low-commission sales and connected analytics. The same publishing pipeline can output both a web-accessible edition and a production-ready EPUB.
			</p>
			<p>
				For protected distribution, ReaderPub’s primary access model is web-native rather than file-native: readers access content in the browser instead of receiving a standard downloadable book file. Web-accessible edition is fully protected from copying or downloading by the patent-pending <strong class="technology-theft-guard-highlight">WeRead Theft Guard</strong>.
			</p>
			<p>
				Access control is enforced at the platform level, allowing institutions to define how content is distributed across users and teams.
			</p>
		</div>
		<div class="cta-row technology-hero-actions">
			<a class="button secondary" href="/security#control-who-reads">Learn more about ReaderPub security</a>
		</div>
	</section>

	<HomePlatformOverview />

	<SpecCardsSection class="section-continuation section-continue-next">
		<h2>Reader collaboration and accessibility</h2>
		<div class="card-grid powers-grid-two">
			<div class="card">
				<h3>Collaborative annotations workflow</h3>
				<p>
					ReaderPub supports chain-sharing of annotated books: reader → author/reader → next
					participants, preserving evolving notes.
				</p>
			</div>
			<div class="card">
				<h3>Native device TTS playback</h3>
				<p>
					ReaderPub uses system voices installed on the user’s device for fast, low-friction
					read-aloud.
				</p>
			</div>
			<div class="card">
				<h2>Built for scale</h2>
				<p>A modern foundation for public and professional reading at scale.</p>
				<ul class="bullets">
					<li>Web-native reading — fast, accessible reading in the browser. No apps, no downloads.</li>
					<li>Designed for real catalogs — works with large, structured collections.</li>
					<li>Reader-first experience — clean typography and deep navigation for long-form reading.</li>
				</ul>
			</div>
			<div class="card">
				<h2>Why this matters</h2>
				<p>Flexibility and access for every audience.</p>
				<ul class="bullets">
					<li>No proprietary apps required</li>
					<li>No lock-in to a single deployment model</li>
					<li>Suitable for libraries, universities, publishers, and public organizations</li>
					<li>Scales from public catalogs to institutional programs</li>
					<li>Built for institutions — supports public access and controlled publishing programs.</li>
				</ul>
			</div>
		</div>
	</SpecCardsSection>

	<PlatformOnboardingCards />

	<div class="modal" id="wepub-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
			<div class="modal-content" role="dialog" aria-modal="true" aria-label="WePub image">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>
					✕
				</button>
			<img src="/images/wepub.webp" alt="WePub image" loading="lazy" decoding="async" width="1024" height="592" />
		</div>
	</div>

	<div class="modal" id="booktree-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
			<div class="modal-content" role="dialog" aria-modal="true" aria-label="BookTree image">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>
					✕
				</button>
			<img src="/images/booktree.webp" alt="BookTree image" loading="lazy" decoding="async" width="976" height="1219" />
		</div>
	</div>

	<script is:inline>
		(() => {
			const openButtons = Array.from(document.querySelectorAll("[data-modal-open]"));
			const modals = Array.from(document.querySelectorAll(".modal"));

			const closeModal = (modal) => {
				if (!modal) return;
				modal.classList.remove("is-open");
				modal.setAttribute("aria-hidden", "true");
			};

			const openModal = (modal) => {
				if (!modal) return;
				modal.classList.add("is-open");
				modal.setAttribute("aria-hidden", "false");
			};

			openButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const target = btn.getAttribute("data-modal-open");
					const modal = target ? document.querySelector(target) : null;
					openModal(modal);
				});
			});

			modals.forEach((modal) => {
				const closeTargets = modal.querySelectorAll("[data-modal-close]");
				closeTargets.forEach((el) => el.addEventListener("click", () => closeModal(modal)));
			});

			document.addEventListener("keydown", (event) => {
				if (event.key !== "Escape") return;
				modals.forEach((modal) => closeModal(modal));
			});
		})();
	</script>

	<style>
		.technology-hero {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
			column-gap: 32px;
			row-gap: 16px;
			align-items: start;
		}

		.technology-hero > * {
			min-width: 0;
		}

		.technology-hero-title {
			grid-column: 1 / -1;
			grid-row: 2;
			font-size: clamp(36px, 5vw, 56px);
			line-height: 1.1;
			margin: 0 0 32px;
		}

		.menu-eyebrow,
		.technology-hero-primary-lede,
		.technology-hero-body,
		.technology-hero-actions {
			grid-column: 1;
		}

		.menu-eyebrow {
			grid-row: 1;
		}

		.technology-hero-primary-lede {
			grid-row: 3;
			margin-bottom: 0;
		}

		.technology-theft-guard-highlight {
			color: var(--link);
			font-weight: 700;
		}

		.technology-hero-body {
			grid-row: 4;
			display: grid;
			gap: 16px;
		}

		.technology-hero-actions {
			grid-row: 5;
			justify-content: flex-start;
		}

		.technology-hero-image {
			grid-column: 2;
			grid-row: 3 / span 3;
			margin-left: auto;
			margin-right: 0;
			max-width: calc(460px * 1.2);
			align-self: center;
		}

		.powers-grid-two {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			justify-content: stretch;
		}

		@media (orientation: portrait) {
			.technology-hero {
				grid-template-columns: 1fr;
				justify-items: center;
				align-items: center;
				text-align: center;
			}

			.technology-hero-body {
				text-align: center;
			}

			.technology-hero-title,
			.technology-hero-primary-lede,
			.technology-hero-image,
			.technology-hero-body,
			.technology-hero-actions,
			.menu-eyebrow {
				grid-column: 1;
			}

			.menu-eyebrow {
				grid-row: 1;
			}

			.technology-hero-title {
				grid-row: 2;
			}

			.technology-hero-primary-lede {
				grid-row: 3;
			}

			.technology-hero-image {
				grid-row: 4;
				margin-left: auto;
				margin-right: auto;
			}

			.technology-hero-body {
				grid-row: 5;
			}

			.technology-hero-actions {
				grid-row: 6;
				justify-content: center;
			}
		}

		@media (max-width: 900px) {
			.powers-grid,
			.powers-grid-two {
				grid-template-columns: 1fr;
			}
		}
	</style>
</Base>

---
import Base from "../layouts/Base.astro";
import { SITE_NAME } from "../consts";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
import TextFirstSection from "../components/sections/TextFirstSection.astro";
---

<Base title={`${SITE_NAME} Pricing`}>
	<section class="hero">
		<div>
			<h1>Pricing</h1>
			<p class="lede">Aggressive creator economics. Serious institutional publishing.</p>
			<p>ReaderPub supports two paths:</p>
			<ul class="bullets">
				<li>authors/publishers selling & renting directly to readers</li>
				<li>institutions publishing trusted collections for the public.</li>
			</ul>
			<div class="cta-row">
				<a class="button" href="/contact">Start onboarding</a>
				<a class="button secondary" href="/catalog">See the catalog</a>
			</div>
		</div>
		<img
			class="image-block proof-media pricing-hero-image"
			src="/images/pricing.webp"
			alt="ReaderPub pricing for creators and institutions"
			loading="lazy"
			decoding="async"
			width="667"
			height="600"
		/>
	</section>

	<SpecCardsSection class="marketplace-pricing-section">
		<div class="marketplace-pricing-layout">
			<div class="marketplace-pricing-copy">
				<h2>Sell and rent directly to your readers.</h2>
				<p class="lede">Keep your audience, keep your data, and keep more of each sale.</p>
				<ul class="bullets">
					<li>Sell web editions and EPUBs directly on ReaderPub.</li>
					<li>Offer rentals for courses, cohorts, and short-term access.</li>
					<li>First-party analytics: sales, rentals, cohorts, engagement.</li>
					<li>Fan clubs: memberships, drops, early access, and campaigns.</li>
					<li>Optional EPUB delivery for external distribution and archiving.</li>
				</ul>
				<div class="cta-row">
					<a class="button" href="/publish">Publish a book</a>
					<a class="button secondary protected-pricing-button" href="/authors/#indie-releases">
						<img src="/images/protected-shield.svg" alt="" aria-hidden="true" />
						<span>Protected against piracy</span>
					</a>
				</div>
			</div>
			<div class="marketplace-card-stack">
				<div class="card">
					<h3>5% fee on sales</h3>
					<p>Low marketplace fee for direct sales.</p>
				</div>
				<div class="card">
					<h3>5% fee on rentals</h3>
					<p>Time-limited access with the same low fee.</p>
				</div>
				<div class="card">
					<h3>Direct reader access</h3>
					<p>No platform lock-in. Own your reader relationship.</p>
				</div>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="sale-rental-section">
		<div class="sale-rental-layout">
			<div class="sale-rental-copy">
				<h2>Sale vs Rental</h2>
				<p class="lede">
					Amazon-style retail is purchase-only. ReaderPub supports both purchase and
					time-limited access — you choose what fits each audience.
				</p>
				<p class="sale-rental-note">
					Sales are permanent access: the reader buys the title and keeps it in their library. They
					can open it anytime, on any device, and access the full WeRead experience.
				</p>
				<p class="sale-rental-note">
					Rentals are time-limited access: you set a duration and a price, and readers get instant
					access for a course, cohort, or limited window. Rentals convert hesitant readers and unlock
					institutional-style programs—without discounting the sale.
				</p>
				<p class="lede">
					You set both prices. Rentals are typically priced lower than purchase to support
					short-term use (often 20–40% of the sale price for shorter windows).
				</p>
			</div>
			<div class="sale-rental-card-stack">
				<div class="card">
					<h3>Sale (Buy)</h3>
					<ul class="bullets">
						<li>Permanent access in the reader’s library.</li>
						<li>Optional downloadable EPUB (when enabled).</li>
						<li>Best for long-term readers and collectors.</li>
					</ul>
				</div>
				<div class="card">
					<h3>Rental (Time-limited)</h3>
					<ul class="bullets">
						<li>Web-only access for a defined window (7/14/30/90 days).</li>
						<li>Access expires at the end of the rental period.</li>
						<li>Best for courses, cohorts, training, and short-term reading.</li>
					</ul>
				</div>
				<p class="sale-rental-note">
					Example: Sale $9.99 → 30-day rental $2.99; 90-day rental $4.99.
				</p>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="creator-catalog-pricing">
		<h2>Sustainable publishing model</h2>
		<p class="lede">
			ReaderPub is designed for active publishing catalogs with real readership, long-term
			discovery, and sustainable hosting economics.
		</p>
		<div class="card-grid creator-plan-grid">
			<div class="card creator-plan-card">
				<h3>Free Indie</h3>
				<p class="plan-price">$0 <span>/ month</span></p>
				<p>Best for independent authors and small launches.</p>
				<ul class="bullets">
					<li>Up to 5 active titles</li>
					<li>5% sales fee</li>
					<li>5% rental fee</li>
					<li>Direct sales and rentals</li>
					<li>Basic analytics</li>
					<li>Reader access and discovery</li>
				</ul>
			</div>
			<div class="card creator-plan-card">
				<h3>Creator</h3>
				<p class="plan-price">$9 <span>/ month</span></p>
				<p>Best for growing author catalogs.</p>
				<ul class="bullets">
					<li>Up to 50 active titles</li>
					<li>Expanded analytics</li>
					<li>Campaign and launch tools</li>
					<li>Enhanced discovery controls</li>
					<li>Everything in Free Indie</li>
				</ul>
			</div>
			<div class="card creator-plan-card">
				<h3>Publisher</h3>
				<p class="plan-price">$49 <span>/ month</span></p>
				<p>Best for publishers and larger catalogs.</p>
				<ul class="bullets">
					<li>Up to 500 active titles</li>
					<li>Bulk ingest</li>
					<li>Advanced analytics</li>
					<li>Cohort and campaign tools</li>
					<li>Priority onboarding</li>
				</ul>
			</div>
			<div class="card creator-plan-card">
				<h3>Studio</h3>
				<p class="plan-price">$199 <span>/ month</span></p>
				<p>Best for large-scale publishing operations.</p>
				<ul class="bullets">
					<li>Up to 5,000 active titles</li>
					<li>API ingest support</li>
					<li>Large-scale catalog management</li>
					<li>Advanced reporting</li>
					<li>Dedicated scaling support</li>
				</ul>
			</div>
		</div>
		<div class="creator-pricing-notes">
			<div>
				<h3>Active catalog economics</h3>
				<p>
					ReaderPub prioritizes books with readership, circulation, and engagement. Older or
					inactive titles may gradually transition into archival discovery tiers optimized for
					long-term preservation and low-cost hosting.
				</p>
			</div>
			<div>
				<h3>Promotion and analytics</h3>
				<p>
					Optional promotion and analytics tools are available for launches, featured
					placements, reading campaigns, audience growth, cohorts, and community programs.
					These tools help authors and publishers grow readership without changing the low 5%
					marketplace fee.
				</p>
			</div>
		</div>
		<p class="creator-pricing-footnote">
			Additional active-title capacity and enterprise-scale catalog plans are available during
			onboarding.
		</p>
	</SpecCardsSection>

	<TextFirstSection class="institution-plans-block">
		<h2>Institution plans (subscription + storage)</h2>
		<p class="lede">
			For libraries, universities, government, and public organizations — publish trusted
			collections to the web with a modern reader.
		</p>
		<p class="institution-plans-summary" style="color: var(--text); font-size: 16px; font-weight: 400;">
			Institutions publish collections, programs, archives, and public libraries. ReaderPub is
			the missing web layer: fast onboarding, clean
			discovery, and a real in-browser reading experience. Institutions budget annually and
			publish collections over time, so pricing is subscription-based with storage included —
			with predictable overage when needed.
		</p>
			<div class="card-grid">
			<div class="card">
				<h3>Starter</h3>
				<p>for pilots and small collections</p>
				<ul class="bullets">
					<li>$499 / month</li>
					<li>Up to 5,000 titles</li>
					<li>Up to 200 GB storage</li>
					<li>reader.pub subdomain</li>
					<li>Basic analytics</li>
				</ul>
			</div>
			<div class="card">
				<h3>Standard</h3>
				<p>for libraries and departments</p>
				<ul class="bullets">
					<li>$1,499 / month</li>
					<li>Up to 50,000 titles</li>
					<li>Up to 1 TB storage</li>
					<li>Custom subdomain option</li>
					<li>Program pages + cohorts</li>
					<li>Advanced analytics</li>
				</ul>
			</div>
			<div class="card">
				<h3>Enterprise</h3>
				<p>for university systems and public agencies</p>
				<ul class="bullets">
					<li>Talk to us</li>
					<li>100,000+ titles</li>
					<li>SSO/SAML</li>
					<li>Dedicated onboarding</li>
					<li>Custom integrations</li>
					<li>SLA</li>
				</ul>
			</div>
		</div>
		<h3>What’s included</h3>
		<ul class="bullets">
			<li>Two deployment options: a reader.pub subdomain OR your own subdomain mapped to ReaderPub hosting.</li>
			<li>Bulk ingest and catalog import (metadata + covers).</li>
			<li>Collections, shelves, and public reading rooms.</li>
			<li>Institution-wide analytics and engagement reporting.</li>
			<li>Optional EPUB delivery package for archiving or external distribution.</li>
		</ul>
		<h3>Add-ons</h3>
		<ul class="bullets">
			<li>Additional storage and bandwidth (metered over included limits).</li>
			<li>Custom integrations (catalog, authentication, reporting).</li>
			<li>Migration support for legacy collections.</li>
		</ul>
	</TextFirstSection>

	<SpecCardsSection>
		<h2>Onboarding process</h2>
		<p class="lede">From files or catalogs to a public web library — fast.</p>
		<p class="onboarding-note" style="color: var(--text); font-size: 16px; font-weight: 400;">
			During the onboarding process, you specify your needs and requirements, and your pricing model will adjust accordingly.
		</p>
		<div class="cta-row">
			<a class="button" href="/contact">Request onboarding</a>
		</div>
	</SpecCardsSection>

	<style>
		.pricing-hero-image {
			flex: 0 1 368px !important;
			max-width: 368px !important;
		}

		.institution-plans-block {
			width: min(100%, 1100px);
			margin-inline: auto;
			text-align: left;
		}

		.sale-rent-grid {
			grid-template-columns: repeat(2, minmax(360px, 480px));
			justify-content: center;
		}

		.sale-rental-note {
			color: var(--text) !important;
		}

		:global(.sale-rental-layout) {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(340px, 520px);
			gap: 32px;
			align-items: start;
		}

		:global(.sale-rental-copy) {
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
		}

		:global(.sale-rental-copy > *) {
			margin: 0 !important;
		}

		:global(.sale-rental-copy > .lede) {
			color: var(--link) !important;
		}

		:global(.sale-rental-card-stack) {
			display: grid;
			gap: var(--section-flow-gap);
			align-self: start;
		}

		:global(.sale-rental-card-stack > .card) {
			min-height: 0;
			width: 100%;
		}

		:global(.sale-rental-card-stack > .sale-rental-note) {
			margin: 0 !important;
			max-width: none;
		}

		:global(.marketplace-pricing-layout) {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(300px, 420px);
			gap: 32px;
			align-items: start;
		}

		:global(.marketplace-pricing-copy) {
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
		}

		:global(.marketplace-pricing-copy > *) {
			margin: 0 !important;
		}

		:global(.marketplace-pricing-copy > .cta-row) {
			margin-top: var(--section-block-gap-adjust) !important;
		}

		:global(.protected-pricing-button) {
			display: inline-flex;
			align-items: center;
			gap: 8px;
		}

		:global(.protected-pricing-button img) {
			width: 20px;
			height: 20px;
			display: block;
			flex-shrink: 0;
		}

		:global(.marketplace-card-stack) {
			display: grid;
			gap: var(--section-flow-gap);
			align-self: start;
		}

		:global(.marketplace-card-stack > .card) {
			min-height: 0;
			width: 100%;
		}

		.creator-catalog-pricing {
			width: min(100%, 1180px);
			margin-inline: auto;
		}

		.creator-plan-grid {
			grid-template-columns: repeat(4, minmax(220px, 1fr));
			justify-content: stretch;
		}

		.creator-plan-card {
			min-height: 360px;
		}

		.plan-price {
			font-family: "Playfair Display", serif;
			font-size: clamp(28px, 3vw, 40px) !important;
			line-height: 1.05 !important;
			color: var(--text) !important;
			font-weight: 700;
		}

		.plan-price span {
			font-family: inherit;
			font-size: 16px;
			color: var(--muted);
			font-weight: 400;
		}

		.creator-pricing-notes {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: var(--section-flow-gap);
			margin-top: var(--section-block-gap-adjust) !important;
		}

		.creator-pricing-notes > div {
			display: flex;
			flex-direction: column;
			gap: 10px;
		}

		.creator-pricing-notes p,
		.creator-pricing-footnote {
			color: var(--text) !important;
		}


		@media (max-width: 1024px) {
			.sale-rent-grid {
				grid-template-columns: 1fr;
			}

			.creator-plan-grid {
				grid-template-columns: repeat(2, minmax(240px, 1fr));
			}

			:global(.marketplace-pricing-layout) {
				grid-template-columns: 1fr;
			}

			:global(.sale-rental-layout) {
				grid-template-columns: 1fr;
			}
		}

		@media (max-width: 720px) {
			.creator-plan-grid,
			.creator-pricing-notes {
				grid-template-columns: 1fr;
			}
		}
	</style>
</Base>

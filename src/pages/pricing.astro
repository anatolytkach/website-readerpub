---
import Base from "../layouts/Base.astro";
import { SITE_NAME } from "../consts";
---

<Base title={`${SITE_NAME} Pricing`}>
	<section class="hero">
		<div>
			<h1>Simple pricing that matches your model.</h1>
			<p class="lede">Choose revenue share for sales or subscription when access is free.</p>
			<div class="cta-row">
				<a class="button" href="/contact">Request pricing</a>
				<a class="button secondary" href="/publishers">Publisher plans</a>
			</div>
		</div>
		<div class="image-placeholder">IMAGE PLACEHOLDER</div>
	</section>

	<section class="section">
		<h2>Pricing rule</h2>
		<ul class="bullets">
			<li>5% revenue share when you sell access.</li>
			<li>Subscription when you do not sell access.</li>
			<li>Hybrid options are available for mixed models.</li>
		</ul>
	</section>

	<section class="section">
		<h2>Example tiers</h2>
		<div class="pricing-block">
			<p>$99/mo for solo creators and small teams.</p>
			<p>$249/mo for growing publishers and institutions.</p>
			<p>$49/mo + 5% revenue share for hybrid programs.</p>
		</div>
	</section>
</Base>

---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, SITE_NAME } from "../consts";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
import TextFirstSection from "../components/sections/TextFirstSection.astro";
---

<Base title={`${SITE_NAME} Pricing`}>
	<section class="pricing-hero">
		<div class="pricing-hero-copy">
			<div class="menu-eyebrow">PRICING</div>
			<h1 class="pricing-hero-title">Free for readers and indies.<br />Fair for everyone else.</h1>
			<p class="lede pricing-hero-lede">Aggressive creator economics. Unbound institutional publishing.</p>
			<img
				class="image-block proof-media pricing-hero-image pricing-hero-image--mobile"
				src="/images/pricing.webp"
				alt=""
				aria-hidden="true"
				loading="lazy"
				decoding="async"
				width="667"
				height="600"
			/>
			<p class="pricing-hero-copy-intro">ReaderPub supports two paths:</p>
			<ul class="bullets pricing-hero-bullets">
				<li>Authors and publishers sell directly to readers with low commission.</li>
				<li>Institutions publish instantly accessible materials with a fixed storage fee.</li>
			</ul>
			<div class="cta-row pricing-hero-actions">
				<a class="button" href="/contact">Contact us for details</a>
				<a class="button secondary" href={BOOKS_URL} target="_blank" rel="noreferrer">See the catalog</a>
			</div>
		</div>
		<img
			class="image-block proof-media pricing-hero-image pricing-hero-image--desktop"
			src="/images/pricing.webp"
			alt="ReaderPub pricing for creators and institutions"
			loading="lazy"
			decoding="async"
			width="667"
			height="600"
		/>
	</section>

	<SpecCardsSection class="marketplace-pricing-section">
		<div class="marketplace-pricing-layout">
			<div class="marketplace-pricing-copy">
				<h2>Sell directly to your readers, and keep the audience.</h2>
				<p class="lede">Keep your audience, keep your data, and keep more of each sale.</p>
				<ul class="bullets">
					<li>Sell web editions and EPUBs directly on ReaderPub.</li>
					<li>First-party analytics: sales, cohorts, engagement.</li>
					<li>WeBuzz communities: memberships, drops, early access, and campaigns.</li>
					<li>Optional EPUB delivery for external distribution and archiving.</li>
				</ul>
				<div class="cta-row">
					<a class="button" href="/start">Publish a book</a>
					<a class="button secondary protected-pricing-button" href="/authors/#indie-releases">
						<img src="/images/protected-shield.svg" alt="" aria-hidden="true" />
						<span>Protected against piracy</span>
					</a>
				</div>
			</div>
			<div class="marketplace-card-stack">
				<div class="card">
					<h3>5% fee on sales</h3>
					<p>Low marketplace fee for direct sales.</p>
				</div>
			<div class="card">
				<h3>Direct reader access through WeBuzz</h3>
				<p>Build long-term relationships with readers through discussions, communities, and direct participation in the ReaderPub ecosystem.</p>
			</div>
			</div>
		</div>
	</SpecCardsSection>

	<SpecCardsSection class="creator-catalog-pricing">
		<h2>Sustainable publishing model</h2>
		<p class="lede">
			ReaderPub is designed for active publishing catalogs with real readership, long-term
			discovery, and sustainable hosting economics.
		</p>
		<div class="card-grid creator-plan-grid">
			<div class="card creator-plan-card">
				<h3>Free Indie</h3>
				<p class="plan-price">$0 <span>/ month</span></p>
				<p>Best for independent authors and small launches.</p>
				<ul class="bullets">
					<li>Up to 5 active titles</li>
					<li>5% sales fee</li>
					<li>Direct sales to connected readers</li>
					<li>Basic analytics</li>
					<li>Reader access and discovery</li>
				</ul>
			</div>
			<div class="card creator-plan-card">
				<h3>Creator</h3>
				<p class="plan-price">$9 <span>/ month</span></p>
				<p>Best for growing author catalogs.</p>
				<ul class="bullets">
					<li>Up to 50 active titles</li>
					<li>Expanded analytics</li>
					<li>Campaign and launch tools</li>
					<li>Enhanced discovery controls</li>
					<li>Everything in Free Indie</li>
				</ul>
			</div>
			<div class="card creator-plan-card">
				<h3>Publisher</h3>
				<p class="plan-price">$49 <span>/ month</span></p>
				<p>Best for publishers and larger catalogs.</p>
				<ul class="bullets">
					<li>Up to 500 active titles</li>
					<li>Bulk ingest</li>
					<li>Advanced analytics</li>
					<li>Cohort and campaign tools</li>
					<li>Priority onboarding</li>
				</ul>
			</div>
			<div class="card creator-plan-card">
				<h3>Studio</h3>
				<p class="plan-price">$199 <span>/ month</span></p>
				<p>Best for large-scale publishing operations.</p>
				<ul class="bullets">
					<li>Up to 5,000 active titles</li>
					<li>API ingest support</li>
					<li>Large-scale catalog management</li>
					<li>Advanced reporting</li>
					<li>Dedicated scaling support</li>
				</ul>
			</div>
		</div>
	</SpecCardsSection>

	<TextFirstSection class="institution-plans-block">
		<h2>Institution plans (subscription + storage)</h2>
		<p class="lede">
			For libraries, universities, government, and public organizations — publish trusted
			collections to the web with a modern reader.
		</p>
		<p class="institution-plans-summary" style="color: var(--text); font-size: 16px; font-weight: 400;">
			Institutions publish collections, programs, archives, and public libraries. ReaderPub is
			the missing web layer: fast onboarding, clean
			discovery, and a real in-browser reading experience. Institutions budget annually and
			publish collections over time, so pricing is subscription-based with storage included —
			with predictable overage when needed.
		</p>
			<div class="card-grid">
			<div class="card">
				<h3>Starter</h3>
				<p>for pilots and small collections</p>
				<ul class="bullets">
					<li class="no-bullet" style="font-weight: 700;">$499 / month</li>
					<li>Up to 5,000 titles</li>
					<li>Up to 200 GB storage</li>
					<li>reader.pub subdomain</li>
					<li>Basic analytics</li>
				</ul>
			</div>
			<div class="card">
				<h3>Standard</h3>
				<p>for libraries and departments</p>
				<ul class="bullets">
					<li class="no-bullet" style="font-weight: 700;">$1,499 / month</li>
					<li>Up to 50,000 titles</li>
					<li>Up to 1 TB storage</li>
					<li>Custom subdomain option</li>
					<li>Program pages + cohorts</li>
					<li>Advanced analytics</li>
				</ul>
			</div>
			<div class="card">
				<h3>Enterprise</h3>
				<p>for university systems and public agencies</p>
				<ul class="bullets">
					<li class="no-bullet" style="font-weight: 700;">Talk to us</li>
					<li>100,000+ titles</li>
					<li>SSO/SAML</li>
					<li>Dedicated onboarding</li>
					<li>Custom integrations</li>
					<li>SLA</li>
				</ul>
			</div>
		</div>
		<div class="institution-details-layout">
			<div class="institution-details-copy">
				<h3>What’s included</h3>
				<ul class="bullets">
					<li>Two deployment options: a reader.pub subdomain OR your own subdomain mapped to ReaderPub hosting.</li>
					<li>Bulk ingest and catalog import (metadata + covers).</li>
					<li>Collections, shelves, and public reading rooms.</li>
					<li>Institution-wide analytics and engagement reporting.</li>
					<li>Optional EPUB delivery package for archiving or external distribution.</li>
				</ul>
				<h3>Add-ons</h3>
				<ul class="bullets">
					<li>Additional storage and bandwidth (metered over included limits).</li>
					<li>Custom integrations (catalog, authentication, reporting).</li>
					<li>Migration support for legacy collections.</li>
				</ul>
			</div>
			<div class="card onboarding-process-card">
				<h2>Get started with ReaderPub</h2>
				<p class="lede">From files or catalogs to a public web library — fast.</p>
				<p class="onboarding-note">
					During the onboarding process, you specify your needs and requirements, and your pricing model will adjust accordingly.
				</p>
				<div class="cta-row">
					<a class="button" href="/contact">Contact us for details</a>
				</div>
			</div>
		</div>
	</TextFirstSection>

	<style>
		.no-bullet {
			list-style: none;
			margin-left: -15px;
		}

		.pricing-hero {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 368px);
			gap: 32px;
			align-items: center;
		}

		.pricing-hero > * {
			min-width: 0;
		}

		.pricing-hero-copy {
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
			min-width: 0;
		}

		.pricing-hero-copy > * {
			margin: 0;
		}

		.pricing-hero-title {
			font-size: clamp(36px, 5vw, 56px);
			line-height: 1.1;
		}

		.pricing-hero-copy > .pricing-hero-actions {
			margin-top: var(--section-block-gap-adjust) !important;
			justify-content: flex-start;
		}

		.pricing-hero-image {
			width: 100%;
			max-width: 368px !important;
			margin: 0;
		}

		.pricing-hero-image--desktop {
			align-self: center;
			justify-self: end;
		}

		.pricing-hero-image--mobile {
			display: none !important;
		}

		@media (max-width: 900px) and (orientation: portrait) {
			.pricing-hero {
				grid-template-columns: 1fr;
				align-items: center;
				justify-items: center;
				text-align: center;
			}

			.pricing-hero-copy {
				text-align: center;
				align-items: center;
			}

			.institution-plans-block {
				text-align: center;
			}
		}

		@media (max-width: 900px) {
			.pricing-hero {
				grid-template-columns: 1fr;
			}

			.pricing-hero-image--desktop {
				display: none !important;
			}

			.pricing-hero-image--mobile {
				display: block !important;
				margin-left: auto;
				margin-right: auto;
			}

			.pricing-hero-copy > .pricing-hero-actions {
				flex-direction: column;
				align-items: center;
				justify-content: center;
			}
		}

		.institution-plans-block {
			width: min(100%, 1100px);
			margin-inline: auto;
			text-align: left;
		}

		.institution-details-layout {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 420px);
			gap: 32px;
			align-items: start;
			margin-top: var(--section-block-gap-adjust) !important;
		}

		.institution-details-copy {
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
		}

		.institution-details-copy > * {
			margin: 0 !important;
		}

		.institution-details-copy > ul + h3 {
			margin-top: var(--section-block-gap-adjust) !important;
		}

		.onboarding-process-card {
			min-height: 0;
			align-self: start;
		}

		.onboarding-process-card .lede {
			color: var(--link);
		}

		.onboarding-note {
			color: var(--text) !important;
			font-size: 16px;
			font-weight: 400;
		}

		:global(.marketplace-pricing-layout) {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 420px);
			gap: 32px;
			align-items: start;
		}

		:global(.marketplace-pricing-copy) {
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
		}

		:global(.marketplace-pricing-copy > *) {
			margin: 0 !important;
		}

		:global(.marketplace-pricing-copy > .cta-row) {
			margin-top: var(--section-block-gap-adjust) !important;
		}

		:global(.protected-pricing-button) {
			display: inline-flex;
			align-items: center;
			gap: 8px;
		}

		:global(.protected-pricing-button img) {
			width: 20px;
			height: 20px;
			display: block;
			flex-shrink: 0;
		}

		:global(.marketplace-card-stack) {
			display: grid;
			gap: var(--section-flow-gap);
			align-self: start;
		}

		:global(.marketplace-card-stack > .card) {
			min-height: 0;
			width: 100%;
		}

		.creator-catalog-pricing {
			width: min(100%, 1180px);
			margin-inline: auto;
		}

		.creator-plan-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
			justify-content: stretch;
		}

		.creator-plan-card {
			min-height: 360px;
		}

		.plan-price {
			font-family: "Playfair Display", serif;
			font-size: clamp(28px, 3vw, 40px) !important;
			line-height: 1.05 !important;
			color: var(--text) !important;
			font-weight: 700;
		}

		.plan-price span {
			font-family: inherit;
			font-size: 16px;
			color: var(--muted);
			font-weight: 400;
		}

		.creator-pricing-notes {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: var(--section-flow-gap);
			margin-top: var(--section-block-gap-adjust) !important;
		}

		.creator-pricing-notes > div {
			display: flex;
			flex-direction: column;
			gap: 10px;
		}

		.creator-pricing-notes p,
		.creator-pricing-footnote {
			color: var(--text) !important;
		}


		@media (max-width: 1024px) {
			.creator-plan-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			:global(.marketplace-pricing-layout) {
				grid-template-columns: 1fr;
			}

			.institution-details-layout {
				grid-template-columns: 1fr;
			}
		}

		@media (max-width: 900px) {
			.creator-plan-grid,
			.creator-pricing-notes {
				grid-template-columns: 1fr;
			}
		}

		@media (orientation: landscape) and (max-width: 900px) {
			.pricing-hero {
				grid-template-columns: minmax(0, 1fr) minmax(0, 34%);
				gap: 20px;
				align-items: center;
			}

			.pricing-hero-title {
				font-size: clamp(23.8px, 3.825vw, 35.7px) !important;
			}

			.pricing-hero-image--desktop {
				max-width: 100% !important;
			}

			.creator-plan-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			.creator-plan-card {
				min-height: 0;
			}
		}
	</style>
</Base>

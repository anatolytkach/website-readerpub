---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, BOOKTREE_NAME, SITE_NAME, WEREAD_NAME } from "../consts";
import SectionIcon from "../components/SectionIcon.astro";
import IconGridSection from "../components/sections/IconGridSection.astro";
import ProofSection from "../components/sections/ProofSection.astro";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";

---

<Base title={`${SITE_NAME} — Public Reading and Publishing Platform`}>
	<section class="home-hero-title">
		<h1>ReaderPub—the web-native publishing platform.</h1>
	</section>
	<ProofSection variant="hero">
		<div>
			<p class="lede">
				Feels like an app. Works on the web. Fully protected.
				<img
					class="hero-inline-icon"
					src="/images/protected-shield.svg"
					alt=""
					aria-hidden="true"
				/>
				<br />
				No downloads. No PDFs. Just fast, clean web-native access on any device.
			</p>
			<ul class="bullets">
				<li>Authors sell directly, with a low 5% fee.</li>
				<li>Readers gain instant access to the book on any device, without downloading files or installing reading apps.</li>
				<li>Publishers maintain collections at web scale, fully protected from copying or downloading.</li>
				<li>Researchers share their work and receive immediate responses from the academic and investment communities.</li>
				<li>Instructors publish courses, and students master them interactively.</li>
				<li>Government, municipalities and charities make their publications instantly available to the public, with immediate response.</li>
			</ul>
			<p class="lede">
				Read, annotate, and share books and publications as living editions. Send a book with notes to an author or another reader, then keep building context together. Now with built-in read-aloud using device TTS voices.
			</p>
			<div class="cta-row">
				<a class="button secondary" href="/readers">For Readers</a>
				<a class="button secondary" href="/authors">For Authors</a>
				<a class="button secondary" href="/institutions">For Institutions</a>
			</div>
		</div>
		<img
			slot="media"
			class="image-block image-large proof-media"
			src="/images/home2.webp"
			alt="ReaderPub connects readers, publishers, and authors through WeRead, WePub, and BookTree"
			loading="eager"
			decoding="async"
			width="1115"
			height="900"
		/>
	</ProofSection>

	<SpecCardsSection class="section-continue-next">
		<h2>The ReaderPub platform family</h2>
		<p>Three components, one public platform.</p>
		<div class="card-grid">
			<div class="card">
				<h3>WePub</h3>
				<p>Publish to the web, enable sales, and build fan clubs around titles.</p>
				<button class="button secondary" type="button" data-modal-open="#wepub-modal">
					Explore WePub
				</button>
			</div>
			<div class="card">
				<h3>{WEREAD_NAME}</h3>
				<p>A modern web reader built for long-form reading and shared libraries.</p>
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
					80K+ books in Catalog
				</a>
			</div>
			<div class="card">
				<h3>{BOOKTREE_NAME}</h3>
				<p>Capture, structure, and publish research with clarity and speed.</p>
				<button class="button secondary" type="button" data-modal-open="#booktree-modal">
					Explore BookTree
				</button>
			</div>
		</div>
	</SpecCardsSection>

	<section class="home-two-up">
		<div class="section home-two-up-block">
			<h2>Read instantly on the web</h2>
			<p>Open a book in one click. No apps, no setup, no friction.</p>
			<ul class="bullets">
				<li>Web-first reading with dedicated-reader comfort.</li>
				<li>Works across devices — pick up where you left off.</li>
				<li>Instant access from a link: no downloads, no installs.</li>
				<li>Built for long sessions: clean UI, fast loading.</li>
			</ul>
		</div>
		<div class="section home-two-up-block">
			<h2>Who ReaderPub serves</h2>
			<p>Three core audiences, one public platform.</p>
			<ul class="bullets">
				<li>Readers who want trusted discovery and lasting libraries.</li>
				<li>Authors who publish, market, and sell directly to engaged readers.</li>
				<li>
					Institutions, including publishers, libraries, universities, government, and public
					organizations.
				</li>
			</ul>
		</div>
	</section>

	<div class="modal" id="wepub-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="WePub image">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>
					✕
				</button>
			<img src="/images/wepub.webp" alt="WePub image" loading="lazy" decoding="async" width="1024" height="592" />
		</div>
	</div>

	<div class="modal" id="booktree-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="BookTree image">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>
					✕
				</button>
			<img src="/images/booktree.webp" alt="BookTree image" loading="lazy" decoding="async" width="976" height="1219" />
		</div>
	</div>

	<style>
		.use-case-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.home-two-up {
			display: grid !important;
			grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
			gap: 58px;
			width: 100%;
			max-width: none;
			align-items: start;
		}

		.home-two-up-block {
			min-width: 0;
		}

		@media (max-width: 900px) {
			.use-case-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}

			@media (max-width: 720px) {
				.home-two-up {
					grid-template-columns: 1fr !important;
					gap: 36px;
				}
			}

		@media (max-width: 640px) {
			.use-case-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>

	<IconGridSection class="section-continuation">
		<h2>Common use cases</h2>
		<div class="card-grid use-case-grid icon-grid">
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="author" title="Authors & Publishers" />
				<div class="icon-grid-card-copy">
					<h3>Authors &amp; Publishers</h3>
					<p>Publish, promote, and sell books at a low 5% commission.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="reader" title="Readers" />
				<div class="icon-grid-card-copy">
					<h3>Readers</h3>
					<p>Discover books, read comfortably and share your opinion in discussions.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="public" title="Public reading rooms" />
				<div class="icon-grid-card-copy">
					<h3>Public reading rooms</h3>
					<p>Curated digital shelves for communities and partners.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="research" title="Researchers" />
				<div class="icon-grid-card-copy">
					<h3>Researchers</h3>
					<p>Release working papers and living books, receive instant feedback.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="program" title="Learning programs" />
				<div class="icon-grid-card-copy">
					<h3>Learning programs</h3>
					<p>Support cohort-based learning and reading challenges.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="library" title="Libraries" />
				<div class="icon-grid-card-copy">
					<h3>Libraries</h3>
					<p>Curate collections, serve communities, and expand digital access.</p>
				</div>
			</div>
		</div>
		<div class="footer-cta" style="background: transparent; border: 0; padding: 0; border-radius: 0;">
			<div class="card-grid onboarding-grid">
				<div class="card">
					<h2>Publish your book on ReaderPub</h2>
					<p class="lede">Sell directly to readers — keep your audience.</p>
					<ul class="bullets">
						<li>Upload Word or EPUB — single titles or batches.</li>
						<li>Set prices for sales: books, courses, cohorts and limited drops.</li>
						<li>Low 5% commission on sales.</li>
						<li>Fan clubs, direct messaging, and first-party analytics.</li>
					</ul>
					<div class="cta-row">
						<a class="button" href="/authors">Publishing features</a>
						<a class="button secondary" href="/pricing">See pricing</a>
					</div>
				</div>
				<div class="card">
					<h2>Onboard your organization on ReaderPub</h2>
					<p class="lede">Tell us what you need: We’ll set up your onboarding.</p>
					<ul class="bullets">
						<li>Import from OPDS feeds, MARC/ONIX/KBART, S3, or CSV exports.</li>
						<li>Preserve catalog metadata across large collections.</li>
						<li>Deploy on reader.pub subdomain or your own subdomain.</li>
						<li>Launch fan clubs and controlled-access programs.</li>
					</ul>
					<div class="cta-row">
						<a class="button" href="/contact">Institutional onboarding</a>
						<a class="button secondary" href="/pricing">See pricing</a>
					</div>
				</div>
			</div>
		</div>
	</IconGridSection>

	<style>
		.home-hero-title {
			padding-top: 54px;
			padding-bottom: 0;
		}

		.home-hero-title h1 {
			margin: 0;
			font-size: clamp(36px, 5vw, 56px);
			line-height: 1.1;
		}

		.home-thanks-note {
			color: var(--text) !important;
		}

		.home-full-width-copy {
			max-width: none !important;
		}

		:global(.home-indie-section p) {
			max-width: none !important;
		}

		:global(.proof-section.hero) {
			padding-top: 16px;
		}

		.hero-inline-icon {
			display: inline-block;
			width: 20px;
			height: 20px;
			margin-left: 8px;
			vertical-align: baseline;
		}

		.onboarding-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			width: 100%;
			text-align: left;
		}

		.footer-cta .card {
			text-align: left;
		}

		.onboarding-grid .card h2 {
			color: var(--text);
		}

		@media (max-width: 800px) {
			.onboarding-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>

	<script is:inline>
		(() => {
			const openButtons = Array.from(document.querySelectorAll("[data-modal-open]"));
			const modals = Array.from(document.querySelectorAll(".modal"));

			const closeModal = (modal) => {
				if (!modal) return;
				modal.classList.remove("is-open");
				modal.setAttribute("aria-hidden", "true");
			};

			const openModal = (modal) => {
				if (!modal) return;
				modal.classList.add("is-open");
				modal.setAttribute("aria-hidden", "false");
			};

			openButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const target = btn.getAttribute("data-modal-open");
					const modal = target ? document.querySelector(target) : null;
					openModal(modal);
				});
			});

			modals.forEach((modal) => {
				const closeTargets = modal.querySelectorAll("[data-modal-close]");
				closeTargets.forEach((el) => el.addEventListener("click", () => closeModal(modal)));
			});

			document.addEventListener("keydown", (event) => {
				if (event.key !== "Escape") return;
				modals.forEach((modal) => closeModal(modal));
			});
		})();
	</script>
</Base>

---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, BOOKTREE_NAME, SITE_NAME, WEREAD_NAME } from "../consts";
---

<Base title={`${SITE_NAME} — Public Reading and Publishing Platform`}>
	<section class="hero">
		<div>
			<h1>A public home for reading, publishing, and shared knowledge.</h1>
			<p class="lede">
				{SITE_NAME} connects readers, authors, and institutions through {WEREAD_NAME} and
				{BOOKTREE_NAME}.
			</p>
			<div class="cta-row">
				<a class="button" href="/contact">Join the preview</a>
				<a class="button secondary" href={BOOKS_URL} target="_blank" rel="noreferrer">
					Browse books
				</a>
			</div>
		</div>
		<div class="image-placeholder image-actual image-large">
			<img
				src="/images/home2.png"
				alt="ReaderPub connects readers, publishers, and authors through WeRead, WePub, and BookTree"
			/>
		</div>
	</section>

	<section class="split">
		<div class="image-placeholder image-actual">
			<img
				src="/images/home3.png"
				alt="Instant web reading experience without apps or downloads"
			/>
		</div>
		<div class="section">
			<h2>Read instantly on the web</h2>
			<p>A full reader experience without installing a thing.</p>
			<ul class="bullets">
				<li>No major library offers a true web reader with app-level UX.</li>
				<li>Many readers prefer not to install more reading apps.</li>
				<li>WeRead opens with a single click — no downloads, no setup.</li>
				<li>The comfort of a dedicated reader, right in the browser.</li>
			</ul>
		</div>
	</section>

	<section class="section">
		<h2>The ReaderPub platform family</h2>
		<p>One public platform with two focused experiences.</p>
		<div class="card-grid">
			<div class="card">
				<h3>WePub</h3>
				<p>Public reading and publishing with open discovery and collections.</p>
				<button class="button secondary" type="button" data-modal-open="#wepub-modal">
					Explore WePub
				</button>
			</div>
			<div class="card">
				<h3>{WEREAD_NAME}</h3>
				<p>A modern web reader built for long-form reading and shared libraries.</p>
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
					Read 80K books with WeRead
				</a>
			</div>
			<div class="card">
				<h3>{BOOKTREE_NAME}</h3>
				<p>Capture, structure, and publish research with clarity and speed.</p>
				<button class="button secondary" type="button" data-modal-open="#booktree-modal">
					Explore BookTree
				</button>
			</div>
		</div>
	</section>

	<div class="modal" id="wepub-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="WePub preview">
			<button class="modal-close" type="button" aria-label="Close" data-modal-close>
				×
			</button>
			<img src="/images/wepub.png" alt="WePub preview" />
		</div>
	</div>

	<div class="modal" id="booktree-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="BookTree preview">
			<button class="modal-close" type="button" aria-label="Close" data-modal-close>
				×
			</button>
			<img src="/images/booktree.png" alt="BookTree preview" />
		</div>
	</div>

	<section class="split">
		<div class="section">
			<h2>Who ReaderPub serves</h2>
			<p>Three core audiences, one public platform.</p>
			<ul class="bullets">
				<li>Readers who want trusted discovery and lasting libraries.</li>
				<li>Authors and researchers who publish with transparency.</li>
				<li>
					Institutions, including publishers, libraries, universities, government, and public
					organizations.
				</li>
			</ul>
			<div class="cta-row">
				<a class="button secondary" href="/readers">Explore Readers</a>
				<a class="button secondary" href="/authors">Explore Authors</a>
				<a class="button secondary" href="/institutions">Explore Institutions</a>
			</div>
		</div>
		<div class="image-placeholder image-actual image-bleed-right image-home-serve">
			<img
				src="/images/home1.png"
				alt="ReaderPub serves readers, authors, and institutions on a shared platform"
			/>
		</div>
	</section>

	<section class="section">
		<h2>Common use cases</h2>
		<div class="card-grid">
			<div class="card">
				<h3>Readers</h3>
				<p>Discover books, read comfortably, and build personal reading habits.</p>
			</div>
			<div class="card">
				<h3>Authors</h3>
				<p>Publish, promote, and sell books directly to real readers.</p>
			</div>
			<div class="card">
				<h3>Public reading rooms</h3>
				<p>Curated digital shelves for communities and partners.</p>
			</div>
			<div class="card">
				<h3>Researchers</h3>
				<p>Release working papers, living books, and open archives.</p>
			</div>
			<div class="card">
				<h3>Learning programs</h3>
				<p>Support cohort-based learning and reading challenges.</p>
			</div>
			<div class="card">
				<h3>Libraries</h3>
				<p>Curate collections, serve communities, and expand digital access.</p>
			</div>
		</div>
	</section>

	<section class="footer-cta">
		<h2>Be first to launch with ReaderPub</h2>
		<p>Talk to us about preview access, partnerships, and institutional pilots.</p>
		<a class="button" href="/contact">Contact ReaderPub</a>
	</section>

	<script is:inline>
		(() => {
			const openButtons = Array.from(document.querySelectorAll("[data-modal-open]"));
			const modals = Array.from(document.querySelectorAll(".modal"));

			const closeModal = (modal) => {
				if (!modal) return;
				modal.classList.remove("is-open");
				modal.setAttribute("aria-hidden", "true");
			};

			const openModal = (modal) => {
				if (!modal) return;
				modal.classList.add("is-open");
				modal.setAttribute("aria-hidden", "false");
			};

			openButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const target = btn.getAttribute("data-modal-open");
					const modal = target ? document.querySelector(target) : null;
					openModal(modal);
				});
			});

			modals.forEach((modal) => {
				const closeTargets = modal.querySelectorAll("[data-modal-close]");
				closeTargets.forEach((el) => el.addEventListener("click", () => closeModal(modal)));
			});

			document.addEventListener("keydown", (event) => {
				if (event.key !== "Escape") return;
				modals.forEach((modal) => closeModal(modal));
			});
		})();
	</script>
</Base>

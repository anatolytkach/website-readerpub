---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, BOOKTREE_NAME, SITE_NAME, WEREAD_NAME } from "../consts";
import SectionIcon from "../components/SectionIcon.astro";
import IconGridSection from "../components/sections/IconGridSection.astro";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";

const CATALOG_HERO_BOOK_OPTIONS = [
	{
		id: "90000074",
		title: "The Adventures of Tom Sawyer, Complete",
		author: "Mark Twain",
		cover: "https://reader.pub/books/protected-content/90000074/assets/OEBPS/1055025884842794877_cover.jpg",
	},
	{
		id: "90000120",
		title: "Treasure Island",
		author: "Robert Louis Stevenson",
		cover: "https://reader.pub/books/protected-content/90000120/assets/OEBPS/9148187011918732592_cover.jpg",
	},
	{
		id: "90008800",
		title: "The Divine Comedy",
		author: "Dante Alighieri; illustrated by Gustave Dore",
		cover: "https://reader.pub/books/protected-content/90008800/assets/OEBPS/975265859820879404_cover.jpg",
	},
	{
		id: "90014838",
		title: "The Tale of Peter Rabbit",
		author: "Beatrix Potter",
		cover: "https://reader.pub/books/protected-content/90014838/assets/OEBPS/5231809340272607769_peter02.gif.png",
	},
	{
		id: "90055040",
		title: 'The Nursery "Alice"',
		author: "Lewis Carroll",
		cover: "https://reader.pub/books/protected-content/90055040/assets/OEBPS/8035424117275221048_cover.jpg",
	},
	{
		id: "90016865",
		title: "Pinocchio: The Tale of a Puppet",
		author: "Carlo Collodi",
		cover: "https://reader.pub/books/protected-content/90016865/assets/OEBPS/5958518236637178825_illus-022.png",
	},
	{
		id: "90078504",
		title: "The Fairy Caravan",
		author: "Beatrix Potter",
		cover: "https://reader.pub/books/protected-content/90078504/assets/OEBPS/5784209194575853353_cover.jpg",
	},
	{
		id: "90025433",
		title: "The Baby's Own Aesop",
		author: "Aesop; illustrated by Walter Crane",
		cover: "https://reader.pub/books/protected-content/90025433/assets/OEBPS/2611731572878816242_front_cover.png",
	},
	{
		id: "90035997",
		title: "The Jungle Book",
		author: "Rudyard Kipling",
		cover: "https://reader.pub/books/protected-content/90035997/assets/OEBPS/5834958138474680943_cover.jpg",
	},
	{
		id: "90052521",
		title: "Grimm's Fairy Tales",
		author: "Jacob Grimm and Wilhelm Grimm",
		cover: "https://reader.pub/books/protected-content/90052521/assets/OEBPS/3371397222058935216_cover.jpg",
	},
	{
		id: "90071879",
		title: "The Tarzan Twins",
		author: "Edgar Rice Burroughs",
		cover: "https://reader.pub/books/protected-content/90071879/assets/OEBPS/7834129313317133214_cover.jpg",
	},
	{
		id: "90025344",
		title: "The Scarlet Letter",
		author: "Nathaniel Hawthorne",
		cover: "https://reader.pub/books/protected-content/90025344/assets/OEBPS/2874891055637417969_cover.jpg",
	},
];

---

<Base title={`${SITE_NAME} — Public Reading and Publishing Platform`}>
	<section class="home-intro-hero">
		<div class="home-intro-copy">
			<h1>ReaderPub—<br />the web-native publishing platform.</h1>
			<p class="lede home-intro-lede">
				<span class="home-intro-lede-line">
					Feels like an app. Works on the web.
					<span class="home-intro-protected-inline">
						Fully protected.
						<img class="hero-inline-icon" src="/images/protected-shield.svg" alt="" aria-hidden="true" />
					</span>
				</span>
				<br />
				No installs or downloads required. Just fast and clean web access to books on any device.
			</p>
		</div>
		<img
			class="image-block image-large home-intro-image"
			src="/images/home2.webp"
			alt="ReaderPub connects readers, publishers, and authors through WeRead, WePub, and BookTree"
			loading="eager"
			decoding="async"
			width="1115"
			height="900"
		/>
	</section>

	<section class="site-catalog-hero" aria-label="Reader experience preview">
		<div class="site-catalog-hero-top">
			<div class="site-catalog-hero-side">
				<div class="site-catalog-hero-copy">
					<div class="site-catalog-hero-eyebrow">{WEREAD_NAME} – THE BROWSER E-READER</div>
					<h2 class="site-catalog-hero-title">
						<span class="site-catalog-hero-title-line">60,000+ famous books.</span>
						<span class="site-catalog-hero-title-line">Genuine reading app.</span>
						<span class="site-catalog-hero-title-line">Right in your browser.</span>
					</h2>
					<p class="site-catalog-hero-text">
						<span class="site-catalog-hero-text-line">Smooth pages, instant open, preserved reading position, easy Notes, Comments and Sharing.</span>
					</p>
				</div>
			</div>
			<div class="site-catalog-hero-readers" aria-hidden="true">
				<img src="/images/readers1.webp" alt="" loading="lazy" decoding="async" width="1024" height="1024" />
			</div>
			<div class="site-catalog-hero-actions">
				<details class="site-hero-book-picker">
					<summary class="site-catalog-hero-button site-hero-book-picker-summary">Check it out in WeRead</summary>
					<div class="site-hero-book-picker-menu">
						{CATALOG_HERO_BOOK_OPTIONS.map((book) => (
							<a class="site-hero-book-option" href={`${BOOKS_URL}protected/?id=${book.id}`} target="_blank" rel="noreferrer">
								<img class="site-hero-book-option-cover" src={book.cover} alt="" />
								<span class="site-hero-book-option-body">
									<span class="site-hero-book-option-title">{book.title}</span>
									<span class="site-hero-book-option-author">{book.author}</span>
								</span>
							</a>
						))}
					</div>
				</details>
				<a class="site-catalog-hero-button site-catalog-hero-publish-button" href="https://reader.pub/publish/" target="_blank" rel="noreferrer">
					Publish Your Book
				</a>
			</div>
		</div>
	</section>

	<section class="home-features-hero">
		<div class="home-features-copy">
			<h2>ReaderPub Features</h2>
			<ul class="bullets home-features-bullets">
				<li>Authors sell directly, with a low 5% fee.</li>
				<li>Readers gain instant access to the book on any device, without downloading files or installing reading apps.</li>
				<li>Publishers maintain collections at web scale, fully protected from copying or downloading.</li>
				<li>Researchers share their work and receive immediate responses from the academic and investment communities.</li>
				<li>Instructors publish courses, and students master them interactively.</li>
				<li>Government, municipalities and charities make their publications instantly available to the public, with immediate response.</li>
			</ul>
			<img
				class="image-block home-features-image-mobile"
				src="/images/chain1.webp"
				alt="ReaderPub connects authors, publishers, libraries, and readers"
				loading="lazy"
				decoding="async"
				width="1200"
				height="1200"
			/>
			<p class="lede home-features-lede">
				Read, annotate, and share books and publications as living editions. Send a book with notes to an author or another reader, then keep building context together. Now with built-in read-aloud using device TTS voices.
			</p>
			<div class="cta-row home-features-actions">
				<a class="button secondary" href="/readers">For Readers</a>
				<a class="button secondary" href="/authors">For Authors</a>
				<a class="button secondary" href="/institutions">For Institutions</a>
			</div>
		</div>
		<img
			class="image-block home-features-image"
			src="/images/chain1.webp"
			alt="ReaderPub connects authors, publishers, libraries, and readers"
			loading="lazy"
			decoding="async"
			width="1200"
			height="1200"
		/>
	</section>

	<SpecCardsSection class="section-continue-next">
		<h2>The ReaderPub platform family</h2>
		<p>Three components, one public platform.</p>
		<div class="card-grid">
			<div class="card">
				<h3>WePub</h3>
				<p>Publish to the web, enable sales, and build fan clubs around titles.</p>
				<button class="button secondary" type="button" data-modal-open="#wepub-modal">
					Explore WePub
				</button>
			</div>
			<div class="card">
				<h3>{WEREAD_NAME}</h3>
				<p>A modern web reader built for long-form reading and shared libraries.</p>
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
					60K+ books in Catalog
				</a>
			</div>
			<div class="card">
				<h3>{BOOKTREE_NAME}</h3>
				<p>Capture, structure, and publish research with clarity and speed.</p>
				<button class="button secondary" type="button" data-modal-open="#booktree-modal">
					Explore BookTree
				</button>
			</div>
		</div>
	</SpecCardsSection>

	<section class="home-two-up">
		<div class="section home-two-up-block">
			<h2>Read instantly on the web</h2>
			<p>Open a book in one click. No apps, no setup, no friction.</p>
			<ul class="bullets">
				<li>Web-first reading with dedicated-reader comfort.</li>
				<li>Works across devices — pick up where you left off.</li>
				<li>Instant access from a link: no downloads, no installs.</li>
				<li>Built for long sessions: clean UI, fast loading.</li>
			</ul>
		</div>
		<div class="section home-two-up-block">
			<h2>Who ReaderPub serves</h2>
			<p>Three core audiences, one public platform.</p>
			<ul class="bullets">
				<li>Readers who want trusted discovery and lasting libraries.</li>
				<li>Authors who publish, market, and sell directly to engaged readers.</li>
				<li>
					Institutions, including publishers, libraries, universities, government, and public
					organizations.
				</li>
			</ul>
		</div>
	</section>

	<div class="modal" id="wepub-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="WePub image">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>
					✕
				</button>
			<img src="/images/wepub.webp" alt="WePub image" loading="lazy" decoding="async" width="1024" height="592" />
		</div>
	</div>

	<div class="modal" id="booktree-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="BookTree image">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>
					✕
				</button>
			<img src="/images/booktree.webp" alt="BookTree image" loading="lazy" decoding="async" width="976" height="1219" />
		</div>
	</div>

	<style>
		.use-case-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.home-two-up {
			display: grid !important;
			grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
			gap: 58px;
			width: 100%;
			max-width: none;
			align-items: start;
		}

		.home-two-up-block {
			min-width: 0;
		}

		@media (max-width: 900px) {
			.use-case-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}

			@media (max-width: 720px) {
				.home-two-up {
					grid-template-columns: 1fr !important;
					gap: 36px;
				}
			}

		@media (max-width: 640px) {
			.use-case-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>

	<IconGridSection class="section-continuation">
		<h2>Common use cases</h2>
		<div class="card-grid use-case-grid icon-grid">
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="author" title="Authors & Publishers" />
				<div class="icon-grid-card-copy">
					<h3>Authors &amp; Publishers</h3>
					<p>Publish, promote, and sell books at a low 5% commission.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="reader" title="Readers" />
				<div class="icon-grid-card-copy">
					<h3>Readers</h3>
					<p>Discover books, read comfortably and share your opinion in discussions.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="public" title="Public reading rooms" />
				<div class="icon-grid-card-copy">
					<h3>Public reading rooms</h3>
					<p>Curated digital shelves for communities and partners.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="research" title="Researchers" />
				<div class="icon-grid-card-copy">
					<h3>Researchers</h3>
					<p>Release working papers and living books, receive instant feedback.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="program" title="Learning programs" />
				<div class="icon-grid-card-copy">
					<h3>Learning programs</h3>
					<p>Support cohort-based learning and reading challenges.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="library" title="Libraries" />
				<div class="icon-grid-card-copy">
					<h3>Libraries</h3>
					<p>Curate collections, serve communities, and expand digital access.</p>
				</div>
			</div>
		</div>
		<div class="footer-cta" style="background: transparent; border: 0; padding: 0; border-radius: 0;">
			<div class="card-grid onboarding-grid">
				<div class="card">
					<h2>Publish your book on ReaderPub</h2>
					<p class="lede">Sell directly to readers — keep your audience.</p>
					<ul class="bullets">
						<li>Upload Word or EPUB — single titles or batches.</li>
						<li>Set prices for sales: books, courses, cohorts and limited drops.</li>
						<li>Low 5% commission on sales.</li>
						<li>Fan clubs, direct messaging, and first-party analytics.</li>
					</ul>
					<div class="cta-row">
						<a class="button" href="/authors">Publishing features</a>
						<a class="button secondary" href="/pricing">See pricing</a>
					</div>
				</div>
				<div class="card">
					<h2>Onboard your organization on ReaderPub</h2>
					<p class="lede">Tell us what you need: We’ll set up your onboarding.</p>
					<ul class="bullets">
						<li>Import from OPDS feeds, MARC/ONIX/KBART, S3, or CSV exports.</li>
						<li>Preserve catalog metadata across large collections.</li>
						<li>Deploy on reader.pub subdomain or your own subdomain.</li>
						<li>Launch fan clubs and controlled-access programs.</li>
					</ul>
					<div class="cta-row">
						<a class="button" href="/contact">Institutional onboarding</a>
						<a class="button secondary" href="/pricing">See pricing</a>
					</div>
				</div>
			</div>
		</div>
	</IconGridSection>

	<style>
		.home-intro-hero,
		.home-features-hero {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(420px, 48%);
			gap: 32px;
		}

		.home-intro-hero {
			align-items: center;
		}

		.home-features-hero {
			align-items: start;
		}

		.home-intro-copy,
		.home-features-copy {
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
			min-width: 0;
		}

		.home-intro-copy {
			align-self: center;
		}

		.home-intro-copy,
		.home-features-copy {
			grid-column: 1;
		}

		.home-intro-image,
		.home-features-image {
			grid-column: 2;
			justify-self: end;
		}

		.home-intro-image {
			align-self: center;
		}

		.home-features-image {
			align-self: start;
		}

		.home-features-image-mobile {
			display: none;
		}

		.home-intro-copy > *,
		.home-features-copy > * {
			margin: 0;
		}

		.home-intro-hero {
			padding-top: 54px;
		}

		.home-intro-copy h1 {
			margin: 0;
			font-size: clamp(36px, 5vw, 56px) !important;
			line-height: 1.1 !important;
		}

		.home-intro-lede,
		.home-features-lede {
			color: var(--link) !important;
		}

		.home-features-lede,
		.home-features-actions {
			margin: 0;
		}

		@media (orientation: landscape) {
			.home-features-hero {
				grid-template-columns: minmax(0, 1fr) minmax(420px, 48%);
				gap: 32px;
				align-items: start;
			}

			.home-features-copy {
				grid-column: 1;
			}

			.home-features-image-mobile {
				display: none !important;
			}

			.home-features-image {
				display: block;
				grid-column: 2;
				justify-self: end;
				align-self: start;
			}

			.home-features-actions {
				justify-content: flex-start;
				width: auto;
				max-width: none;
				margin: 0;
			}
		}

		.home-intro-copy > .home-intro-lede {
			font-size: 27px !important;
			line-height: 1.45 !important;
		}

		.home-intro-lede-line {
			display: inline;
		}

		.home-intro-protected-inline {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			white-space: nowrap;
		}

		.hero-inline-icon {
			display: block;
			width: 22px;
			height: 22px;
			flex: 0 0 auto;
		}

		.home-intro-image,
		.home-features-image {
			width: 100%;
			margin: 0;
		}

		.home-intro-image {
			max-width: 640px !important;
		}

		.home-features-image {
			max-width: 560px !important;
		}

		.home-features-copy h2 {
			font-size: clamp(24px, 3vw, 34px) !important;
			line-height: 1.15 !important;
		}

		.site-catalog-hero {
			display: flex;
			flex-direction: column;
			gap: 24px;
			align-items: stretch;
			margin-bottom: 0;
			padding-bottom: 28px;
			width: 100%;
			max-width: none;
		}

		.site-catalog-hero-top {
			display: grid;
			grid-template-columns: minmax(420px, 48%) minmax(520px, 1fr);
			grid-template-areas:
				"image copy"
				"image actions";
			column-gap: 56px;
			row-gap: 20px;
			align-items: center;
			width: 100%;
			max-width: none;
		}

		.site-catalog-hero-side {
			grid-area: copy;
			grid-column: 2;
			grid-row: 1;
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: flex-start;
			min-width: 0;
			max-width: none;
			width: 100%;
			gap: 0;
			justify-self: start;
			align-self: center;
		}

		.site-catalog-hero-copy {
			padding: 0;
			display: flex;
			flex-direction: column;
			justify-content: center;
			gap: 16px;
			max-width: 760px;
			width: 100%;
			border: none;
			background: transparent;
			box-shadow: none;
			min-width: 0;
		}

		.site-catalog-hero-copy > * {
			margin: 0;
		}

		.site-catalog-hero-readers {
			grid-area: image;
			grid-column: 1;
			grid-row: 1 / span 2;
			display: flex;
			align-items: center;
			justify-content: flex-start;
			pointer-events: none;
			min-width: 0;
			justify-self: start;
			align-self: center;
			width: 100%;
			max-width: 760px;
		}

		.site-catalog-hero-readers img {
			display: block;
			width: 100%;
			height: auto;
			object-fit: contain;
			transform: none;
		}

		.site-catalog-hero-eyebrow {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			font-size: clamp(13px, 1.35vw, 15px);
			letter-spacing: 0.06em;
			color: #008f80;
			font-weight: 400;
		}

		.site-catalog-hero-title {
			margin: 0;
			font-family: "Playfair Display", "Times New Roman", serif;
			font-size: clamp(44px, 3.85vw, 72px);
			line-height: 0.98;
			letter-spacing: -0.03em;
			color: #14202f;
			max-width: 100%;
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			gap: 0.04em;
			width: 100%;
		}

		.site-catalog-hero-title-line {
			display: block;
			white-space: nowrap;
		}

		.site-catalog-hero-text-line {
			display: block;
			white-space: normal;
		}

		.site-catalog-hero-text {
			margin: 0;
			max-width: 760px;
			font-size: clamp(16px, 1.55vw, 18px);
			line-height: 1.42;
			color: #586273;
			display: flex;
			flex-direction: column;
			align-items: flex-start;
			gap: 0.28em;
			width: 100%;
		}

		.site-catalog-hero-actions {
			grid-area: actions;
			grid-column: 2;
			grid-row: 2;
			display: flex;
			flex-wrap: nowrap;
			gap: 12px;
			align-items: center;
			justify-content: flex-start;
			width: auto;
			max-width: 760px;
			margin-top: 10px;
			justify-self: start;
			align-self: start;
		}

		.site-catalog-hero-button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 10px 18px;
			border-radius: 999px;
			border: 1px solid var(--accent);
			color: #ffffff;
			background: var(--accent);
			font-weight: 600;
			font-size: 14px;
			line-height: 1.4;
			box-shadow: none;
			transition: transform 0.2s ease, box-shadow 0.2s ease;
			cursor: pointer;
			text-decoration: none;
		}


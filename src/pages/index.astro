---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, SITE_NAME } from "../consts";
import SectionIcon from "../components/SectionIcon.astro";
import AudienceNavCards from "../components/sections/AudienceNavCards.astro";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
---

<Base title={`${SITE_NAME} — Public Reading and Publishing Platform`}>
	<section class="home-intro-hero">
		<div class="home-intro-copy">
			<h1 class="home-hero-heading">Books Built for the Internet</h1>
			<p class="lede home-intro-lede">
				<span class="home-intro-lede-line">
					Read instantly in your browser. Publish securely. Distribute globally.<br />
					No apps, downloads, or platform <span class="home-intro-no-break">lock-in</span>.
				</span>
				<span class="home-intro-protected-inline">
					With the <span class="home-intro-brand-inline">ReaderPub</span> web-native publishing platform, your books and knowledge publications are instantly accessible and protected – no DRM required.
					<span class="hero-inline-icon" aria-hidden="true">
						<SectionIcon type="security" title="Protection icon" />
					</span>
				</span>
			</p>
			<div class="cta-row home-intro-actions home-intro-actions-catalog">
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">60K+ famous books in Catalog</a>
			</div>
		</div>
		<img
			class="image-block image-large home-intro-image"
			src="/images/chain1.webp"
			alt="ReaderPub connects authors, publishers, libraries, and readers"
			loading="eager"
			decoding="async"
			width="1200"
			height="1059"
		/>
	</section>

	<SpecCardsSection class="home-audience-cards section-continue-next">
		<AudienceNavCards />
	</SpecCardsSection>


	<style>
		.home-intro-hero {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(0, 48%);
			gap: 32px;
			align-items: center;
			padding-top: 54px;
			padding-bottom: 20px;
		}

		:global(.home-audience-cards) {
			padding-top: 20px !important;
		}

		.home-intro-copy {
			display: flex;
			flex-direction: column;
			gap: var(--section-flow-gap);
			min-width: 0;
			align-self: center;
			grid-column: 1;
		}

		.home-intro-image {
			grid-column: 2;
			justify-self: end;
			align-self: center;
			width: 100%;
			margin: 0;
			max-width: 640px !important;
		}

		.home-intro-copy > * {
			margin: 0;
		}

		.home-intro-copy .home-hero-heading {
			font-size: clamp(28px, 8.4vw, 56px) !important;
			line-height: 1.1 !important;
			max-width: 100%;
			overflow-wrap: break-word;
		}

		.home-intro-lede {
			color: var(--link) !important;
		}

		.home-intro-actions {
			margin: 0;
		}

		.home-intro-actions-catalog {
			margin-top: calc(var(--section-flow-gap) * -0.25);
		}

		.home-intro-actions-catalog .button {
			font-size: calc(14px * 1.3);
			padding: calc(10px * 1.3) calc(18px * 1.3);
			max-width: 100%;
			text-align: center;
			white-space: normal;
		}

		.home-intro-copy > .home-intro-lede {
			font-size: 27px !important;
			line-height: 1.45 !important;
		}

		.home-intro-lede-line {
			display: block;
			line-height: inherit;
		}

		.home-intro-protected-inline {
			display: block;
			line-height: inherit;
			margin-top: 0.54em;
			white-space: normal;
			color: var(--text);
			font-size: 0.8em;
		}

		.home-intro-brand-inline {
			font-family: "Playfair Display", serif;
			font-weight: 700;
			color: var(--text);
		}

		.home-intro-no-break {
			white-space: nowrap;
		}

		.hero-inline-icon {
			display: inline-block;
			width: 1em;
			height: 1em;
			line-height: 0;
			vertical-align: -0.12em;
			margin-left: 0.16em;
			transform: translateY(-0.02em) scale(1.56);
			transform-origin: left center;
		}

		.hero-inline-icon :global(.section-icon) {
			width: 100%;
			height: 100%;
			display: block;
		}

		@media (orientation: portrait) {
			.home-intro-hero {
				padding-top: 29px;
				grid-template-columns: 1fr;
				align-items: center;
				justify-items: center;
				text-align: center;
			}

			.home-intro-copy {
				align-items: center;
				text-align: center;
			}

			.home-intro-image {
				justify-self: center;
				margin-inline: auto;
			}

			.home-intro-copy > .home-intro-lede {
				font-size: 21.6px !important;
			}

			.home-intro-copy,
			.home-intro-image {
				grid-column: auto;
			}
		}

		@media (max-width: 400px) {
			.home-intro-copy .home-hero-heading {
				font-size: clamp(26px, 7.5vw, 32px) !important;
			}

			.home-intro-copy > .home-intro-lede {
				font-size: 19px !important;
			}

			.home-intro-actions-catalog .button {
				font-size: 15px;
				padding: 10px 14px;
			}
		}

		@media (orientation: landscape) and (max-width: 900px) {
			.home-intro-hero {
				padding-top: 16px;
				grid-template-columns: minmax(0, 1fr) minmax(0, 42%);
				gap: 20px;
				align-items: center;
			}

			.home-intro-copy > .home-intro-lede {
				font-size: 18px !important;
				line-height: 1.35 !important;
			}

			.home-intro-image {
				max-width: 100% !important;
			}

			.home-features-hero {
				grid-template-columns: minmax(0, 1fr) minmax(0, 42%);
				gap: 20px;
				align-items: start;
			}

			.home-features-image {
				display: block;
				max-width: 100% !important;
			}

			.home-features-image-mobile {
				display: none !important;
			}

			.home-features-actions {
				justify-content: flex-start;
				margin: 0;
			}

			.site-catalog-hero-top {
				grid-template-columns: minmax(0, 50%) minmax(0, 1fr);
				column-gap: 24px;
			}

			.site-catalog-hero-title {
				font-size: clamp(28px, 4vw, 44px);
			}

			.site-catalog-hero-actions {
				flex-wrap: wrap;
				gap: 8px;
			}

			.site-hero-book-picker-menu {
				max-height: 200px;
			}
		}
	</style>

</Base>

---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, BOOKTREE_NAME, SITE_NAME, WEREAD_NAME } from "../consts";
import SectionIcon from "../components/SectionIcon.astro";
import IconGridSection from "../components/sections/IconGridSection.astro";
import ProofSection from "../components/sections/ProofSection.astro";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";

const featuredBooks = [
	{
		title: "Abducted to Oz",
		author: "Evans, Robert J.",
		readUrl: "https://reader.pub/books/reader/?id=10127",
		coverUrl: "https://reader.pub/books/content/10127/OEBPS/5520401511868121211_10127-cover.png",
		buyUrl: "/contact",
	},
	{
		title: "Absurd Ditties",
		author: "Farrow, G. E.",
		readUrl: "https://reader.pub/books/reader/?id=53190",
		coverUrl: "https://reader.pub/books/content/53190/OEBPS/2634218585178233573_cover.jpg",
		buyUrl: "/contact",
	},
	{
		title: "A Black Adonis",
		author: "Porter, Linn Boyd",
		readUrl: "https://reader.pub/books/reader/?id=26599",
		coverUrl: "https://reader.pub/books/content/26599/OEBPS/4328419331932462176_fcover.jpg",
		buyUrl: "/contact",
	},
	{
		title: "ABC's of Science",
		author: "Oliver, Charles A.",
		readUrl: "https://reader.pub/books/reader/?id=1331",
		coverUrl: "https://reader.pub/books/content/1331/OEBPS/5971494174478934257_1331-cover.png",
		buyUrl: "/contact",
	},
	{
		title: "Abijah's Bubble",
		author: "Smith, Francis Hopkinson",
		readUrl: "https://reader.pub/books/reader/?id=23699",
		coverUrl: "https://reader.pub/books/content/23699/OEBPS/5956686520237392739_23699-cover.png",
		buyUrl: "/contact",
	},
	{
		title: "A Boy Knight",
		author: "Scott, Martin J.",
		readUrl: "https://reader.pub/books/reader/?id=32365",
		coverUrl: "https://reader.pub/books/content/32365/OEBPS/6260335208709197217_32365-cover.png",
		buyUrl: "/contact",
	},
];
---

<Base title={`${SITE_NAME} — Public Reading and Publishing Platform`}>
	<ProofSection variant="hero">
		<div>
			<h1>ReaderPub is the web-native publishing platform.</h1>
			<p class="lede">
				80,000+ books already live in the Catalog.
				<br />
				Independent authors sell and rent direct with 5% fees.
				<br />
				Institutions publish collections at web scale.
			</p>
			<div class="cta-row">
				<a class="button secondary" href="/readers">For Readers</a>
				<a class="button secondary" href="/authors">For Authors</a>
				<a class="button secondary" href="/institutions">For Institutions</a>
			</div>
		</div>
		<img
			slot="media"
			class="image-block image-large proof-media"
			src="/images/home2.webp"
			alt="ReaderPub connects readers, publishers, and authors through WeRead, WePub, and BookTree"
			loading="eager"
			decoding="async"
			width="1536"
			height="1319"
		/>
	</ProofSection>

	<SpecCardsSection class="section-continue-next">
		<h2>The ReaderPub platform family</h2>
		<p>Three components, one public platform.</p>
		<div class="card-grid">
			<div class="card">
				<h3>WePub</h3>
				<p>Publish to the web, enable sales and rentals, and build fan clubs around titles.</p>
				<button class="button secondary" type="button" data-modal-open="#wepub-modal">
					Explore WePub
				</button>
			</div>
			<div class="card">
				<h3>{WEREAD_NAME}</h3>
				<p>A modern web reader built for long-form reading and shared libraries.</p>
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
					80K+ books in Catalog
				</a>
			</div>
			<div class="card">
				<h3>{BOOKTREE_NAME}</h3>
				<p>Capture, structure, and publish research with clarity and speed.</p>
				<button class="button secondary" type="button" data-modal-open="#booktree-modal">
					Explore BookTree
				</button>
			</div>
		</div>
	</SpecCardsSection>

	<section class="home-two-up">
		<div class="section home-two-up-block">
			<h2>Read instantly on the web</h2>
			<p>Open a book in one click. No apps, no setup, no friction.</p>
			<ul class="bullets">
				<li>Web-first reading with dedicated-reader comfort.</li>
				<li>Works across devices — pick up where you left off.</li>
				<li>Instant access from a link: no downloads, no installs.</li>
				<li>Built for long sessions: clean UI, fast loading.</li>
			</ul>
		</div>
		<div class="section home-two-up-block">
			<h2>Who ReaderPub serves</h2>
			<p>Three core audiences, one public platform.</p>
			<ul class="bullets">
				<li>Readers who want trusted discovery and lasting libraries.</li>
				<li>Authors who publish, market, sell, and rent directly to readers.</li>
				<li>
					Institutions, including publishers, libraries, universities, government, and public
					organizations.
				</li>
			</ul>
		</div>
	</section>

	<div class="modal" id="wepub-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="WePub image">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>
					✕
				</button>
			<img src="/images/wepub.webp" alt="WePub image" loading="lazy" decoding="async" width="1024" height="592" />
		</div>
	</div>

	<div class="modal" id="booktree-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="BookTree image">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>
					✕
				</button>
			<img src="/images/booktree.webp" alt="BookTree image" loading="lazy" decoding="async" width="976" height="1219" />
		</div>
	</div>

	<SpecCardsSection>
		<h2 id="indie-releases">Independent publishing is live on ReaderPub.</h2>
		<p>
			WeRead Catalog includes 80,000+ public-domain books (with thanks to Project Gutenberg).
			<br />
			These featured titles are independent releases published by authors on ReaderPub:
		</p>
		<div class="card-grid">
			{featuredBooks.map((b) => (
				<a class="book-card-link" href={b.readUrl} target="_blank" rel="noreferrer">
					<div class="card book-card">
						<div class="book-cover-placeholder" style={`background-image: url('${b.coverUrl}');`}></div>
						<div class="book-card-text">
							<h3>{b.title}</h3>
							<p>{b.author}</p>
						</div>
					</div>
				</a>
			))}
		</div>
		<p>Live today: web reading, direct sales, rentals, analytics.</p>
		<div class="cta-row">
			<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
				Browse 80,000+ books
			</a>
			<a class="button secondary" href="/authors">Start publishing</a>
		</div>
	</SpecCardsSection>

	<style>
		.book-card-link {
			display: block;
			text-decoration: none;
			color: inherit;
			transition: transform 0.15s ease;
		}

		.book-card-link:hover,
		.book-card-link:focus-visible {
			transform: translateY(-2px);
		}

		.book-card {
			display: flex;
			flex-direction: row;
			gap: 16px;
			align-items: center;
		}

		.book-cover-placeholder {
			width: 72px;
			height: 96px;
			border-radius: 6px;
			background: linear-gradient(135deg, #e9eef3, #d8e1ea);
			background-size: cover;
			background-position: center;
			background-repeat: no-repeat;
			flex-shrink: 0;
		}

		.book-card-text {
			display: grid;
			gap: 6px;
		}

		.book-card h3 {
			color: var(--link);
			font-size: clamp(15px, 1.3vw, 21px);
		}

		.use-case-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			justify-content: stretch;
			justify-items: stretch;
			width: 100%;
			max-width: none;
		}

		.home-two-up {
			display: grid !important;
			grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
			gap: 58px;
			width: 100%;
			max-width: none;
			align-items: start;
		}

		.home-two-up-block {
			min-width: 0;
		}

		@media (max-width: 900px) {
			.use-case-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}

			@media (max-width: 720px) {
				.home-two-up {
					grid-template-columns: 1fr !important;
					gap: 36px;
				}
			}

		@media (max-width: 640px) {
			.use-case-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>

	<IconGridSection class="section-continuation">
		<h2>Common use cases</h2>
		<div class="card-grid use-case-grid icon-grid">
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="reader" title="Readers" />
				<div class="icon-grid-card-copy">
					<h3>Readers</h3>
					<p>Discover books, read comfortably, and build personal reading habits.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="author" title="Authors" />
				<div class="icon-grid-card-copy">
					<h3>Authors</h3>
					<p>Publish, promote, and sell books directly to real readers.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="public" title="Public reading rooms" />
				<div class="icon-grid-card-copy">
					<h3>Public reading rooms</h3>
					<p>Curated digital shelves for communities and partners.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="research" title="Researchers" />
				<div class="icon-grid-card-copy">
					<h3>Researchers</h3>
					<p>Release working papers, living books, and open archives.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="program" title="Learning programs" />
				<div class="icon-grid-card-copy">
					<h3>Learning programs</h3>
					<p>Support cohort-based learning and reading challenges.</p>
				</div>
			</div>
			<div class="card use-case-card icon-grid-card">
				<SectionIcon type="library" title="Libraries" />
				<div class="icon-grid-card-copy">
					<h3>Libraries</h3>
					<p>Curate collections, serve communities, and expand digital access.</p>
				</div>
			</div>
		</div>
		<div class="footer-cta" style="background: transparent; border: 0; padding: 0; border-radius: 0;">
			<div class="card-grid onboarding-grid">
				<div class="card">
					<h2>Publish your book on ReaderPub</h2>
					<p class="lede">Sell and rent directly to readers — keep your audience.</p>
					<ul class="bullets">
						<li>Upload Word, PDF, or EPUB — single titles or batches.</li>
						<li>Set prices for sales and rentals (courses, cohorts, limited drops).</li>
						<li>Low commission: 5% on sales, 5% on rentals.</li>
						<li>Fan clubs, direct messaging, and first-party analytics.</li>
					</ul>
					<div class="cta-row">
						<a class="button" href="/authors">Publishing features</a>
						<a class="button secondary" href="/pricing">See pricing</a>
					</div>
				</div>
				<div class="card">
					<h2>Onboard your organization on ReaderPub</h2>
					<p class="lede">Tell us what you need: We’ll set up your onboarding.</p>
					<ul class="bullets">
						<li>Import from OPDS feeds, MARC/ONIX/KBART, S3, or CSV exports.</li>
						<li>Preserve catalog metadata across large collections.</li>
						<li>Deploy on reader.pub subdomain or your own subdomain.</li>
						<li>Launch fan clubs and controlled-access programs.</li>
					</ul>
					<div class="cta-row">
						<a class="button" href="/contact#request-onboarding">Institutional onboarding</a>
						<a class="button secondary" href="/pricing">See pricing</a>
					</div>
				</div>
			</div>
		</div>
	</IconGridSection>

	<style>
		.onboarding-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			width: 100%;
			text-align: left;
		}

		.footer-cta .card {
			text-align: left;
		}

		.onboarding-grid .card h2 {
			color: var(--text);
		}

		@media (max-width: 800px) {
			.onboarding-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>

	<script is:inline>
		(() => {
			const openButtons = Array.from(document.querySelectorAll("[data-modal-open]"));
			const modals = Array.from(document.querySelectorAll(".modal"));

			const closeModal = (modal) => {
				if (!modal) return;
				modal.classList.remove("is-open");
				modal.setAttribute("aria-hidden", "true");
			};

			const openModal = (modal) => {
				if (!modal) return;
				modal.classList.add("is-open");
				modal.setAttribute("aria-hidden", "false");
			};

			openButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const target = btn.getAttribute("data-modal-open");
					const modal = target ? document.querySelector(target) : null;
					openModal(modal);
				});
			});

			modals.forEach((modal) => {
				const closeTargets = modal.querySelectorAll("[data-modal-close]");
				closeTargets.forEach((el) => el.addEventListener("click", () => closeModal(modal)));
			});

			document.addEventListener("keydown", (event) => {
				if (event.key !== "Escape") return;
				modals.forEach((modal) => closeModal(modal));
			});
		})();
	</script>
</Base>

---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, BOOKTREE_NAME, SITE_NAME, WEREAD_NAME } from "../consts";

const featuredBooks = [
	{
		title: "Book Title 1",
		author: "Author Name 1",
		readUrl: `${BOOKS_URL}#book-1`,
		buyUrl: "/contact",
	},
	{
		title: "Book Title 2",
		author: "Author Name 2",
		readUrl: `${BOOKS_URL}#book-2`,
		buyUrl: "/contact",
	},
	{
		title: "Book Title 3",
		author: "Author Name 3",
		readUrl: `${BOOKS_URL}#book-3`,
		buyUrl: "/contact",
	},
	{
		title: "Book Title 4",
		author: "Author Name 4",
		readUrl: `${BOOKS_URL}#book-4`,
		buyUrl: "/contact",
	},
	{
		title: "Book Title 5",
		author: "Author Name 5",
		readUrl: `${BOOKS_URL}#book-5`,
		buyUrl: "/contact",
	},
	{
		title: "Book Title 6",
		author: "Author Name 6",
		readUrl: `${BOOKS_URL}#book-6`,
		buyUrl: "/contact",
	},
];
---

<Base title={`${SITE_NAME} — Public Reading and Publishing Platform`}>
	<section class="hero">
		<div>
			<h1>A live platform for reading and publishing on the public web.</h1>
			<p class="lede">
				{SITE_NAME} is live: read now with {WEREAD_NAME}, publish with WePub, and organize
				sources with {BOOKTREE_NAME}.
			</p>
			<div class="cta-row">
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
					Browse books
				</a>
				<a class="button secondary" href="/publish">Publish your book</a>
				<a class="button secondary" href="/contact">Institutional onboarding</a>
			</div>
		</div>
		<img
			class="image-block image-large"
			src="/images/home2.png"
			alt="ReaderPub connects readers, publishers, and authors through WeRead, WePub, and BookTree"
		/>
	</section>

	<section class="split">
		<img
			class="image-block"
			src="/images/home3.png"
			alt="Instant web reading experience without apps or downloads"
		/>
		<div class="section">
			<h2>Read instantly on the web</h2>
			<p>Open a book in one click. No apps, no setup, no friction.</p>
			<ul class="bullets">
				<li>Web-first reading with dedicated-reader comfort.</li>
				<li>Works across devices — pick up where you left off.</li>
				<li>Instant access from a link: no downloads, no installs.</li>
				<li>Built for long sessions: clean UI, fast loading.</li>
			</ul>
		</div>
	</section>

	<section class="section">
		<h2>The ReaderPub platform family</h2>
		<p>Three components, one public platform.</p>
		<div class="card-grid">
			<div class="card">
				<h3>WePub</h3>
				<p>Publish to the web, enable sales and rentals, and build fan clubs around titles.</p>
				<button class="button secondary" type="button" data-modal-open="#wepub-modal">
					Explore WePub
				</button>
			</div>
			<div class="card">
				<h3>{WEREAD_NAME}</h3>
				<p>A modern web reader built for long-form reading and shared libraries.</p>
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
					Read 80K books with WeRead
				</a>
			</div>
			<div class="card">
				<h3>{BOOKTREE_NAME}</h3>
				<p>Capture, structure, and publish research with clarity and speed.</p>
				<button class="button secondary" type="button" data-modal-open="#booktree-modal">
					Explore BookTree
				</button>
			</div>
		</div>
	</section>

	<div class="modal" id="wepub-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="WePub preview">
			<button class="modal-close" type="button" aria-label="Close" data-modal-close>
				×
			</button>
			<img src="/images/wepub.png" alt="WePub preview" />
		</div>
	</div>

	<div class="modal" id="booktree-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="BookTree preview">
			<button class="modal-close" type="button" aria-label="Close" data-modal-close>
				×
			</button>
			<img src="/images/booktree.png" alt="BookTree preview" />
		</div>
	</div>

	<section class="split">
		<div class="section">
			<h2>Who ReaderPub serves</h2>
			<p>Three core audiences, one public platform.</p>
			<ul class="bullets">
				<li>Readers who want trusted discovery and lasting libraries.</li>
				<li>Authors who publish, market, sell, and rent directly to readers.</li>
				<li>
					Institutions, including publishers, libraries, universities, government, and public
					organizations.
				</li>
			</ul>
			<div class="cta-row">
				<a class="button secondary" href="/readers">Explore Readers</a>
				<a class="button secondary" href="/authors">Explore Authors</a>
				<a class="button secondary" href="/institutions">Explore Institutions</a>
			</div>
		</div>
		<img
			class="image-block image-bleed-right image-home-serve"
			src="/images/home1.png"
			alt="ReaderPub serves readers, authors, and institutions on a shared platform"
		/>
	</section>

	<section class="section">
		<h2>ReaderPub is a live publishing marketplace.</h2>
		<p>
			80,000+ public-domain books are already available in the Catalog (with thanks to Project
			Gutenberg). These featured titles are independent releases published by authors on
			ReaderPub.
		</p>
		<p>Featured Independent Releases</p>
		<div class="card-grid">
			{featuredBooks.map((b) => (
				<div class="card">
					<h3>{b.title}</h3>
					<p>{b.author}</p>
					<div class="cta-row">
						<a class="button secondary" href={b.readUrl} target="_blank" rel="noreferrer">
							Read
						</a>
						<a class="button secondary" href={b.buyUrl}>Buy</a>
					</div>
				</div>
			))}
		</div>
		<div class="cta-row">
			<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
				Browse 80,000+ books
			</a>
			<a class="button secondary" href="/publish">Start publishing</a>
		</div>
	</section>

	<section class="section">
		<h2>Common use cases</h2>
		<div class="card-grid">
			<div class="card">
				<h3>Readers</h3>
				<p>Discover books, read comfortably, and build personal reading habits.</p>
			</div>
			<div class="card">
				<h3>Authors</h3>
				<p>Publish, promote, and sell books directly to real readers.</p>
			</div>
			<div class="card">
				<h3>Public reading rooms</h3>
				<p>Curated digital shelves for communities and partners.</p>
			</div>
			<div class="card">
				<h3>Researchers</h3>
				<p>Release working papers, living books, and open archives.</p>
			</div>
			<div class="card">
				<h3>Learning programs</h3>
				<p>Support cohort-based learning and reading challenges.</p>
			</div>
			<div class="card">
				<h3>Libraries</h3>
				<p>Curate collections, serve communities, and expand digital access.</p>
			</div>
		</div>
	</section>

	<section class="footer-cta">
		<h2>Onboard your organization on ReaderPub</h2>
		<p>Libraries, publishers, and universities: tell us what you need. We’ll set up your onboarding.</p>
		<a class="button" href="/contact">Institutional onboarding</a>
	</section>

	<script is:inline>
		(() => {
			const openButtons = Array.from(document.querySelectorAll("[data-modal-open]"));
			const modals = Array.from(document.querySelectorAll(".modal"));

			const closeModal = (modal) => {
				if (!modal) return;
				modal.classList.remove("is-open");
				modal.setAttribute("aria-hidden", "true");
			};

			const openModal = (modal) => {
				if (!modal) return;
				modal.classList.add("is-open");
				modal.setAttribute("aria-hidden", "false");
			};

			openButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const target = btn.getAttribute("data-modal-open");
					const modal = target ? document.querySelector(target) : null;
					openModal(modal);
				});
			});

			modals.forEach((modal) => {
				const closeTargets = modal.querySelectorAll("[data-modal-close]");
				closeTargets.forEach((el) => el.addEventListener("click", () => closeModal(modal)));
			});

			document.addEventListener("keydown", (event) => {
				if (event.key !== "Escape") return;
				modals.forEach((modal) => closeModal(modal));
			});
		})();
	</script>
</Base>

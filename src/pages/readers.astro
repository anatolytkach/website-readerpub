---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, SITE_NAME, WEREAD_NAME } from "../consts";
---

<Base title={`${SITE_NAME} for Readers`}>
	<section class="hero reverse">
		<div>
			<h1>Read instantly on the web.</h1>
			<p class="lede">Explore 80,000+ books in the browser—no apps, no downloads.</p>
			<div class="cta-row">
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
					Browse Catalog
				</a>
				<a class="button secondary" href="https://reader.pub/books/reader/?id=67098" target="_blank" rel="noreferrer">Read sample book on WeRead</a>
			</div>
		</div>
		<img
			class="image-block"
			src="/images/readers1.png"
			alt="Reader using multiple devices with access to a large digital library"
		/>
	</section>

	<section class="split">
		<div class="section">
			<h2>Why web reading wins</h2>
			<p>The fastest way to start reading, with a full reader experience — no downloads required.</p>
			<ul class="bullets">
				<li>Most major book libraries still don’t offer a true web reader that matches the quality of native apps.</li>
				<li>Many readers don’t want to install another app or struggle with device-specific readers.</li>
				<li>With WeRead, a simple link is enough — click and start reading instantly.</li>
				<li>You get the same long-form reading comfort without setup or friction.</li>
			</ul>
		</div>
		<img
			class="image-block image-bleed-right image-xl-sm"
			src="/images/readers3.png"
			alt="Instant web reading without downloads or setup"
		/>
	</section>

	<section class="split reverse split-wide">
		<div>
			<div class="section">
				<h2>WeRead: Reader benefits</h2>
				<p>A personal reading space built for discovery and continuity.</p>
				<ul class="bullets">
					<li>Curated shelves, reading plans, and discovery lists.</li>
					<li>One library across personal, academic, and professional reading.</li>
					<li>Follow authors, series, and institutions in one feed.</li>
					<li>Private notes that stay with you across devices.</li>
				</ul>
			</div>
			<div class="section">
				<h2>BookTree: Built for serious reading</h2>
				<p>Structure, focus, and long-term work with texts.</p>
				<ul class="bullets">
					<li>Organize books, excerpts, and references across projects.</li>
					<li>Keep context while reading long and complex materials.</li>
					<li>Build personal knowledge maps from what you read.</li>
					<li>Designed for sustained attention, not endless scrolling.</li>
				</ul>
			</div>
		</div>
		<img
			class="image-block image-large-xs image-bleed-left"
			src="/images/readers2.png"
			alt="Reader benefits and structured reading illustration"
		/>
	</section>
</Base>

---
import Base from "../layouts/Base.astro";
import { SITE_NAME, WEREAD_NAME } from "../consts";
---

<Base title={`${SITE_NAME} for Readers`}>
	<section class="hero reverse">
		<div>
			<h1>Readers deserve a public, powerful library.</h1>
			<p class="lede">{WEREAD_NAME} is the web reader that makes discovery, depth, and sharing easy.</p>
			<div class="cta-row">
				<a class="button" href="/contact">Join as a reader</a>
				<a class="button secondary" href="/pricing">See pricing</a>
			</div>
		</div>
		<div class="image-placeholder image-actual">
			<img
				src="/images/readers1.png"
				alt="Reader using multiple devices with access to a large digital library"
			/>
		</div>
	</section>

	<section class="split">
		<div>
			<div class="section">
				<h2>WeRead: Reader benefits</h2>
				<p>A personal reading space built for discovery and continuity.</p>
				<ul class="bullets">
					<li>Curated shelves, reading plans, and discovery lists.</li>
					<li>One library across personal, academic, and professional reading.</li>
					<li>Follow authors, series, and institutions in one feed.</li>
					<li>Private notes that stay with you across devices.</li>
				</ul>
			</div>
			<div class="section">
				<h2>BookTree: Built for serious reading</h2>
				<p>Structure, focus, and long-term work with texts.</p>
				<ul class="bullets">
					<li>Organize books, excerpts, and references across projects.</li>
					<li>Keep context while reading long and complex materials.</li>
					<li>Build personal knowledge maps from what you read.</li>
					<li>Designed for sustained attention, not endless scrolling.</li>
				</ul>
			</div>
		</div>
		<div class="image-placeholder image-actual image-large image-bleed-right">
			<img src="/images/readers2.png" alt="Reader benefits and structured reading illustration" />
		</div>
	</section>
</Base>

---
import Base from "../layouts/Base.astro";
import { SITE_NAME } from "../consts";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
import SectionIcon from "../components/SectionIcon.astro";

const topic = Astro.url.searchParams.get("topic") ?? "";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<Base title={`${SITE_NAME} Contact`}>
	{turnstileSiteKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
	<section class="hero">
		<div>
			<div class="menu-eyebrow">GET STARTED</div>
			<h1>Connect with us</h1>
			<p class="lede">
				Tell us what you plan to publish—and in what volume—and we will get back to you with a detailed plan and instructions.
			</p>
			<p style="margin-bottom: 16px;">The publishing process, as well as our approach to reading, distributing, discussing, and selling books and other materials, is detailed in our knowledge base.</p>
			<div class="cta-row">
				<a class="button secondary" href="/kb">Knowledge base</a>
				<a class="button secondary" href="/pricing">See pricing</a>
				<button class="button" type="button" data-modal-open="#request-onboarding-modal">Contact us</button>
			</div>
		</div>
		<img
			class="image-block"
			src="/images/onboarding.webp"
			alt="ReaderPub onboarding"
			loading="lazy"
			decoding="async"
			width="980"
			height="890"
		/>
	</section>

		<SpecCardsSection class="contact-spec-cards">
			<h2>Useful tips:</h2>
			<div class="card-grid icon-grid">
				<div class="card icon-grid-card">
					<SectionIcon type="author" title="Independent authors & small publishers" />
					<div class="icon-grid-card-copy">
						<h3>Independent authors & small publishers</h3>
						<ul class="bullets">
							<li>Upload one or multiple files (Word or EPUB).</li>
							<li>WePub engine produces web publishing + optional EPUB output.</li>
							<li>Enable Buy, analytics, and fan clubs.</li>
							<li>See sales and billing reports.</li>
							<li>Monitor social activity related to your listings.</li>
							<li>Communicate with your fans and followers.</li>
							<li>Plan events and presentations.</li>
						</ul>
						<p class="direct-submit-note">
							If you already have a finished Word manuscript or EPUB file, you may not even need to contact us in advance; just publish your book right now:
						</p>
						<div class="cta-row contact-card-actions">
							<a class="button direct-submit-button" href="https://reader.pub/publish/">Submit your book</a>
						</div>
					</div>
				</div>
				<div class="card icon-grid-card contact-institutions-card">
					<SectionIcon type="library" title="Institutions & catalogs" />
					<div class="icon-grid-card-copy">
						<h3>Institutions & catalogs</h3>
						<p class="onboarding-import-lede">We import from the way collections are commonly stored today:</p>
						<ul class="bullets">
							<li>Bulk file drop (ZIP of EPUB/Word files) + metadata spreadsheet</li>
							<li>OPDS/OPDS2 feeds (where available)</li>
							<li>MARC/ONIX/CSV metadata exports + cover assets</li>
							<li>S3-compatible bucket export or rsync/FTP transfer</li>
							<li>Repository exports (institutional repositories / digital collections)</li>
							<li>We map identifiers, preserve catalog structure, and publish as a web library.</li>
						</ul>
						<button class="button request-onboarding-button contact-card-request-button" type="button" data-modal-open="#request-onboarding-modal">
Contact us for details
						</button>
					</div>
				</div>
			</div>
	</SpecCardsSection>

			<div class="modal onboarding-modal" id="request-onboarding-modal" aria-hidden="true">
				<div class="modal-backdrop" data-modal-close></div>
				<div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="request-onboarding-modal-title">
				<button class="modal-close" type="button" aria-label="Close" data-modal-close>✕</button>
			<div class="onboarding-modal-inner">
				<h3 id="request-onboarding-modal-title">Connect with us</h3>
				<p class="onboarding-modal-note">
					We serve independent authors, publishers, and institutions.<br />
					If you already have files (Word or EPUB) or maintain in-house catalogs, please mention this in your
					message.
				</p>
				{topic && <p class="contact-topic">Topic: {topic}</p>}
				<form class="onboarding-form" method="POST" action="/api/onboarding">
					<label for="your-name">Your name</label>
					<input id="your-name" name="your_name" type="text" required />

					<label for="role">I am</label>
						<select id="role" name="role" required>
							<option value="">Select one</option>
							<option value="Author">Author</option>
							<option value="Publisher">Publisher</option>
							<option value="Library">Library</option>
								<option value="University / Research">University / Research</option>
								<option value="Government organization">Government organization</option>
								<option value="Public organization">Public organization</option>
								<option value="Other business entity">Other business entity</option>
							</select>

					<div class="onboarding-conditional" id="org-group">
						<label for="name">Organization</label>
						<input id="name" name="name" type="text" />
					</div>

					<div class="onboarding-conditional" id="website-group">
						<label for="website">Website</label>
						<input id="website" name="website" type="url" />
					</div>

					<label for="email">Email</label>
					<input id="email" name="email" type="email" required />

					<label for="phone">Phone</label>
					<input id="phone" name="phone" type="tel" />

					<label for="project">What do you intend to publish or launch?</label>
					<textarea
						id="project"
						name="project"
						required
						placeholder="Example: a digital reading room, a publisher catalog, a policy library, or a new book release."
						rows="5"
					></textarea>

					<label for="titles">How many titles (estimate)</label>
					<input id="titles" name="titles" type="number" min="0" />

					<label for="timeline">Timeline</label>
					<select id="timeline" name="timeline">
						<option value="">Select one</option>
						<option value="Now">Now</option>
						<option value="This month">This month</option>
						<option value="This quarter">This quarter</option>
						<option value="Not sure yet">Not sure yet</option>
					</select>

					<fieldset>
						<legend>What features you need?</legend>
						<label><input type="checkbox" name="needs" value="Web publishing" /> Web publishing</label>
						<label><input type="checkbox" name="needs" value="Sales" /> Sales</label>
						<label><input type="checkbox" name="needs" value="Fan clubs" /> Fan clubs</label>
						<label><input type="checkbox" name="needs" value="EPUB output" /> EPUB output</label>
						<label><input type="checkbox" name="needs" value="Migration / catalog import" /> Migration / catalog import</label>
					</fieldset>

					<label for="notes">Anything else?</label>
					<textarea id="notes" name="notes" rows="4"></textarea>

					<input type="hidden" name="topic" value={topic} />
					<input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
					{turnstileSiteKey && <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>}
					<p class="onboarding-form-error" hidden></p>

					<div class="cta-row onboarding-modal-actions">
						<button class="button" type="submit">Send a message</button>
					</div>
				</form>
				</div>
			</div>
		</div>

		<div class="modal onboarding-success-modal" id="onboarding-success-modal" aria-hidden="true">
			<div class="modal-backdrop"></div>
			<div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="onboarding-success-modal-title">
				<button class="modal-close" type="button" aria-label="Close" data-success-close>✕</button>
				<div class="onboarding-success-inner">
					<p id="onboarding-success-modal-title">
						Thank you, your message has been sent.<br />
						We will get back to you soon.
					</p>
				</div>
			</div>
		</div>

<style>
		.hero .image-block {
			max-width: 391px !important;
		}

		.card .onboarding-import-lede {
			color: var(--link);
			font-size: 18px;
		}

		.request-onboarding-button {
			background: var(--accent);
			color: #ffffff;
			border-color: var(--accent);
		}

		.contact-topic {
			text-align: center;
			color: var(--muted);
		}

		:global(.contact-spec-cards .icon-grid-card) {
			align-content: start;
		}

		:global(.contact-spec-cards .icon-grid-card > .section-icon),
		:global(.contact-spec-cards .icon-grid-card .icon-grid-card-copy > h3) {
			align-self: center;
		}

		.direct-submit-note {
			margin-top: 18px !important;
			color: var(--text) !important;
		}

		.contact-card-actions {
			align-items: center;
			justify-content: flex-start;
			gap: 10px;
			margin-top: 4px;
		}

		@media (orientation: portrait) {
			.contact-card-actions {
				justify-content: center;
			}

			:global(.contact-spec-cards .icon-grid-card) {
				align-content: center;
			}
		}

		.contact-card-actions .button {
			margin-top: 0;
		}

		.direct-submit-button {
			box-sizing: border-box;
			line-height: normal;
		}

		.contact-card-request-button {
			align-self: flex-start;
			margin-top: auto;
		}

		:global(.contact-spec-cards .contact-institutions-card) {
			grid-template-rows: auto auto 1fr auto;
		}

		:global(.contact-spec-cards .contact-institutions-card .bullets) {
			align-self: start;
		}

		:global(.contact-spec-cards) {
			padding-top: 20px !important;
			padding-bottom: 14px !important;
		}

			:global(.contact-spec-cards .icon-grid) {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			:global(.onboarding-modal) {
				align-items: center;
			}

			:global(.onboarding-modal .modal-content) {
				position: relative;
				width: min(480px, calc(100vw - 32px)) !important;
				max-width: min(480px, calc(100vw - 32px)) !important;
				height: min(84dvh, 920px) !important;
				max-height: min(84dvh, 920px) !important;
				display: block !important;
				line-height: 1.35 !important;
				background: linear-gradient(135deg, var(--card) 0%, var(--card) 15%, #ffffff 100%);
				border: 1px solid var(--border);
				border-radius: 16px;
				padding: 0;
				overflow: hidden;
			}

		:global(.onboarding-modal .modal-close) {
			top: 10px;
			right: 10px;
			z-index: 4;
		}

			:global(.onboarding-modal-inner) {
				position: absolute;
				inset: 56px 4px 10px 10px;
				display: grid;
				gap: 14px;
				height: auto;
				overflow-y: auto;
				padding: 0 10px 14px;
				border-radius: inherit;
				scrollbar-gutter: stable;
				scrollbar-width: thin;
			}

			:global(.onboarding-modal-inner::-webkit-scrollbar) {
				width: 10px;
			}

			:global(.onboarding-modal-inner::-webkit-scrollbar-track) {
				background: transparent;
				margin: 10px 0;
			}

			:global(.onboarding-modal-inner::-webkit-scrollbar-thumb) {
				background: rgba(77, 91, 113, 0.45);
				border-radius: 999px;
				border: 2px solid transparent;
				background-clip: padding-box;
			}

		:global(.onboarding-modal-inner h3) {
			margin: 0;
			text-align: center;
		}

			:global(.onboarding-modal-note) {
				margin: 0;
				color: var(--text);
				font-size: 16px;
				line-height: 1.35;
				text-align: left;
			}

		:global(.onboarding-form) {
			display: flex;
			flex-direction: column;
			gap: 10px;
		}

		:global(.onboarding-form > label),
		:global(.onboarding-form legend) {
			display: block;
			font-size: 16px;
			font-weight: 500;
			color: var(--text);
			margin-top: 4px;
		}

		:global(.onboarding-form input[type="text"]),
		:global(.onboarding-form input[type="url"]),
		:global(.onboarding-form input[type="email"]),
		:global(.onboarding-form input[type="tel"]),
		:global(.onboarding-form input[type="number"]),
		:global(.onboarding-form select),
		:global(.onboarding-form textarea) {
			box-sizing: border-box;
			width: 100%;
			font: inherit;
			font-size: 16px;
			color: var(--text);
			background: #ffffff;
			border: 1px solid var(--border);
			border-radius: 10px;
			padding: 10px 12px;
			outline: none;
			appearance: none;
			-webkit-appearance: none;
			transition: border-color 0.2s ease, box-shadow 0.2s ease;
		}

		:global(.onboarding-form textarea) {
			resize: vertical;
			min-height: 110px;
		}

		:global(.onboarding-form input[type="text"]:focus),
		:global(.onboarding-form input[type="url"]:focus),
		:global(.onboarding-form input[type="email"]:focus),
		:global(.onboarding-form input[type="tel"]:focus),
		:global(.onboarding-form input[type="number"]:focus),
		:global(.onboarding-form select:focus),
		:global(.onboarding-form textarea:focus) {
			border-color: var(--accent);
			box-shadow: 0 0 0 3px rgba(0, 133, 134, 0.12);
		}

		:global(.onboarding-form fieldset) {
			border: 1px solid var(--border);
			border-radius: 10px;
			padding: 12px;
			display: grid;
			gap: 8px;
		}

		:global(.onboarding-form fieldset label) {
			display: flex;
			align-items: center;
			gap: 8px;
			color: var(--muted);
			font-weight: 400;
			font-size: 16px;
		}

		:global(.onboarding-form input[type="checkbox"]) {
			accent-color: var(--accent);
			width: 16px;
			height: 16px;
			flex: 0 0 16px;
		}

		:global(.onboarding-form-error) {
			margin: 2px 0 0;
			color: #b42318;
			font-size: 15px;
			line-height: 1.35;
			text-align: center;
		}

			:global(.onboarding-modal-actions) {
				justify-content: center;
				margin-top: 6px;
			}

			:global(.onboarding-success-modal .modal-content) {
				position: relative;
				width: min(540px, calc(100vw - 32px)) !important;
				max-width: min(540px, calc(100vw - 32px)) !important;
				display: block !important;
				line-height: 1.35 !important;
				background: linear-gradient(135deg, var(--card) 0%, var(--card) 15%, #ffffff 100%);
				border: 1px solid var(--border);
				border-radius: 16px;
				padding: 28px 24px;
			}

			:global(.onboarding-success-modal .modal-close) {
				top: 10px;
				right: 10px;
			}

			:global(.onboarding-success-inner) {
				display: grid;
				place-items: center;
				text-align: center;
				min-height: 120px;
				padding-top: 12px;
			}

			:global(.onboarding-success-inner p) {
				margin: 0;
				color: var(--text);
				font-size: 32px;
				line-height: 1.3;
				max-width: 460px;
			}

			@media (max-width: 980px) {
				:global(.contact-spec-cards .icon-grid) {
					grid-template-columns: 1fr !important;
				}
			}

			@media (max-width: 900px) {
				.hero > div > .cta-row {
					justify-content: center;
				}
			}

			@media (orientation: landscape) and (max-width: 900px) {
				:global(.onboarding-modal .modal-content) {
					height: min(92dvh, 500px) !important;
					max-height: min(92dvh, 500px) !important;
					width: min(560px, calc(100vw - 32px)) !important;
					max-width: min(560px, calc(100vw - 32px)) !important;
				}

				:global(.onboarding-modal-inner) {
					inset: 44px 10px 8px 10px;
					gap: 10px;
				}

				:global(.onboarding-modal-note) {
					font-size: 14px !important;
				}

				:global(.onboarding-form > label),
				:global(.onboarding-form legend) {
					font-size: 14px !important;
					margin-top: 2px !important;
				}

				:global(.onboarding-form input[type="text"]),
				:global(.onboarding-form input[type="url"]),
				:global(.onboarding-form input[type="email"]),
				:global(.onboarding-form input[type="tel"]),
				:global(.onboarding-form input[type="number"]),
				:global(.onboarding-form select),
				:global(.onboarding-form textarea) {
					padding: 8px 10px !important;
					font-size: 14px !important;
				}

				:global(.onboarding-success-inner p) {
					font-size: 22px !important;
				}
			}
		</style>

		<script is:inline>
			(() => {
				const requestModal = document.querySelector("#request-onboarding-modal");
				const successModal = document.querySelector("#onboarding-success-modal");
				const openButtons = Array.from(document.querySelectorAll('[data-modal-open="#request-onboarding-modal"]'));
				const onboardingForm = document.querySelector(".onboarding-form");
				const formError = onboardingForm?.querySelector(".onboarding-form-error");
				const submitButton = onboardingForm?.querySelector('button[type="submit"]');
				if (!requestModal || !successModal || !onboardingForm) return;

				const roleSelect = document.querySelector("#role");
				const orgGroup = document.querySelector("#org-group");
				const websiteGroup = document.querySelector("#website-group");
				const orgInput = document.querySelector("#name");
				const websiteInput = document.querySelector("#website");

				const updateConditionalFields = () => {
					const isAuthor = roleSelect?.value === "Author";
					if (orgGroup) {
						orgGroup.style.display = isAuthor ? "none" : "";
						if (orgInput) orgInput.required = !isAuthor;
					}
					if (websiteGroup) {
						websiteGroup.style.display = isAuthor ? "none" : "";
						if (websiteInput) websiteInput.required = !isAuthor;
					}
				};

				roleSelect?.addEventListener("change", updateConditionalFields);
				updateConditionalFields();

				const resetTurnstile = () => {
					if (window.turnstile && typeof window.turnstile.reset === "function") {
						window.turnstile.reset();
					}
				};

				const closeModal = (modalElement) => {
					modalElement.classList.remove("is-open");
					modalElement.setAttribute("aria-hidden", "true");
				};

				const openModal = (modalElement) => {
					modalElement.classList.add("is-open");
					modalElement.setAttribute("aria-hidden", "false");
				};

				openButtons.forEach((btn) => {
					btn.addEventListener("click", (event) => {
						event.preventDefault();
						if (formError) {
							formError.textContent = "";
							formError.hidden = true;
						}
						closeModal(successModal);
						openModal(requestModal);
					});
				});

				const requestCloseTargets = requestModal.querySelectorAll("[data-modal-close]");
				requestCloseTargets.forEach((el) =>
					el.addEventListener("click", () => {
						closeModal(requestModal);
					})
				);

				const successCloseTargets = successModal.querySelectorAll("[data-success-close]");
				successCloseTargets.forEach((el) =>
					el.addEventListener("click", () => {
						closeModal(successModal);
					})
				);

				onboardingForm.addEventListener("submit", async (event) => {
					event.preventDefault();
					const formData = new FormData(onboardingForm);
					const action = onboardingForm.getAttribute("action");
					const originalButtonText = submitButton?.textContent || "";

					if (formError) {
						formError.textContent = "";
						formError.hidden = true;
					}
					if (submitButton) {
						submitButton.disabled = true;
						submitButton.textContent = "Sending…";
					}

					try {
						if (!action) throw new Error("The onboarding endpoint is not configured.");
						const response = await fetch(action, {
							method: "POST",
							body: formData,
							headers: {
								Accept: "application/json",
							},
						});
						const payload = await response.json().catch(() => null);
						if (!response.ok || !payload?.ok) {
							throw new Error(payload?.error || "We could not submit your request. Please try again.");
						}

						closeModal(requestModal);
						openModal(successModal);
						onboardingForm.reset();
						updateConditionalFields();
						resetTurnstile();
					} catch (error) {
						if (formError) {
							formError.textContent = error instanceof Error ? error.message : "We could not submit your request. Please try again.";
							formError.hidden = false;
						}
						resetTurnstile();
					} finally {
						if (submitButton) {
							submitButton.disabled = false;
							submitButton.textContent = originalButtonText;
						}
					}
				});

				document.addEventListener("keydown", (event) => {
					if (event.key === "Escape") {
						closeModal(requestModal);
						closeModal(successModal);
					}
				});
			})();
		</script>
	</Base>

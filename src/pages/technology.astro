---
import Base from "../layouts/Base.astro";
import { BOOKS_URL, SITE_NAME } from "../consts";
import ProofSection from "../components/sections/ProofSection.astro";
import SpecCardsSection from "../components/sections/SpecCardsSection.astro";
---

<Base title={`${SITE_NAME} Technology`}>
	<ProofSection variant="hero">
		<div>
			<h1>Built for web-native publishing at scale.</h1>
			<p class="lede">
				ReaderPub powers instant reading, structured publishing, and analytics for authors and
				institutions.
			</p>
			<p>ReaderPub supports web publishing plus commerce: sales (5%), rentals (5%), and analytics.</p>
			<p>The same publishing pipeline can output both a public web edition and a production-ready EPUB.</p>
		</div>
		<img
			slot="media"
			class="image-block proof-media"
			src="/images/technology.webp"
			alt="Technology and publishing workflows for public and institutional reading"
			loading="lazy"
			decoding="async"
			width="4088"
			height="4138"
		/>
	</ProofSection>

	<SpecCardsSection class="section-continue-next">
		<h2>What powers ReaderPub</h2>
		<div class="card-grid powers-grid">
			<div class="card">
				<h3>WeRead</h3>
				<p>Instant web reading for readers and shared libraries.</p>
				<a class="button" href={BOOKS_URL} target="_blank" rel="noreferrer">
					Browse Catalog
				</a>
			</div>
			<div class="card">
				<h3>WePub</h3>
				<p>Web publishing and distribution for authors and institutions.</p>
				<button class="button secondary" type="button" data-modal-open="#wepub-modal">
					Explore WePub
				</button>
			</div>
			<div class="card">
				<h3>BookTree</h3>
				<p>Sources, excerpts, and structured work across texts.</p>
				<button class="button secondary" type="button" data-modal-open="#booktree-modal">
					Explore BookTree
				</button>
			</div>
			<div class="card">
				<h3>Analytics</h3>
				<p>Sales, rentals, and engagement across catalogs and audiences.</p>
				<a class="button secondary" href="/contact#request-onboarding">Request pricing</a>
			</div>
		</div>
	</SpecCardsSection>

	<ProofSection class="proof-section-full section-continuation section-continue-next">
		<picture slot="media" class="image-full">
			<source srcset="/images/chain1.webp" media="(orientation: portrait)" />
			<img
				src="/images/chain.webp"
				alt="Connected reading and publishing chain"
				loading="lazy"
				decoding="async"
				width="1200"
				height="206"
			/>
		</picture>
	</ProofSection>

	<SpecCardsSection class="section-continuation section-continue-next">
		<div class="card-grid powers-grid powers-grid-two">
			<div class="card">
				<h2>Built for scale</h2>
				<p>A modern foundation for public and professional reading at scale.</p>
				<ul class="bullets">
					<li>Web-native reading — fast, accessible reading in the browser. No apps, no downloads.</li>
					<li>Designed for real catalogs — works with large, structured collections.</li>
					<li>Reader-first experience — clean typography and deep navigation for long-form reading.</li>
				</ul>
			</div>
			<div class="card">
				<h2>Why this matters</h2>
				<p>Flexibility and access for every audience.</p>
				<ul class="bullets">
					<li>No proprietary apps required</li>
					<li>No lock-in to a single deployment model</li>
					<li>Suitable for libraries, universities, publishers, and public organizations</li>
					<li>Scales from public catalogs to institutional programs</li>
					<li>Built for institutions — supports public access and controlled publishing programs.</li>
				</ul>
			</div>
		</div>
	</SpecCardsSection>

	<section class="footer-cta section-continuation tech-footer-cta">
		<p>Interested in how this fits your organization?</p>
		<a class="button footer-cta-button" href="/contact#request-onboarding">Request information</a>
	</section>

	<div class="modal" id="wepub-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="WePub image">
			<button class="modal-close" type="button" aria-label="Close" data-modal-close>
				×
			</button>
			<img src="/images/wepub.webp" alt="WePub image" loading="lazy" decoding="async" width="1024" height="592" />
		</div>
	</div>

	<div class="modal" id="booktree-modal" aria-hidden="true">
		<div class="modal-backdrop" data-modal-close></div>
		<div class="modal-content" role="dialog" aria-modal="true" aria-label="BookTree image">
			<button class="modal-close" type="button" aria-label="Close" data-modal-close>
				×
			</button>
			<img src="/images/booktree.webp" alt="BookTree image" loading="lazy" decoding="async" width="976" height="1219" />
		</div>
	</div>

	<script is:inline>
		(() => {
			const openButtons = Array.from(document.querySelectorAll("[data-modal-open]"));
			const modals = Array.from(document.querySelectorAll(".modal"));

			const closeModal = (modal) => {
				if (!modal) return;
				modal.classList.remove("is-open");
				modal.setAttribute("aria-hidden", "true");
			};

			const openModal = (modal) => {
				if (!modal) return;
				modal.classList.add("is-open");
				modal.setAttribute("aria-hidden", "false");
			};

			openButtons.forEach((btn) => {
				btn.addEventListener("click", () => {
					const target = btn.getAttribute("data-modal-open");
					const modal = target ? document.querySelector(target) : null;
					openModal(modal);
				});
			});

			modals.forEach((modal) => {
				const closeTargets = modal.querySelectorAll("[data-modal-close]");
				closeTargets.forEach((el) => el.addEventListener("click", () => closeModal(modal)));
			});

			document.addEventListener("keydown", (event) => {
				if (event.key !== "Escape") return;
				modals.forEach((modal) => closeModal(modal));
			});
		})();
	</script>

	<style>
		.footer-cta-button {
			width: max-content;
			max-width: 100%;
			place-self: center;
		}

		.tech-footer-cta {
			padding-top: 29px !important;
			padding-bottom: 29px !important;
		}

		.powers-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
			justify-content: stretch;
		}

		.powers-grid-two {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.proof-section-full {
			grid-template-columns: 1fr;
		}

		@media (max-width: 1100px) {
			.powers-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
		}

		@media (max-width: 720px) {
			.powers-grid {
				grid-template-columns: 1fr;
			}

			.powers-grid-two {
				grid-template-columns: 1fr;
			}

		}
	</style>
</Base>

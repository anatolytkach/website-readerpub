---
import Base from "../../layouts/Base.astro";
import { SITE_NAME } from "../../consts";
---

<Base title={`${SITE_NAME} for Libraries`}>
	<section class="hero reverse">
		<div>
			<h1>Libraries extend their mission into the public web.</h1>
			<p class="lede">Create digital reading rooms that serve patrons, partners, and communities.</p>
		</div>
		<div class="image-placeholder">IMAGE PLACEHOLDER</div>
	</section>

	<section class="section">
		<h2>Library benefits</h2>
		<p>Extend collections with digital programs and access.</p>
		<ul class="bullets">
			<li>Curate shelves and programs with public visibility.</li>
			<li>Support community reading initiatives and cohorts.</li>
			<li>Extend collections with modern web access.</li>
			<li>Track engagement to guide programming.</li>
		</ul>
	</section>
</Base>

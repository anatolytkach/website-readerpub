---
import Base from "../../layouts/Base.astro";
import { SITE_NAME } from "../../consts";
---

<Base title={`${SITE_NAME} for Government`}>
	<section class="hero reverse">
		<div>
			<h1>Government publishes with transparency and reach.</h1>
			<p class="lede">Make public documents, research, and policy libraries easy to find and read.</p>
		</div>
		<div class="image-placeholder">IMAGE PLACEHOLDER</div>
	</section>

	<section class="section">
		<h2>Government benefits</h2>
		<ul class="bullets">
			<li>Centralize reports, regulations, and public resources.</li>
			<li>Serve staff and constituents with the same library.</li>
			<li>Improve transparency with accessible reading formats.</li>
			<li>Track public engagement to inform policy work.</li>
		</ul>
	</section>
</Base>

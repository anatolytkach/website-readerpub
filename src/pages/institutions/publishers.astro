---
import Base from "../../layouts/Base.astro";
import { SITE_NAME } from "../../consts";
---

<Base title={`${SITE_NAME} for Publishers`}>
	<section class="hero reverse">
		<div>
			<h1>Publishers grow reach without losing control.</h1>
			<p class="lede">Launch catalogs, previews, and programs on a public platform built for discovery.</p>
		</div>
		<div class="image-placeholder">IMAGE PLACEHOLDER</div>
	</section>

	<section class="section">
		<h2>Publisher benefits</h2>
		<p>Reach readers while keeping control of access.</p>
		<ul class="bullets">
			<li>Showcase frontlist and backlist with confidence.</li>
			<li>Offer public previews or private access by segment.</li>
			<li>Measure engagement and demand by title.</li>
			<li>Build direct relationships with readers and institutions.</li>
		</ul>
	</section>
</Base>

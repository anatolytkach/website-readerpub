---
import Base from "../../layouts/Base.astro";
import { SITE_NAME } from "../../consts";
---

<Base title={`${SITE_NAME} for Public Organizations`}>
	<section class="hero reverse">
		<div>
			<h1>Public organizations amplify mission-driven knowledge.</h1>
			<p class="lede">Publish reports, guides, and resources that reach the right communities.</p>
		</div>
		<div class="image-placeholder">IMAGE PLACEHOLDER</div>
	</section>

	<section class="section">
		<h2>Public organization benefits</h2>
		<p>Share mission resources with clarity and reach.</p>
		<ul class="bullets">
			<li>Share mission resources with clarity and permanence.</li>
			<li>Curate collections for partners and constituents.</li>
			<li>Launch public reading programs and campaigns.</li>
			<li>Build trust with transparent, accessible publishing.</li>
		</ul>
	</section>
</Base>

---
import Base from "../../layouts/Base.astro";
import { SITE_NAME } from "../../consts";
---

<Base title={`${SITE_NAME} for Universities`}>
	<section class="hero reverse">
		<div>
			<h1>Universities publish research with visibility and trust.</h1>
			<p class="lede">Support faculty, labs, and students with a public research library.</p>
		</div>
		<div class="image-placeholder">IMAGE PLACEHOLDER</div>
	</section>

	<section class="section">
		<h2>University benefits</h2>
		<p>Support research and learning with public access.</p>
		<ul class="bullets">
			<li>Release working papers, reports, and open archives.</li>
			<li>Power coursework reading and cohort programs.</li>
			<li>Unify campus libraries and departmental collections.</li>
			<li>Highlight institutional expertise to the public.</li>
		</ul>
	</section>
</Base>
